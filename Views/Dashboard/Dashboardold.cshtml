    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {

                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}

<style>
    /* Your existing styles */
    .rating-button-container {
        margin-bottom: 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .rating-button {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 8px 15px;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

        .rating-button:hover {
            background-color: #0056b3;
        }

        .rating-button.active {
            background-color: #28a745; /* Green for active/selected rating */
            font-weight: bold;
        }

    .chart-container {
        position: relative;
        height: 50vh; /* Responsive height for the chart */
        width: 100%;
        margin: auto;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
    }

    /* --- NEW STYLES FOR THE CLICKABLE CARD --- */
    .trend-redirect-card {
        background-color: #00698f; /* Match your existing header color */
        color: #ffffff;
        padding: 25px;
        border-radius: 8px;
        text-align: center;
        cursor: pointer; /* Indicates it's clickable */
        transition: background-color 0.3s ease, transform 0.2s ease;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); /* Subtle shadow */
        margin-bottom: 20px; /* Space below the card */
    }

        .trend-redirect-card:hover {
            background-color: #005a7a; /* Darken on hover */
            transform: translateY(-3px); /* Slightly lift on hover */
        }

        .trend-redirect-card h3 {
            color: #ffffff; /* Ensure title is white */
            margin-bottom: 10px;
        }

        .trend-redirect-card p {
            color: #e0e0e0; /* Lighter text */
            font-size: 1.1em;
            margin-bottom: 15px;
        }

        .trend-redirect-card .fas {
            font-size: 3em; /* Large icon */
            color: #FFD700; /* Gold color for icon */
        }
</style>


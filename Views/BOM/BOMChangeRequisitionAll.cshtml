            });

        }
        });

    });
</script>
<script>
    $(document).ready(function () {
    // Function to update the final product name and check for existing combinations
    function updateProductName() {
        var productName = "";

        // Get selected values from all dropdowns (Values of Selection)

        var canopy = $("#canopy").val();
        var fueltank = $("#fueltank").val();
        var exhaustsystem = $("#exhaustsystem").val();
        var acoustictreatment = $("#acoustictreatment").val();
        var finalpacking = $("#finalpacking").val();
        var assembly = $("#assembly").val();
        var electrical = $("#electrical").val();
        var finalItemv = $("#finalItem").val();
        var baseframev = $("#baseframe").val();
        var dgassyv = $("#dgassy").val();
        var panelv = $("#panel").val();
        var alternatorv = $("#alternator").val();
        

        // Get selected text for product name (Final Product Name Text)
        var finalItem = $("#finalItem option:selected").text();
        var baseframe = $("#baseframe option:selected").text();
        var dgassy = $("#dgassy option:selected").text();
        var panel = $("#panel option:selected").text();
        var alternator = $("#alternator option:selected").text();

        // Build the product name string for display
        var selectedValues = [finalItem + ' With', baseframe + ' - Base Frame', alternator + ' - Alternator', dgassy + ' - Type', panel + ' - Panel'];
        productName = selectedValues.filter(Boolean).join(" | ");

        // Update the "Final Product" input field
        $("#FinalProduct").val(productName);

        // Prepare data to send to the controller
        var dataToSend = {
           
            finalItem: finalItemv,
            canopy: canopy,
            fueltank: fueltank,
            exhaustsystem: exhaustsystem,
            acoustictreatment: acoustictreatment,
            finalpacking: finalpacking,
            assembly: assembly,
            baseframe: baseframev,
            dgassy: dgassyv,
            panel: panelv,
            alternator: alternatorv,
            electrical: electrical
        };

        // AJAX call to the controller
        $.ajax({
            type: "GET",
            url: "@Url.Action("CheckProductCombination", "BOM")", // Replace "BOM" with your actual controller name
            data: dataToSend,
            success: function (response) {
                if (response.success) {
                    toastr.success(response.msg);
                    debugger;
                    $('#convertbom').prop('disabled', false);
                    //$('#FinalProductCode').prop('disabled', false);
                    $('#FinalProductCode').val(response.itemcode);
                    // Combination does NOT exist, allow saving
                } else {
                    toastr.error(response.msg);
                    $('#convertbom').prop('disabled', true);
                    $('#FinalProductCode').prop('disabled', true);
                    $('#FinalProductCode').val('');
                    // Combination exists, prevent saving
                }
            },
            error: function (xhr, status, error) {
                console.error("Error checking product combination:", error);
                // ... handle the error (e.g., display an error message)
            }
        });
    }
        // Attach change event handlers to all select elements
    $("select.form-control-sm").change(function () {
        updateProductName();
    });
});
</script>



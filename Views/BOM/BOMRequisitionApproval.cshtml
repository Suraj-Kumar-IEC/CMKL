    function formatDate(dateStr) {
        if (!dateStr) {
            return ''; // or some other default value
        }
        var timestamp = parseInt(dateStr.replace(/\/Date\((\d+)\)\//, '$1'));
        var date = new Date(timestamp);
        var day = date.getDate();
        var month = date.getMonth() + 1;
        var year = date.getFullYear();
        var hours = date.getHours();
        var minutes = date.getMinutes();
        var seconds = date.getSeconds();

        return `${padZero(day)}/${padZero(month)}/${year} ${padZero(hours)}:${padZero(minutes)}:${padZero(seconds)}`;
    }

    function padZero(value) {
        return (value < 10 ? '0' : '') + value;
    }

    function loadVouchers() {
    $('#wait-sign').show();

    $.ajax({
        type: 'GET',
        url: '@Url.Action("GetRequisitions", "BOM")',
        success: function (data) {
            $('#wait-sign').hide();
            var hasUnapprovedOrders = false;
            $('#voucher-table-body').empty();

            // Debugging: View the data structure in your browser console (F12)
            console.log("Voucher Data Received:", data);

            if (!data || data.length === 0) {
                $('#voucher-table-body').append('<tr><td colspan="7" class="text-center text-muted">No requisitions found.</td></tr>');
                return;
            }

            $.each(data, function (index, item) {
                let approvalButton = '';

                // FIX: Use loose equality (==) or check for common "unapproved" values
                // This handles if the server returns 0, "0", false, or null.
                // Also check for lowercase 'isApproved' in case of JSON serialization changes.
               // var status = (item.IsApproved !== undefined) ? item.IsApproved : item.isApproved;

                //if (status == 0 || status == "0" || status === false) {
                    approvalButton = '<a href="#" class="btn btn-success btn-sm ms-1" id="Approve" onclick="approveVoucher(' + item.id + ', this)">Approve</a>';
                    hasUnapprovedOrders = true;
               // }

                $('#voucher-table-body').append(`
                    <tr>
                        <td>${item.BOMReqeusitionNo || 'N/A'}</td>
                        <td>${item.BOMNumber || 'N/A'}</td>
                        <td>${item.OldFG || 'N/A'}</td>
                        <td>${item.NewFG || 'N/A'}</td>
                        <td>${formatDate(item.Createdon)}</td>
                        <td>${item.Createdby || 'System'}</td>
                        <td>
                            <button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#viewLinesModal" onclick="loadLines(${item.id})">View Lines</button>
                            ${approvalButton}
                        </td>
                    </tr>
                `);
            });
        },
        error: function (xhr) {
            $('#wait-sign').hide();
            console.error("Error loading vouchers:", xhr.responseText);
            toastr.error("Failed to load requisition list.");
        }
    });
}


        function loadLines(voucherId) {
        debugger;
        $.ajax({
            type: 'GET',
            url: '@Url.Action("GetRequisitionLines", "BOM")',
            data: { voucherId: voucherId },
            success: function (data) {
                var audio = new Audio('/Sound/Save.mp3');
                audio.play();
                $('#lines-table-body').empty();
                $.each(data, function (index, item) {
                    $('#lines-table-body').append(`
                        <tr>
                            <td>${item.CategoryName}</td>
                            <td>${item.SubcategoryName}</td>
                            <td>${item.FinalItemName}</td>
                            <td>${item.RawItemName}</td>
                            <td>${item.QuantityRequired}</td>
                            <td>${item.UOM}</td>
                            <td>${item.Action}</td>
                            <td>${item.Stock}</td>
                        </tr>
                    `);
                });
                $('#viewLinesModal').modal('show');
            }

        });
    }
            function approveVoucher(voucherId, element) {
            const $el = $(element);
            const originalContent = $el.html();

            // 1. UI Feedback
            $('#wait-sign').show();
            $el.addClass('disabled').css('pointer-events', 'none');
            $el.html('<i class="fas fa-spinner fa-spin"></i> Processing...');

            $.ajax({
                type: 'POST',
                url: '@Url.Action("ApproveReqisitionVouchernew", "BOM")',
                data: { voucherId: voucherId },
                success: function (data) {
                    $('#wait-sign').hide();

                    var isSuccess = data.success || data.Success;
                    var message = data.msg || data.message || "";
                    // Check for both 'details' and 'Negativeitems' for backward compatibility
                    var details = data.details || data.Details || data.Negativeitems || [];

                    if (isSuccess) {
                        toastr.success(message || "Voucher approved successfully!", "Success", {
                            timeOut: 12000,
                            closeButton: true,
                            progressBar: true
                        });
                        if (typeof loadVouchers === 'function') loadVouchers();
                    }
                    else {
                        // FAILURE: Handle detailed validation lists
                        if (message.includes("Validation failed") || details.length > 0) {
                            let detailMsg = `<strong>${message}</strong>`;

                            if (details.length > 0) {
                                detailMsg += '<ul style="margin-top: 10px; padding-left: 20px; text-align: left; font-size: 13px;">';
                                $.each(details, function(i, item) {
                                    // Style: Stock errors in red, Lot errors in orange
                                    let color = item.includes("[Stock]") ? "#dc3545" : "#fd7e14";
                                    detailMsg += `<li style="color: ${color}; margin-bottom: 4px;">${item}</li>`;
                                });
                                detailMsg += '</ul>';
                            }

                            toastr.warning(detailMsg, "Validation Alert", {
                                timeOut: 0,           // Sticky
                                extendedTimeOut: 0,
                                closeButton: true,
                                allowHtml: true,      // Essential for <ul>
                                tapToDismiss: false
                            });
                        }
                        else {
                            toastr.error(message || "Error approving voucher!");
                        }

                        // Reset button so user can retry
                        $el.removeClass('disabled').css('pointer-events', 'auto');
                        $el.html(originalContent);
                    }
                },
                error: function (xhr, status, error) {
                    $('#wait-sign').hide();
                    toastr.error("A network error occurred. Please try again.");
                    $el.removeClass('disabled').css('pointer-events', 'auto');
                    $el.html(originalContent);
                }
            });
        }

    $('#viewLinesModal .close').on('click', function () {
        $('#viewLinesModal').modal('hide');
    });

</script>


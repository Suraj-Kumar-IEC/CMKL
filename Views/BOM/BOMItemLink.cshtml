<script>
$("#Item").autocomplete({
    appendTo: $("#Item").parent(), // Append to the parent element of #Item
    source: function (request, response) {
        $.ajax({
            url: '@Url.Action("searchraw", "BOM")',
            dataType: "json",
            data: { itemname: request.term },
            success: function (data) {
                console.log(data); // Add this to see if data is being received
                response($.map(data, function (item) {
                    return { label: item.label, value: item.label };
                }));
            },
            error: function (xhr, status, error) {
                alert("Error");
            }
        });
    },
    select: function (event, ui) {
        // Display the selected itemname in the original input field
        $(this).val(ui.item.label);
        // Store the selected itemid in a hidden input field
        $("#ItemId").val(ui.item.value);
        // Update the selected option in the dropdown list
        $("#raw").val(ui.item.label);
    }
});
</script>

<script>
    $("#exportToExcel").click(function () {
        var bomTable = $("#bom-table"); // Make sure to select the correct table element
        var data = [];
        debugger;
        bomTable.find("tr:gt(0)").each(function () { // Skip the header row
            var row = [];
            $(this).find("td").each(function () {
                var cellValue = $(this).text();
                row.push(cellValue);
            });
            data.push(row);
        });

        try {
            var jsonData = JSON.stringify({ data: data }); // Wrap data in an object
            $.ajax({
                type: "POST",
                url: "/BOM/GenerateExcel",
                data: jsonData,
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    var filePath = response.filePath;
                    // Remove previous download link
                    $("#download-button-container a").remove();
                    // Create a new download button
                    var downloadButton = $("<a>", {
                        href: "/Files/" + filePath,
                        text: "Download BOM_List.xlsx",
                        download: "BOM_List.xlsx"
                    });
                    // Append the button to the page
                    $("#download-button-container").append(downloadButton);
                    toastr.success(`BOM Excel File Generated - Please click <a href="/Files/${filePath}" download="BOM_List.xlsx">here</a> to download`);
                }
            });
        } catch (e) {
            console.error("Error converting data to JSON:", e);
        }
    });
</script>



<script type="text/javascript">
    $(function () {
        var previousValue = "";
        $("#finalItem").click(function () {
            var currentValue = $(this).val();
            if (currentValue !== previousValue) {
                previousValue = currentValue;
                $.ajax({
                    url: '@Url.Action("GetFinalItems", "BOM")',
                    type: 'GET',
                    dataType: 'json',
                    success: function (data) {
                        $('#finalItem').empty(); // clear existing options
                        var options = '';
                        $.each(data, function (index, item) {
                            options += '<option value="' + item.Value + '">' + item.Text + '</option>';
                        });
                        $('#finalItem').append(options); // append new options
                        $('#finalItem').val(previousValue); // select the previously selected value
                    }
                });
            }
        });
    });
</script>


<script>
$("#createbom").click(function (e) {
    e.preventDefault();
    var finalItemv = $("#finalItem").val();
    var finalItem = $("#finalItem option:selected").text();
    var totalQuantity = $("#totalQuantity").val();
    var baseframe = $("#baseframe").val();
    var dgassy = $("#dgassy").val();
    var panel = $("#panel").val();
    var alternator = $("#alternator").val();
    var canopy = $("#canopy").val();
    var fueltank = $("#fueltank").val();
    var assembly = $("#assembly").val();
    var acoustictreatment = $("#acoustictreatment").val();
    var exhaustsystem = $("#exhaustsystem").val();
    var final = $("#finalpacking").val();
    var electrical = $("#electrical").val();
    debugger;

    if (finalItem == '' || totalQuantity == '') {
        toastr.info('Please fill in all fields');
        //$('#ItemName').focus();
        e.preventDefault();
        return false;
    }

    $.ajax({
        type: "POST",
        url: '@Url.Action("CreateBOM", "BOM")',
        data: {
            finalItem: finalItem, totalQuantity: totalQuantity, baseframe: baseframe, dgassy: dgassy, panel: panel, alternator: alternator
            , canopy: canopy, fueltank: fueltank, assembly: assembly, acoustictreatment: acoustictreatment, exhaustsystem: exhaustsystem, final: final, electrical: electrical
        },
        success: function (data) {
            $("#bom-list").html(data);
            toastr.success('BOM List Successfully Created');
            // alert("BOM created successfully!");
        },
        error: function (xhr, status, error) {
            console.log("Error: " + error);
            console.log("Status: " + status);
            console.log("XHR: " + xhr.responseText);
        }
    });
    return false;
});
</script>


@{
    ViewBag.Title = "BOMlinkandItemDetail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}


<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h2>Search Item Code</h2>
            <form>
                <div class="form-group">
                    <label for="itemCode">Item Code:</label>
                    <input type="text" id="itemCode" name="itemCode" class="form-control" />
                    <button type="button" id="searchButton" class="btn btn-primary">Search</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <h2>Item Information</h2>
            <table id="itemInfoTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>Item ID</th>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Description</th>
                        <th>UOM</th>
                        <th>Basic Price</th>
                        <th>Min Stock Level</th>
                        <th>Max Stock Level</th>
                        <th>Stock</th>
                        <th>Rejected Stock</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="itemInfoTbody">
                </tbody>
            </table>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <h2>Raw Item Information</h2>
            <table id="rawItemTable" class="table table-striped">
                <thead>
                    <tr>
                        <th>BOM ID</th>
                        <th>Master Item</th>
                        <th>Parent Item</th>
                        <th>Parent Sub</th>
                        <th>Raw Item</th>
                        <th>Quantity</th>
                        <th>UOM</th>
                    </tr>
                </thead>
                <tbody id="rawItemTbody">
                </tbody>
            </table>
        </div>
    </div>

    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/toastr/Js/toastr.js"></script>
    <link href="~/toastr/toastr.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.16.2/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/exceljs/4.2.1/exceljs.min.js"></script>

    <script>
$(document).ready(function () {
    $('#searchButton').on('click', function () {
        var itemCode = $('#itemCode').val();
        $.ajax({
            type: 'GET',
            url: '@Url.Action("SearchItem", "BOM")',
            data: { itemCode: itemCode },
            success: function (data) {
                $('#itemInfoTbody').empty();
                $('#rawItemTbody').empty();

                if (data.itemInfo) {
                    var item = data.itemInfo;
                    $('#itemInfoTbody').append('<tr>' +
                        '<td>' + item.Itemid + '</td>' +
                        '<td>' + item.ItemCode + '</td>' +
                        '<td>' + item.ItemName + '</td>' +
                        '<td>' + item.Desc + '</td>' +
                        '<td>' + item.UOM + '</td>' +
                        '<td>' + item.BasicPrice + '</td>' +
                        '<td>' + item.Minstklvl + '</td>' +
                        '<td>' + item.Maxstklvl + '</td>' +
                        '<td>' + item.Stock + '</td>' +
                        '<td>' + item.RejectedStock + '</td>' +
                        '<td><button type="button" class="btn btn-danger" onclick="deleteItem(' + item.Itemid + ')">Delete</button></td>' +
                        '</tr>');
                } else {
                    toastr.error('Item Not Found');
                    //console.log("No item info found");
                }

                $.each(data.rawItemInfo, function (index, item) {
                    $('#rawItemTbody').append('<tr>' +
                        '<td>' + item.BOMid + '</td>' +
                        '<td>' + item.MasterItem + '</td>' +
                        '<td>' + item.ParentItem + '</td>' +
                        '<td>' + item.ParentSub + '</td>' +
                        '<td>' + item.RawItem + '</td>' +
                        '<td>' + item.Quantity + '</td>' +
                        '<td>' + item.UOM + '</td>' +
                        '</tr>');
                });
            }
        });
    });
});

function deleteItem(itemId) {
    if (confirm("Are you sure you want to delete this item?")) {
        debugger;
        $.ajax({
            type: 'Post',
            url: '@Url.Action("DeleteItem", "BOM")',
            data: { itemId: itemId },
            success: function (data) {
                if (data.success)
                {
                    toastr.success("Item deleted successfully.");
                    //$('#searchButton').click();
                    $('#itemInfoTbody').empty();
                    $('#rawItemTbody').empty();

                }

                else {
                    toastr.error(data.error);
                }
            }
        });
    }
}
    </script>
</div>
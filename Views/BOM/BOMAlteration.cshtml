
@{
    ViewBag.Title = "BOMAlteration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}

<div class="container">
    <div class="row">
        <div class="col-md-3">
            <label>Select BOM</label>
            <select id="bomid" class="form-control form-control-sm">
            </select>
        </div>
        <div class="col-md-3">
            <label>Final Item Series</label>
            <input type="text" id="fgseries" class="form-control form-control-sm" disabled />
        </div>
        <div class="col-md-3">
            <label>FG Item Code</label>
            <input type="text" id="fgcode" class="form-control form-control-sm" disabled />
        </div>
        <div class="col-md-3">
            <label>FG Desc</label>
            <input type="text" id="fgdesc" class="form-control form-control-sm" disabled />
        </div>
    </div>
</div>
<br />
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-3">
            <div class="left-side">
                <form>
                    <div class="form-group">
                        <label for="itemCode" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Item Code</label>
                        <input type="text" id="itemCode" class="form-control form-control-sm" />
                        <input type="text" id="itemid" class="form-control form-control-sm" style="display:none" />
                    </div>
                    <div class="form-group">
                        <label for="itemDesc" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Item Description</label>
                        <input type="text" id="itemDesc" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="form-group">
                        <label for="uom" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">UOM</label>
                        <input type="text" id="uom" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="form-group">
                        <label for="Category" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Category</label>
                        <select id="category" class="form-control form-control-sm"></select>
                        <input type="text" id="categoryid" class="form-control form-control-sm" style="display:none" />
                    </div>
                    <div class="form-group">
                        <label for="subcategory" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Sub Category</label>
                        <select id="subcategory" class="form-control form-control-sm"></select>
                        <input type="text" id="subcategoryid" class="form-control form-control-sm" style="display:none" />
                    </div>
                    <div class="form-group">
                        <label for="stock" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Available Stock</label>
                        <input type="text" id="stock" class="form-control form-control-sm" disabled />
                    </div>
                    <div class="form-group">
                        <label for="quantityRequired" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Quantity Required</label>
                        <input type="text" id="quantityRequired" class="form-control form-control-sm" />
                    </div>
                    <button id="addButton" class="btn btn-primary" style="background-color:#00698f">Add Item</button>
                </form>
            </div>
        </div>
        <div class="col-md-9">
            <div class="right-side">
                <h4 style="background-color: #00698f; color: #ffffff; padding: 5px 12px; border-radius: 5px; text-align: center;">Items</h4>
                <div class="table-container">
                    <table id="itemLinesTableold" class="table table-striped table-sm">
                        <thead>
                            <tr>
                                <th>Item Code</th>
                                <th>Item Name</th>
                                <th>Category</th>
                                <th>Sub Category</th>
                                <th>Quantity</th>
                                <th>UOM</th>
                                <th>Approved By</th>
                                <th>Approved Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="itemLinesoldTbody">
                            <!-- table rows will be added dynamically using ajax -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" role="dialog" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background-color:#00698f; color:#fff;">
                <h5 class="modal-title" id="confirmDeleteModalLabel">
                    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>&nbsp; Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to remove the following item from this BOM?</p>
                <p><strong id="deleteItemNameLabel" style="color:#c0392b;"></strong></p>
                <p class="text-muted" style="font-size:0.85rem;">
                    This will reverse the stock deduction and release any FIFO lot allocation for this line.
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa fa-trash" aria-hidden="true"></i>&nbsp; Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        loadBOM();
        // Fetch Data of Categories
        $.ajax({
            type: 'GET',
            url: "/BOM/linkmasterlist",
            success: function (data) {
                var dropdown = $('#category'); // Replace 'categoryDropdown' with the actual ID of your dropdown.
                dropdown.empty(); // Clear existing options

                dropdown.append($('<option></option>').val("").text("Select Category"));
                $.each(data.categorylist, function (index, item) {
                    dropdown.append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
            },
            error: function (jqXHR, textStatus, errorThrown) {
                console.error("Error fetching categories:", textStatus, errorThrown);
                // Optionally, display an error message to the user.
            }
        });
        function loadBOM() {
            $.ajax({
                type: 'GET',
                url: '/Reports/GetBomNumbers', // Corrected URL: URL to url
                success: function (data) {
                    var dropdown = $('#bomid'); // Corrected selector: ('#bomid') to $('#bomid')
                    dropdown.empty(); // Clear existing options
                    dropdown.append($('<option>', {
                        value: '',
                        text: 'Select Voucher'
                    }));
                    $.each(data.list, function (i, item) { // Corrected: $each to $.each
                        dropdown.append($('<option>', {
                            value: item.value,
                            text: item.text
                        }));
                    });
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.error("Error fetching BOM numbers:", textStatus, errorThrown);
                    // Optionally display an error message to the user
                }
            });
        }

        $('#bomid').change(function () {
            var bomidnumber = $(this).val();
            GetBOMItems(bomidnumber);
        });
        $('#addButton').click(function () {
            event.preventDefault();
            
            var itemid = $('#itemid').val();
            var uom = $('#uom').val();
            var category = $('#category option:selected').val();
            var subcategory = $('#subcategory option:selected').val();
            var quantityRequired = $('#quantityRequired').val();
            var bomidnumber = $('#bomid option:selected').val();
            $.ajax({
                type: 'POST',
                url: '/BOM/AddBomAlterationItems',
                data: { itemid: itemid, uom: uom, category: category, subcategory: subcategory, quantityRequired: quantityRequired, bomidnumber: bomidnumber },
                success: function (data) {
                    //clear all fields 
                    
                    $('#itemCode').val('');
                    $('#itemDesc').val('');
                    $('#itemid').val('');
                    $('#stock').val('');
                    $('#uom').val('');                   
                    $('#quantityRequired').val(0);
                    
                  
                    GetBOMItems(bomidnumber);
                    toastr.success(data.msg);
                }
            });


        });

        function GetBOMItems(bomidnumber) {
            
            $.ajax({
                type: 'GET',
                url: '/BOM/GetBOMAlterationItems',
                data: { bomidnumber: bomidnumber },
                success: function (data) {
                    var table = $('#itemLinesTableold').find('tbody');
                    table.empty(); // Clear existing table rows
                    //Load Head Values
                    $('#fgcode').val('');
                    $('#fgcode').val(data.head.fgcode);
                    $('#fgdesc').val('');
                    $('#fgdesc').val(data.head.fgdesc);
                    $('#fgseries').val('');
                    $('#fgseries').val(data.finalitemdesc);
                    $.each(data.items, function (i, item) {
                        var formattedDate;
                        if (item.ApprovedDate) { // Check if ApprovedDate is not null or undefined
                            var date = new Date(parseInt(item.ApprovedDate.substr(6)));
                            formattedDate = moment(date).format('DD/MM/YYYY');
                        } else {
                            formattedDate = 'NA'; // Display 'NA' if ApprovedDate is null
                        }

                        var row = '<tr>' +
                            '<td style="display:none;">' + (item.Lineid || '') + '</td>' +
                            '<td>' + item.RItemCode + '</td>' +
                            '<td>' + item.ItemName + '</td>' +
                            '<td>' + item.Category + '</td>' +
                            '<td>' + item.SubCategory + '</td>' +
                            '<td>' + item.Quantity + '</td>' +
                            '<td>' + item.UOM + '</td>' +
                            '<td>' + item.ApprovedBy + '</td>' +
                            '<td>' + formattedDate + '</td>' +
                            '<td><button class="btn btn-sm btn-danger delete-line" data-lineid="' + (item.Lineid || '') + '">Delete</button></td>' +
                            '</tr>';
                        table.append(row);
                    });
                    toastr.success('Successfully Retrieved..');
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.error("Error fetching BOM data:", textStatus, errorThrown);
                    // Optionally display an error message to the user
                    // Example: $('#itemlist').html('<tr><td colspan="7">Error loading data.</td></tr>');
                }
            });
        }


        $('#category').on('change', function () {
            var categoryId = $(this).val();
            $.ajax({
                type: 'GET',
                url: '/BOM/GetSubCategories',
                data: { categoryId: categoryId },
                dataType: 'json',
                success: function (data) {
                    $('#subcategory').empty();
                    $.each(data.subcategory, function (index, item) {
                        $('#subcategory').append($('<option>', { value: item.value, text: item.text }));
                    });
                }
            });
        });
        // Store pending delete info for the confirm modal
        var pendingDeleteLineId = null;
        var pendingDeleteBomId = null;
        var pendingDeleteItemName = '';

        $('#itemLinesTableold').on('click', '.delete-line', function () {
            pendingDeleteLineId  = $(this).data('lineid');
            pendingDeleteBomId   = $('#bomid option:selected').val();
            // Grab item name from same row for display in modal
            pendingDeleteItemName = $(this).closest('tr').find('td:eq(1)').text();

            $('#deleteItemNameLabel').text(pendingDeleteItemName);
            $('#confirmDeleteModal').modal('show');
        });

        $('#confirmDeleteBtn').on('click', function () {
            $('#confirmDeleteModal').modal('hide');
            $.ajax({
                type: 'POST',
                url: '/BOM/AlterBOMDeleteLine',
                data: { lineid: pendingDeleteLineId },
                success: function (data) {
                    GetBOMItems(pendingDeleteBomId);
                    toastr.success('Item Line Removed..');
                },
                error: function (xhr, status, error) {
                    console.error("Error deleting line:", status, error);
                    toastr.error('Error removing item line.');
                }
            });
        });
    });

</script>


<script>

    $(document).ready(function () {
        $('#itemCode').on('keyup', function (e) {
            if (e.which === 13 || e.which === 9) { // enter or tab key
                getItemDetails();
                $('#category').focus();
                toastr.info('Select Category & Subcategory..')
            }
        });

        $('#itemCode').on('blur', function () {
            getItemDetails();
            $('#category').focus();
            toastr.info('Select Category & Subcategory..')
        });
        function getItemDetails() {
            var itemCode = $('#itemCode').val();

            function jsonDateToDate(jsonDate) {
                if (!jsonDate) return '';
                var date = new Date(parseInt(jsonDate.replace(/\/Date\((\d+)\)\//, '$1')));
                var day = date.getDate();
                var month = date.getMonth() + 1; // months are 0-based, so add 1
                var year = date.getFullYear();
                return `${padZero(day)}/${padZero(month)}/${year}`;
            }

            function padZero(value) {
                return (value < 10 ? '0' : '') + value;
            }
            $.ajax({
                type: 'GET',
                url: '/Purchase/GetItemDetails',
                data: { itemCode: itemCode },
                success: function (data) {
                    if (data.success) {
                        //let Dateformatted = "NA";
                        // Directly use the value from data.LastDate or 'NA' if it's 0
                        let formattedDate = data.LastDate === 0 || data.LastDate === "NA" ? 'NA' : moment(data.LastDate, 'DD-MM-YYYY HH:mm:ss').format('DD/MM/YYYY');
                        if (data.get && data.get.length > 0 && data.get[0].Date) {
                            Dateformatted = jsonDateToDate(data.get[0].Date);
                        } else {
                            Dateformatted = 'NA';
                        }

                        $('#itemDesc').val(data.itemname);
                        $('#uom').val(data.uomText);
                        $('#stock').val(data.stock);
                        $('#itemid').val(data.itemid);
                        toastr.success('Details Reterived');
                        var audio = new Audio('/Sound/Save.mp3');
                        audio.play();
                    } else {
                        toastr.error('Item Not Found');
                        // alert('Item not found / ' + data.error);
                        var audio = new Audio('/Sound/Error.mp3');
                        audio.play();
                    }
                },
            });
        }
    });

</script>

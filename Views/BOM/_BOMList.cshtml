@model IEnumerable<CMKL.Models.BOMItem>

@if (Model is not null)
{
    <table id="bom-table" class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>Category</th>
                <th>Sub Category</th>
                <th>Item Code</th>
                <th>Final Item</th>
                <th>Raw Item Name</th>
                <th>Quantity</th>
                <th>Available Stock</th>
                <th>UOM</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr @(item.Quantity > item.Stock ? "class=low-stock" : "")>
                    <td>@item.Category</td>
                    <td>@item.subCategory</td>
                    <td>@item.ItemCode</td>
                    <td>@item.FinalItem</td>
                    <td>@item.RawItemName</td>
                    <td>@item.Quantity.ToString("G0")</td>
                    <td>@item.Stock.ToString("G0")</td>
                    <td>@item.UOM</td>

                </tr>
            }
        </tbody>
    </table>

   
    <script>
       $(document).ready(function () {
           var itemsRequiredMoreStock = [];
           $('#bom-table tr').each(function () {
               var quantity = parseInt($(this).find('td:eq(5)').text());
               var stock = parseInt($(this).find('td:eq(6)').text());
               debugger;
               if (quantity > stock) {
                   itemsRequiredMoreStock.push($(this).find('td:eq(2)').text());
               }
           });
           
           if (itemsRequiredMoreStock.length > 0) {
               toastr.error('Few items require more stock: ' + itemsRequiredMoreStock.join(', '), 'Low Stock Alert', {
                   closeButton: true,
                   tapToDismiss: false
               });
               // Send AJAX request to notify the server
               $.ajax({
                   type: 'POST',
                   url: '@Url.Action("NotifyLowStock", "YourController")',
                   data: { items: itemsRequiredMoreStock },
                   success: function (data) {
                       console.log('Notification sent successfully');
                   }
               });
           }
       });
    </script>
      

    <style>
        .low-stock {
            background-color: #FFC080; /* red background */
            color: #FFFFFF; /* white font */
            font-weight: bold;
        }
    </style>
}

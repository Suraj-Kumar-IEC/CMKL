@{
    ViewBag.Title = "Create Service Request";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Assuming you use a layout page
}

@* Essential CSS includes *@
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
<link href="~/toastr/toastr.css" rel="stylesheet" />

<style>
    body {
        background-color: #f0f2f5;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #34495e;
    }

    .container {
        max-width: 1000px; /* Wider for more fields */
        margin-top: 30px;
        margin-bottom: 30px;
    }

    .card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .card-header {
        background-color: #0d47a1;
        color: #ffffff;
        padding: 20px 25px;
        font-size: 1.8em;
        font-weight: 600;
        text-align: center;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

    .card-body {
        padding: 30px;
    }

    .form-group label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        display: block;
    }

    .form-group .text-danger {
        font-size: 0.9em;
        vertical-align: middle;
        margin-left: 3px;
    }

    .form-control {
        border-radius: 5px;
        border: 1px solid #ced4da;
        padding: 10px 15px;
        font-size: 0.95em;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .form-control::placeholder {
            color: #a0a0a0;
        }

        .form-control:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }

    textarea.form-control {
        min-height: 80px; /* Adjusted for remarks */
        resize: vertical;
    }

    .form-control-file {
        padding-top: 8px;
    }

    .card-footer {
        background-color: #f8f9fa;
        border-top: 1px solid #e9ecef;
        padding: 20px 30px;
        text-align: center;
        border-bottom-left-radius: 10px;
        border-bottom-right-radius: 10px;
    }

    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
        padding: 12px 30px;
        font-size: 1.1em;
        font-weight: 600;
        border-radius: 5px;
        transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.1s ease;
    }

        .btn-primary:hover {
            background-color: #0056b3;
            border-color: #0056b3;
            transform: translateY(-1px);
        }

    .btn-secondary {
        background-color: #6c757d;
        border-color: #6c757d;
        padding: 12px 30px;
        font-size: 1.1em;
        font-weight: 600;
        border-radius: 5px;
        transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.1s ease;
    }

        .btn-secondary:hover {
            background-color: #5a6268;
            border-color: #5a6268;
            transform: translateY(-1px);
        }

    .mr-2 {
        margin-right: 15px !important;
    }

    .invalid-feedback {
        display: none;
        color: #dc3545;
        font-size: 0.875em;
        margin-top: 5px;
    }

    .form-group .is-invalid ~ .invalid-feedback,
    .form-control.is-invalid + .invalid-feedback {
        display: block;
    }
</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            Create New Service Request
        </div>
        <div class="card-body">
            <form id="serviceRequestForm" enctype="multipart/form-data">
                <!-- Customer Details -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="BranchName">Branch Name<span class="text-danger">*</span>:</label>
                            <input type="text" class="form-control" id="BranchName" name="BranchName" required placeholder="Enter Branch Name">
                            <div class="invalid-feedback">Branch Name is required.</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="CustomerName">Customer Name<span class="text-danger">*</span>:</label>
                            <input type="text" class="form-control" id="CustomerName" name="CustomerName" required placeholder="Enter Customer Name">
                            <div class="invalid-feedback">Customer Name is required.</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="CustomerPhoneNo">Customer Phone No.<span class="text-danger">*</span>:</label>
                            <input type="tel" class="form-control" id="CustomerPhoneNo" name="CustomerPhoneNo" required placeholder="Enter Phone No.">
                            <div class="invalid-feedback">Valid 10-digit Phone No. is required.</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="CustomerAddress">Customer Address:</label>
                            <textarea class="form-control" id="CustomerAddress" name="CustomerAddress" rows="2" placeholder="Enter Customer Address"></textarea>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="State">State:</label>
                            <select class="form-control" id="State" name="State">
                                <option value="">-- Select State --</option>
                                <option value="Punjab">Punjab</option>
                                <option value="Haryana">Haryana</option>
                                <!-- Add more states as needed -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Request Details -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="RequestBy">Request By:</label>
                            <input type="text" class="form-control" id="RequestBy" name="RequestBy" placeholder="Name of Requester">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="ComplaintDate">Complaint Date:</label>
                            <input type="date" class="form-control" id="ComplaintDate" name="ComplaintDate">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="EmailAddress">E-mail Address:</label>
                            <input type="email" class="form-control" id="EmailAddress" name="EmailAddress" placeholder="Enter Email Address">
                            <div class="invalid-feedback">Invalid Email Address.</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="PlantName">Plant Name:</label>
                            <input type="text" class="form-control" id="PlantName" name="PlantName" placeholder="Enter Plant Name">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="PurchaseCommissioningDate">Purchase/Commissioning Date:</label>
                            <input type="date" class="form-control" id="PurchaseCommissioningDate" name="PurchaseCommissioningDate">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="DesiredDateOfDeputation">Desired Date & Time of Deputation of Engineer:</label>
                            <input type="datetime-local" class="form-control" id="DesiredDateOfDeputation" name="DesiredDateOfDeputation">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Machine/DG Set Details -->
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="EngineModelId">Engine Model:</label>
                            <select class="form-control" id="EngineModelId" name="EngineModelId">
                                <option value="">-- Select Engine Model --</option>
                                @* Options will be loaded via AJAX *@
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="PanelType">Panel:</label>
                            <select class="form-control" id="PanelType" name="PanelType">
                                <option value="">-- Select Panel Type --</option>
                                <option value="Manual">Manual</option>
                                <option value="Auto">Auto</option>
                                <!-- Add more panel types as needed -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="EngineSerialNumber">Engine Serial No.:</label>
                            <input type="text" class="form-control" id="EngineSerialNumber" name="EngineSerialNumber" placeholder="Enter Engine Serial No.">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="Phase">Phase:</label>
                            <select class="form-control" id="Phase" name="Phase">
                                <option value="">-- Select Phase --</option>
                                <option value="1 Ph">1 Ph</option>
                                <option value="3 Ph">3 Ph</option>
                                <!-- Add more phases as needed -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="DGSetRating">DG Set Rating:</label>
                            <select class="form-control" id="DGSetRating" name="DGSetRating">
                                <option value="">-- Select DG Set Rating --</option>
                                @* Options will be loaded via AJAX *@
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="WarrantyStatus">Warranty:</label>
                            <select class="form-control" id="WarrantyStatus" name="WarrantyStatus">
                                <option value="">-- Select Warranty Status --</option>
                                <!-- Options will be loaded via AJAX -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label for="ComplaintReportedByCustomer">Complaint Reported By Customer:</label>
                            <textarea class="form-control" id="ComplaintReportedByCustomer" name="ComplaintReportedByCustomer" rows="2" placeholder="Describe complaint"></textarea>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="EngineHours">Engine Hours:</label>
                            <input type="number" step="0.01" class="form-control" id="EngineHours" name="EngineHours" placeholder="Enter Engine Hours">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Upload Copies -->
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="UploadCopy1File">Upload Copy 1 (Scanned Copy):</label>
                            <input type="file" class="form-control-file" id="UploadCopy1File" name="UploadCopy1File" accept=".pdf,.jpg,.jpeg,.png">
                            <small class="form-text text-muted">Max file size: 5MB (example)</small>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="UploadCopy2File">Upload Copy 2 (Scanned Copy):</label>
                            <input type="file" class="form-control-file" id="UploadCopy2File" name="UploadCopy2File" accept=".pdf,.jpg,.jpeg,.png">
                            <small class="form-text text-muted">Max file size: 5MB (example)</small>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <!-- Engineer & Complaint Resolution (Initial state, might be hidden or read-only for customer) -->
                <h5>Engineer & Complaint Resolution Details</h5>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="EngineerDeputedFromId">Engineer Deputed From:</label>
                            <select class="form-control" id="EngineerDeputedFromId" name="EngineerDeputedFromId">
                                <option value="">-- Select Status --</option>
                                <!-- Options loaded via AJAX -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="TechnicianName">Technician Name:</label>
                            <input type="text" class="form-control" id="TechnicianName" name="TechnicianName" placeholder="Enter Technician Name">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="TechnicianContactNo">Technician Contact No.:</label>
                            <input type="tel" class="form-control" id="TechnicianContactNo" name="TechnicianContactNo" placeholder="Enter Contact No.">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="DateOfEngineerDeputation">Date of Engineer Deputation:</label>
                            <input type="date" class="form-control" id="DateOfEngineerDeputation" name="DateOfEngineerDeputation">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="ComplaintSource">Complaint Source:</label>
                            <select class="form-control" id="ComplaintSource" name="ComplaintSource">
                                <option value="">-- Select Source --</option>
                                <!-- Options loaded via AJAX -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="ComplaintReportInOutDate">Complaint Report In/Out Date:</label>
                            <input type="date" class="form-control" id="ComplaintReportInOutDate" name="ComplaintReportInOutDate">
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="ComplaintDueToCustomerFault">Complaint Due To Customer Fault:</label>
                            <select class="form-control" id="ComplaintDueToCustomerFault" name="ComplaintDueToCustomerFault">
                                <option value="">-- Select --</option>
                                <option value="Applicable">Applicable</option>
                                <option value="Not Applicable">Not Applicable</option>
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="NatureOfComplaintAnalyzedByServiceEngg">Nature Of Complaint Analyzed By Service Engg.:</label>
                            <textarea class="form-control" id="NatureOfComplaintAnalyzedByServiceEngg" name="NatureOfComplaintAnalyzedByServiceEngg" rows="2" placeholder="Enter analysis"></textarea>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="ComplaintStatus">Complaint Status:</label>
                            <select class="form-control" id="ComplaintStatus" name="ComplaintStatus">
                                <option value="">-- Select Status --</option>
                                <!-- Options loaded via AJAX -->
                            </select>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="ActionTakenResolution">Action Taken (Resolution):</label>
                            <textarea class="form-control" id="ActionTakenResolution" name="ActionTakenResolution" rows="2" placeholder="Enter resolution details"></textarea>
                            <div class="invalid-feedback"></div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12 text-center">
                        <button type="submit" id="saveServiceRequest" class="btn btn-primary mr-2">Save Service Request</button>
                        <button type="button" class="btn btn-secondary" onclick="resetForm()">Clear Form</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    @* Ensure jQuery is loaded *@
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    @* Ensure Bootstrap JS is loaded *@
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    @* Ensure Toastr JS is loaded *@
    <script src="~/toastr/Js/toastr.js"></script>

    <script>
        $(document).ready(function () {
            // --- Initial Load of Dropdowns ---
            loadEngineModels();
            loadPhases();
            loadDGSets();
            loadWarrantyStatuses();
            loadEngineerDeputedFromStatuses();
            loadComplaintSources();
            loadComplaintStatuses();

            // --- Form Submission Handler ---
            $('#serviceRequestForm').submit(function (e) {
                e.preventDefault();

                if (!validateForm()) {
                    toastr.error("Please correct the highlighted fields.", "Validation Error");
                    return;
                }

                var formData = new FormData(this);

                $('#saveServiceRequest').prop('disabled', true).text('Saving...');

                $.ajax({
                    url: '@Url.Action("Save", "ServiceRequest")', // <<< IMPORTANT: Adjust Controller name
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) {
                            toastr.success(response.message, "Success");
                            resetForm();
                        } else {
                            toastr.error(response.message, "Error");
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("AJAX Error:", status, error, xhr.responseText);
                        toastr.error("An unexpected error occurred. Please try again.", "Error");
                    },
                    complete: function () {
                        $('#saveServiceRequest').prop('disabled', false).text('Save Service Request');
                    }
                });
            });

            // --- Validation Function ---
            
            // --- Reset Form Function ---
            function resetForm() {
                $('#serviceRequestForm')[0].reset();
                $('.form-control, .form-control-file').removeClass('is-invalid');
                $('.invalid-feedback').empty();
                // Reload dropdowns to reset them to default "-- Select --"
                loadEngineModels();
                loadPhases();
                loadDGSets();
                loadWarrantyStatuses();
                loadEngineerDeputedFromStatuses();
                loadComplaintSources();
                loadComplaintStatuses();
            }

            // --- Dropdown Load Functions ---
            function loadDropdown(selector, url, defaultText) {
                $.ajax({
                    url: url,
                    type: 'GET',
                    dataType: 'json',
                    success: function (response) {
                        $(selector).empty().append('<option value="">' + defaultText + '</option>');
                        if (response.success && response.data) {
                            $.each(response.data, function (index, item) {
                                $(selector).append('<option value="' + item.Value + '">' + item.Text + '</option>');
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Error loading " + selector + ":", status, error);
                        toastr.error("Failed to load " + defaultText.replace('-- Select ', '').replace(' --', '') + " list.", "Error");
                    }
                });
            }

            function loadEngineModels() { loadDropdown('#EngineModelId', '@Url.Action("GetEngineModels", "ServiceRequest")', '-- Select Engine Model --'); }
            function loadPhases() { /* This is a static dropdown, no AJAX needed */ } // If it's static, remove this call
            function loadDGSets() { loadDropdown('#DGSetRating', '@Url.Action("GetDGSets", "ServiceRequest")', '-- Select DG Set Rating --'); }
            function loadWarrantyStatuses() { loadDropdown('#WarrantyStatus', '@Url.Action("GetWarrantyStatuses", "ServiceRequest")', '-- Select Warranty Status --'); }
            function loadEngineerDeputedFromStatuses() { loadDropdown('#EngineerDeputedFromId', '@Url.Action("GetEngineerDeputedFromStatuses", "ServiceRequest")', '-- Select Status --'); }
            function loadComplaintSources() { loadDropdown('#ComplaintSource', '@Url.Action("GetComplaintSources", "ServiceRequest")', '-- Select Source --'); }
            function loadComplaintStatuses() { loadDropdown('#ComplaintStatus', '@Url.Action("GetComplaintStatuses", "ServiceRequest")', '-- Select Status --'); }
        });
    </script>
}
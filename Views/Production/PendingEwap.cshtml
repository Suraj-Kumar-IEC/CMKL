<script>
    $(document).ready(function () {
        //Load Engine Models in Modal list
        $.ajax({
            url: '/Production/GetEngineModel',
            type: 'GET',
            success: function (data) {
                $('#model').append($('<option></option>').val("").text("Select Engine Model"));
                $.each(data, function (index, item) {
                    $('#model').append($('<option></option>').val(item.value).text(item.text));
                });
            }

        })
       //Change Erection Remarks On The Basis of Selection
        $('#erection').change(function () {
            var val = $(this).val(); // Get the *value* of the selected option            
            if (val === 'Yes') { // Use === for strict equality comparison
                $('#erectiondetail').val('As Per Attached Annexure at Extra Cost'); // Corrected selector
            } else {
                $('#erectiondetail').val('NA'); // Corrected selector
            }
        });
        //Get Phase
        $.ajax({
            url: '/Production/GetAlternatorPhase',
            type: 'GET',
            success: function (data) {
                $('#aphase').append($('<option></option>').val("").text("Select Phase"));
                $.each(data.phase, function (index, item) {
                    $('#aphase').append($('<option></option>').val(item.value).text(item.text));
                });
            }
        })
        //Get Panel Type
        $.ajax({
            url: '/Production/GetCPType',
            type: 'GET',
            success: function (data) {
                $('#cptype').append($('<option></option>').val("").text("Select Control Panel"));
                $.each(data.type, function (index, item) {
                    $('#cptype').append($('<option></option>').val(item.value).text(item.text));
                });
            }
        })
        //Get Ratings 
        $.ajax({
            url: '/Production/GetRatings',
            type: 'GET',
            success: function (data) {
                $('#ratingOfGenset').append($('<option></option>').val("").text("Select Rating"));
                $.each(data.rating, function (index, item) {
                    $('#ratingOfGenset').append($('<option></option>').val(item.value).text(item.text));
                });
                //Update ControlPanel Rating
                $('#cprating').append($('<option></option>').val("").text("Select Rating"));
                $.each(data.rating, function (index, item) {
                    $('#cprating').append($('<option></option>').val(item.value).text(item.text));
                });
                $('#arating').append($('<option></option>').val("").text("Select Rating"));
                $.each(data.rating, function (index, item) {
                    $('#arating').append($('<option></option>').val(item.value).text(item.text));
                });
            }
        })
        $.ajax({
            url: '/Production/GetBatteriesModel',
            type: 'GET',
            success: function (data) {
                $('#BatteryRating').append($('<option></option>').val("").text("Select Battery"));
                $.each(data, function (index, item) {
                    $('#BatteryRating').append($('<option></option>').val(item.value).text(item.text));
                });
            }
        })

        // Function to load pending records
        function loadPendingRecords() {
            $.ajax({
                type: 'GET',
                url: '/Production/PendingEwapCases',
                dataType: 'JSON',
                success: function (data) {
                    $('#PendingRows').empty();
                    if (data && data.get && data.get.length > 0) {
                        $.each(data.get, function (index, item) {
                            var dateValue = parseInt(item.VoucherDate.replace(/[^0-9]/g, ''));
                            var voucherDate = new Date(dateValue);
                            var formattedDate = voucherDate.toLocaleDateString('en-GB', {
                                day: '2-digit',
                                month: '2-digit',
                                year: 'numeric'
                            }).replace(/\//g, '-');

                            var row = '<tr>' +
                                '<td>' + item.VoucherNumber + '</td>' +
                                '<td>' + formattedDate + '</td>' +
                                '<td>' + item.CreatedBy + '</td>' +
                                '<td>' + item.FGProductCode + '</td>' +
                                '<td>' + item.FGProductName + '</td>' +
                                '<td><button class="btn btn-primary btn-sm approve-button" style="background-color: #00698f; color: #ffffff; padding: 3px 6px; border-radius: 5px;" data-voucher="' + item.id + '">Update Status</button></td>' +
                                '</tr>';

                            $('#PendingRows').append(row);
                        });
                    } else {
                        // Handle case where no data is returned
                        $('#PendingRows').append('<tr><td colspan="6">No pending records found.</td></tr>');
                    }
                },
                error: function (error) {
                    console.error("Error loading pending records:", error);
                    toastr.error("Failed to load pending production records.");
                }
            });
        }

        $('#Reject').click(function () {
            var headid = $('#headid').val();
            $.ajax({
                type: 'GET',
                url: '/Production/RejectProductionData',
                data: { headid: headid },
                success: function (data) {
                    if (data.success) {
                        toastr.success(data.message);
                        $('#updateStatusModal').modal('hide');
                        loadPendingRecords(); // This function should refresh your data grid/list
                    } else {
                        toastr.error(data.message);
                    }
                },
                error: function (xhr, status, error) {
                    // Added for better error handling
                    toastr.error("An error occurred: " + error);
                    console.error("AJAX Error:", status, error, xhr);
                }
            });
        });

        // Handle approve button click (using event delegation)
        $('#PendingTable').on('click', '.approve-button', function () {
            var itemId = $(this).data('voucher');
            $.ajax({
                type: 'GET',
                url: '/Production/GetProdutionUpdate',
                data: { BOMID: itemId },
                success: function (response) {
                    if (response.success) {
                        var data = response.data;
                        // Populate the battery fields
                        $('#BatterySerialNo').val(data.batterySerial);
                        $('#Batteryqty').val(data.batteryQty);

                        // Toggle Editability
                        if (data.isBatteryEditable) {
                            // If true, no lot was found, let the user type
                            $('#BatterySerialNo').prop('disabled', false);
                            $('#BatterySerialNo').css('background-color', '#ffffff');
                            $('#Batteryqty').prop('disabled', false);
                            $('#Batteryqty').css('background-color', '#ffffff');// Optional: visual cue
                        } else {
                            // If false, data came from FIFO lot, lock the field
                            $('#BatterySerialNo').prop('disabled', true);
                            $('#BatterySerialNo').css('background-color', '#e9ecef');
                            $('#Batteryqty').prop('disabled', true);
                            $('#Batteryqty').css('background-color', '#e9ecef'); // Standard disabled look
                        }
                        // Access the data object
                        $('#emake').val(data.emake);
                       // $('#emodel').val(data.emodel);
                        $('#engineSerialNo').val(data.engineSerialNo);
                        $('#etestcert').val(data.etestcert);
                        $('#eremarks').val(data.eremarks);
                        $('#amake').val(data.amake);
                        $('#aframe').val(data.aframe);
                        $('#alternatorSerialNo').val(data.alternatorSerialNo);
                        $('#atestcert').val(data.atestcert);
                        $('#awarranty').val(data.awarranty);
                        $('#aremarks').val(data.aremarks);
                        $('#exhaust').val(data.exhaust);
                        $('#kgsticker').val(data.kgsticker);
                        $('#AVM').val(data.AVM);
                        $('#fuelspout').val(data.fuelspout);
                        $('#flexbel').val(data.flexbel);
                        $('#aphase').val(data.aphase);
                        $('#arating').val(data.arating);
                        var emodelValue = data.emodel;  // Get the *value* of emodel from the AJAX response.
                        $('#model').val(emodelValue);
                    } else {
                        toastr.error(response.message); // Show the user-friendly message
                    }
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error:", error);
                    alert("An error occurred while fetching data. Please check the console."); // basic error
                }
            })
            $('#headid').val(itemId);
            $('#updateStatusModal').modal('show');
        });

        $('#closemodel').click(function () {
            $('#updateStatusModal').modal('hide');
        });

        $('#saveStatus').on('click', function () {
            // Gather Information
            $('#saveStatus').prop('disabled', true);
            $('#wait-sign').show();

            var id = $('#headid').val();
            var testingdate = $('#dateOfTesting').val();
            var engineserial = $('#engineSerialNo').val();
            var model = $('#model option:selected').val();
            var alternatorserial = $('#alternatorSerialNo').val();
            var rating = $('#ratingOfGenset').val();
            var remarks = $('#specialRemarks').val();
            var PanelSerialNo = $('#PanelSerialNo').val();
            var KRMNo = $('#KRMNo').val();
            var BatteryRating = $('#BatteryRating').val();
            var BatterySerialNo = $('#BatterySerialNo').val();
            var Batteryqty = $('#Batteryqty').val();

            // 1.  Save EWAP Status Data
            $.ajax({
                type: 'POST',
                url: '/Production/SaveEwapStatus',
                dataType: 'JSON', // Corrected:  Expect JSON response
                data: {
                    id: id,
                    testingdate: testingdate,
                    engineserial: engineserial,
                    model: model,
                    alternatorserial: alternatorserial,
                    rating: rating,
                    remarks: remarks,
                    PanelSerialNo: PanelSerialNo,
                    KRMNo: KRMNo,
                    BatteryRating: BatteryRating,
                    BatterySerialNo: BatterySerialNo,
                    Batteryqty: Batteryqty
                },
                success: function (response) { // Changed 'data' to 'response'
                    if (response.success) {
                        $('#updateStatusModal').modal('hide');
                        loadPendingRecords();
                        toastr.success(response.msg); // Use response.msg
                    } else {
                        toastr.error(response.error); // Use response.error
                    }
                },
                error: function (xhr, status, error) {
                    toastr.error("An error occurred while saving EWAP status: " + error); // Include error
                    console.error("EWAP Status AJAX Error:", error); // Log the error
                },
                complete: function () { //runs after success or error
                    $('#saveStatus').prop('disabled', false);
                    $('#wait-sign').hide();
                }
            });

            // 2.  Save Testing Data 
            var testingData = { // Changed variable name to testingData
                id: id, // Use the 'id' from above
                CPtype: $('#cptype').val(),
                CPRating: $('#cprating').val(),
                PanelSerialNo: $('#PanelSerialNo').val(),
                CPOtherDetail: $('#cpotherdetail').val(),
                BMake: $('#bmake').val(),
                BatteryRating: $('#BatteryRating').val(),
                BatteryQTY: $('#Batteryqty').val(),
                BatterySerialNo: $('#BatterySerialNo').val(),
               // Erection: $('#erection').val(),
               // ErectionDetail: $('#erectiondetail').val(),
                DateOfTesting: $('#dateOfTesting').val(),
                RatingOfGenset: $('#ratingOfGenset').val(),
                Canopy: $('#canopy').val(),
                Lube: $('#lube').val(),
                KCool: $('#kcool').val(),
                KRMNo: $('#KRMNo').val(),
                ADBlue: $('#adblue').val(),
                SpecialRemarks: $('#specialRemarks').val(),
            };

            $.ajax({
                type: 'POST',
                url: '/Production/SaveTestingData',
                contentType: 'application/json; charset=utf-8', // Added contentType
                data: JSON.stringify(testingData), //  Corrected data to testingData and stringified
                success: function (response) { // Changed 'data' to 'response'
                    if (response.success) {
                        toastr.success(response.message);
                    }
                    else {
                        toastr.error(response.message);
                    }
                },
                error: function (xhr, status, error) {
                    toastr.error("An error occurred while saving testing data: " + error);
                    console.error("Testing Data AJAX Error:", error);
                }
            });
        });


        // Initial loading of records
        loadPendingRecords();

    });
</script>


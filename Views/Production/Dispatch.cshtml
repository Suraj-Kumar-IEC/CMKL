        function resetPDIStatus() {
            $('#pdiStatusButton').removeClass('pdi-done').addClass('pdi-not-done').html('<i class="fas fa-exclamation-circle me-1"></i> Not Verified');
            $('#dispatchOrderButton').prop('disabled', true);
            $('#id').val('');
        }

        function updateTotalAmount() {
            var basic = parseFloat($('#basicprice').val()) || 0;
            var freight = parseFloat($('#frieght').val()) || 0;
            var taxPercent = parseFloat($('#taxid option:selected').attr('data-percent')) || 0;
            var taxType = $('#taxtype option:selected').text().trim();
            var round = parseFloat($('#roundoff').val()) || 0;

            var subtotal = basic + freight;
            var totalTaxValue = (subtotal * taxPercent) / 100;

            // LOGIC FIX: Condition based on Tax Type for correct Column mapping in backend
            if (taxType === 'IGST') {
                $('#gst').val(totalTaxValue.toFixed(2)); // Visible IGST field
                $('#cgst').val('0.00'); // Hidden CGST field
                $('#sgst').val('0.00'); // Hidden SGST field

                // Keep display consistent
                $('#cgst_display').val('0.00');
                $('#sgst_display').val('0.00');
            } else if (taxType === 'CGST | SGST') {
                // Split tax for CGST/SGST logic
                var splitTax = (totalTaxValue / 2).toFixed(2);

                $('#gst').val('0.00'); // Reset IGST column to 0
                $('#cgst').val(splitTax); // Populate hidden CGST field
                $('#sgst').val(splitTax); // Populate hidden SGST field

                // Update UI Display
                $('#cgst_display').val(splitTax);
                $('#sgst_display').val(splitTax);
            } else {
                // Default fallback
                $('#gst').val(totalTaxValue.toFixed(2));
                $('#cgst').val('0.00');
                $('#sgst').val('0.00');
                $('#cgst_display').val('0.00');
                $('#sgst_display').val('0.00');
            }

            var grandTotal = subtotal + totalTaxValue;
            var finalBill = grandTotal + round;

            $('#totalamt').val(grandTotal.toFixed(2));
            $('#billingamount').val(finalBill.toFixed(2));
            $('#lblGrandTotal').text("₹" + finalBill.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
        }

        function saveDispatch() {
            $('#wait-sign').show();
            $('#dispatchOrderButton').prop('disabled', true);

            var formData = {
                dispatchVoucherNumber: $('#dispatchVoucherNumber').val(),
                dispatchDate: $('#dispatchDate').val(),
                customerName: $('#customerName').val(),
                customerGST: $('#customerGST').val(),
                customerLocation: $('#customerLocation').val(),
                shippingAddress: $('#shippingAddress').val(),
                billingAddress: $('#billingAddress').val(),
                fgItemCode: $('#fgItemCode').val(),
                billdate: $('#BillDate').val(),
                id: $('#id').val(),
                ordernumber: $('#ordernumber').val(),
                orderdate: $('#orderdate').val(),
                BillNumber: $('#BillNumber').val(),
                basicprice: $('#basicprice').val(),
                gst: $('#gst').val(), // Maps to IGST column
                totalamt: $('#totalamt').val(),
                billingamount: $('#billingamount').val(),
                frieght: $('#frieght').val(),
                transport: $('#transport').val(),
                lr: $('#lr').val(),
                lrdate: $('#lrdate').val(),
                lorryno: $('#lorryno').val(),
                eway: $('#eway').val(),
                erection: $('#erection option:selected').val(),
                erectiondetail: $('#erectiondetail').val(),
                taxid: $('#taxid').val(),
                taxtypeid: $('#taxtype').val(),
                cgst: $('#cgst_display').val(),
                sgst: $('#sgst_display').val(),
                roundoff: $('#roundoff').val()
            };

            $.post('@Url.Action("SaveDispatchData", "Production")', formData, function(res) {
                $('#wait-sign').hide();
                if (res.success) {
                    toastr.success("Dispatch finalized!");
                    window.open('/Inventory/PackingSlipPrint?BOMID=' + res.BOMID, '_blank');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error(res.message || "Error saving record.");
                    $('#dispatchOrderButton').prop('disabled', false);
                }
            });
        }

        function initPdiDropdowns() {
            $.getJSON('/Production/GetEngineModel', (d) => $.each(d, (i, item) => $('#emodel').append(new Option(item.text, item.value))));
            $.getJSON('/Production/GetCPType', (d) => $.each(d.type, (i, item) => $('#cptype').append(new Option(item.text, item.value))));
            $.getJSON('/Production/GetRatings', (d) => {
                $.each(d.rating, (i, item) => {
                    $('#ratingOfGenset').append(new Option(item.text, item.value));
                    $('#cprating').append(new Option(item.text, item.value));
                });
            });
            $.getJSON('/Production/GetBatteriesModel', (d) => $.each(d, (i, item) => $('#BatteryRating').append(new Option(item.text, item.value))));
        }
    </script>

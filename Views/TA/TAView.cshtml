<script type="text/javascript">
    $(document).ready(function () {
        $("#add").click(function () {

            AddTransport();
        });
    })
    function AddTransport() {
        $("#advance").prop("disabled", true);
        $("name").fadeOut();
        var tbladdtransport = $("#tblTransportList");

        var tbltype = $("#TAtype").val();
        var tbldate = $("#TDATE").val();
        var tblfrom = $("#TFROM").val();
        var tblto = $("#TTO").val();
        var tblmode = $("#TMODE").val();
        var tblamount = $("#Amount").val();


        var TranList = "<tr><td>" +

            tbltype +
            "</td><td>" +
            tbldate +
            "</td><td>" +
            tblfrom +
            "</td><td>" +
            tblto +
            "</td><td>" +
            tblmode +
            "</td><td>" +
            tblamount +
            "</td><td> <input type='button' value='Remove' name='remove' class='btn btn-danger' onclick='Removeitem(this)' /> </td></tr>"

        tbladdtransport.append(TranList)//.fadeIn(800);
        finaltotal();
        resettrans();
    }
    function finaltotal() {
        $("#TAtotal").val("0");
        var finalttl = 0;
        var balance = 0;
        $("#tblTransportList").find("tr:gt(0)").each(function () {
            var TTL = parseFloat($(this).find("td:eq(5)").text());
            finalttl += TTL;
            debugger;

        });
        $("#TAtotal").val(parseFloat(finalttl).toFixed(0));
        var advance = $("#advance").val();
        var total = $("#TAtotal").val();
        var balance = total - advance;

        $("#balance").val(parseFloat(balance).toFixed(0));

    }

    function resettrans() {
        $("#Transid").val("");
        $("#TDATE").val("");
        $("#TFROM").val("");
        $("#TTO").val("");
        $("#TMODE").val("");
        $("#Amount").val("");

    }
    function Removeitem(tblid) {
        //  debugger
        var getamt = $(tblid).closest('tr').find("td:eq(5)").text();
        var getamt1 = $("#TAtotal").val();
        var minus = getamt1 - getamt;
        $("#TAtotal").val(parseFloat(minus).toFixed(0));
        $(tblid).closest('tr').remove().fadeOut(800);
    }
</script>



       



        <div><div class="container" align="center"><h2>TA Form</h2></div></div>





        <div>
            <div class="container" align="center">

                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Name" id="name" name="name" width="30px" style="margin-bottom: 10px;" required>
                </div>
                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Designation" id="designation" name="designation" width="30px" style="margin-bottom: 10px;" required>
                </div>
                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Journey From" id="jfrom" name="jfrom" width="30px" style="margin-bottom: 10px;" required>
                </div>
                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Journey To" id="jto" name="jto" width="30px" style="margin-bottom: 10px;" required>
                </div>
                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Date of Leaving HQ" id="dtlvhq" name="dtlvhq" width="30px" style="margin-bottom: 10px;" required>
                </div>
                <div class="col-lg-4">
                    <input type="text" class="form-control" placeholder="Date of Arrival HQ" id="dtavhq" name="dtavhq" width="30px" style="margin-bottom: 10px;" required>
                </div>


                <div class="animsition-loading">
                    <div class="col-lg-4">
                        <input type="text" class="form-control" placeholder="Advance Taken" id="advance" name="advance" width="30px" style="margin-bottom: 10px;" required>
                    </div>
                    <div class="col-lg-4">
                        <input type="text" class="form-control" placeholder="0.00" id="TAtotal" name="TAtotal" width="30px" style="margin-bottom: 10px;" required readonly>
                    </div>
                    <div class="col-lg-4">
                        <input type="text" class="form-control" placeholder="0.00" id="balance" name="balance" width="30px" style="margin-bottom: 10px;" required readonly>
                    </div>

                </div>
                <div class="col-lg-4">
                    <input class="form-control" type="file" id="Fileupload" multiple>
                </div>



            </div>
        </div>



        @* <form id="myForm">*@
        <fieldset>

            <hr />

            <legend style="align-content">
                Travel Details
            </legend>
            <div class="container">
                <div class="row">


                    <div class="col-sm-3">
                        <select class="form-control" id="TAtype" name="TAtype" width="30px" style="margin-bottom:10px">
                            <option>Select TA/DA Type</option>
                            <option>Outstation Travel</option>
                            <option>Local Travel</option>
                            <option>Hotel Stay</option>
                            <option>Food</option>
                        </select>
                    </div>
                    <div class="col-sm-3">
                        <p>@Html.TextBoxFor(mode => mode.TATransport.DateTime, new { id = "TDATE", placeholder = "Date Of Travel / Food / Hotel", @class = "form-control" })</p>
                    </div>
                    <div class="col-sm-3">
                        <p>@Html.TextBoxFor(mode => mode.TATransport.From, new { id = "TFROM", placeholder = "Location From", @class = "form-control" })</p>
                    </div>
                    <div class="col-sm-3">
                        <p>@Html.TextBoxFor(mode => mode.TATransport.To, new { id = "TTO", placeholder = "Location To", @class = "form-control", })</p>
                    </div>
                    <div class="col-sm-3">
                        <p>@Html.TextBoxFor(mode => mode.TATransport.Mode, new { id = "TMODE", placeholder = "Travel Mode -Bus/Car / Food / Hotel ", @class = "form-control" })</p>
                    </div>
                    <div class="col-sm-3">
                        <p>@Html.TextBoxFor(mode => mode.TATransport.Amount, new { id = "Amount", placeholder = "Amount", @class = "form-control" })</p>
                    </div>
                    @*<div class="col-sm-3">
                            <p> <input type="text" id="TAtotal" name="Total" readonly="readonly" value="0.00" class="form-control"</p>
                        </div>
                    *@
                    <div class="col-sm-3">
                        <button type="button" id="add" class="btn btn-primary right-0">Add Transport Detail</button>
                    </div>


                </div>
            </div>


        </fieldset>
        <fieldset>
            <div class="text-center">Travel Detail List</div>
            <h5></h5>
            <hr />
            <style>
                table, th, td {
                    border: 1px solid black;
                    border-collapse: collapse;
                }

                th, td {
                    padding: 5px;
                    text-align: center;
                }
            </style>
            <table style="width:100%" id="tblTransportList" align="center">
                <thead>
                    <tr>
                        <th>
                            Type
                        </th>

                        <th>
                            Date
                        </th>
                        <th>
                            Location From
                        </th>
                        <th>
                            Location To
                        </th>
                        <th>
                            Mode
                        </th>
                        <th>
                            Amount
                        </th>
                        <th>
                            Action
                        </th>
                    </tr>
                </thead>
            </table>

        </fieldset>
        <hr>
        @*<button type="button" id="save" class="btn btn-info" onclick="addProject()">Save TA Bill</button>*@
        <button type="button" id="save" class="btn btn-info" onclick="addProject()">Save TA bill</button>

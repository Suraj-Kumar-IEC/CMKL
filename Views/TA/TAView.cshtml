<script>

    //addProject();
    function addProject() {

        // Save Data Line wise
        var table_data = new Array();

        $('#tblTransportList tbody tr').each(function (row, tr) {
            //  var barcode = parseInt($(tr).find('td:eq(1)').text());
            // var itemcode = $(tr).find('td:eq(1)').text();
            // var itemname = $(tr).find('td:eq(2)').text();
            var sum = {
                //these records i am going to add into sales table
                'tatype': $(tr).find('td:eq(0)').text(),
                'tadate': $(tr).find('td:eq(1)').text(),
                'locationfrom': $(tr).find('td:eq(2)').text(),
                'locationto': $(tr).find('td:eq(3)').text(),
                'mode': $(tr).find('td:eq(4)').text(),
                'amount': $(tr).find('td:eq(5)').text(),
                //'itemid': $(tr).find('td:eq(7)').text(),
            };
            table_data.push(sum);

        });
        console.log(table_data);
        $.post("/TA/SaveNew",
            {


                data: JSON.stringify({
                    name: $("#name").val(),
                    jesignation: $("#designation").val(),
                    jfrom: $("#jfrom").val(),
                    jto: $("#jto").val(),
                    jstartdt: $("#dtlvhq").val(),
                    jenddt: $("#dtavhq").val(),
                    advance: $("#advance").val(),
                    total: $("#TAtotal").val(),
                    balance: $("#balance").val(),
                    //balance: $("#balance").val,
                    // total: $("#total").val(),
                    data: table_data
                })
            },
            function (data, status) {
                console.log(data);
                //alert("Status: " + status + "\nMessage: " + data.message);

                toastr.success(data.message);
                $("#billno").val(""),
                    $("#billdt").val(""),
                    $('#product_list tbody').empty();
                // location.reload(true);
            });

    }
</script>



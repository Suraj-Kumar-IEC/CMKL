@model dynamic
@{
    Layout = null;

    var items = Model.SaleItems as IEnumerable<dynamic> ?? new List<dynamic>();
    var ratingSummary = Model.RatingWiseSummary as IEnumerable<dynamic> ?? new List<dynamic>();

    int totalUnits = items.Count();
    decimal totalBatteryQty = 0;
    foreach (var item in items) { try { totalBatteryQty += (decimal)(item.BatteryQty ?? 0); } catch { } }

    decimal grandTotalValue = (decimal)(Model.TotalGrandTotal ?? 0);
    var indianCulture = new System.Globalization.CultureInfo("en-IN");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f1f5f9;
            margin: 0;
            padding: 0;
            color: #334155;
        }

        .wrapper {
            width: 100%;
            max-width: 900px;
            margin: 20px auto;
            background-color: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border: 1px solid #e2e8f0;
        }

        .header {
            background: linear-gradient(135deg, #004d69 0%, #00698f 100%);
            color: #ffffff;
            padding: 30px;
        }

            .header h1 {
                margin: 0;
                font-size: 22px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .dashboard {
            padding: 20px;
            background-color: #f8fafc;
            display: table;
            width: 100%;
            border-collapse: separate;
            border-spacing: 8px;
            box-sizing: border-box;
        }

        .stat-card {
            display: table-cell;
            background: #ffffff;
            padding: 12px;
            border-radius: 10px;
            text-align: center;
            width: 25%;
            border: 1px solid #e2e8f0;
            vertical-align: middle;
        }

        .stat-label {
            font-size: 8px;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
            display: block;
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 14px;
            font-weight: 800;
            color: #00698f;
        }

        .content {
            padding: 25px;
        }

        .section-title {
            font-size: 11px;
            font-weight: 800;
            color: #1e293b;
            text-transform: uppercase;
            border-left: 4px solid #00698f;
            padding-left: 10px;
            margin: 25px 0 15px 0;
        }

        .table-container {
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        th {
            background-color: #f8fafc;
            color: #64748b;
            font-weight: 700;
            text-align: left;
            padding: 12px;
            border-bottom: 2px solid #e2e8f0;
            text-transform: uppercase;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: top;
        }

        .logistics-box {
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            padding: 6px 10px;
            border-radius: 6px;
        }

        .logistics-label {
            font-size: 8px;
            color: #0369a1;
            font-weight: 800;
            text-transform: uppercase;
            display: block;
        }

        .logistics-val {
            font-size: 10px;
            font-weight: 700;
            color: #0c4a6e;
        }

        .rating-matrix {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            overflow: hidden;
        }

            .rating-matrix th {
                background-color: #00698f;
                color: #ffffff;
                font-size: 10px;
                padding: 10px;
                text-align: center;
            }

            .rating-matrix td {
                padding: 10px;
                border-bottom: 1px solid #f1f5f9;
                font-size: 12px;
                text-align: center;
            }

        .footer {
            padding: 30px;
            text-align: center;
            border-top: 1px solid #f1f5f9;
            font-size: 10px;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="header">
            <h1>@Model.Title</h1>
            <p style="margin:5px 0 0; opacity:0.8; font-size:12px;">Automated Dispatch Audit | @DateTime.Now.ToString("dd MMMM, yyyy")</p>
        </div>

        <div class="dashboard">
            <div class="stat-card" style="border-top: 4px solid #10b981;"><span class="stat-label">Total Basic</span><span class="stat-value">₹ @Model.TotalBasicPrice.ToString("N0", indianCulture)</span></div>
            <div class="stat-card" style="border-top: 4px solid #00698f;"><span class="stat-label">Units Dispatched</span><span class="stat-value">@totalUnits Sets</span></div>
            <div class="stat-card" style="border-top: 4px solid #f59e0b;"><span class="stat-label">Battery Outflow</span><span class="stat-value">@totalBatteryQty.ToString("N0") Nos</span></div>
            <div class="stat-card" style="border-top: 4px solid #8b5cf6;"><span class="stat-label">Report Type</span><span class="stat-value">Logistics</span></div>
        </div>

        <div class="content">
            <div class="section-title">Verified Logistics Log</div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 20%;">Invoice / OA</th>
                            <th style="width: 25%;">Consignee</th>
                            <th style="width: 15%;">Product</th>
                            <th style="width: 40%;">Logistics Intelligence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:700; color: #0f172a;">@item.Billno</div>
                                    <div style="color:#64748b; font-size:9px;">OA: @item.OA</div>
                                </td>
                                <td>
                                    <div style="font-weight:700;">@item.CustomerName</div>
                                    <div style="color:#64748b; font-size:9px; line-height: 1.2;"><i>@item.Shipping</i></div>
                                </td>
                                <td>
                                    <div style="font-weight:700; color: #00698f;">@item.Rating</div>
                                    <div style="font-size:9px; color: #64748b;">S/N: @item.ESerial</div>
                                </td>
                                <td>
                                    <div class="logistics-box">
                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                            <tr>
                                                <td style="padding:0; border:none; width:50%;">
                                                    <span class="logistics-label">Transporter</span>
                                                    <span class="logistics-val">@item.Transporter</span>
                                                </td>
                                                <td style="padding:0; border:none; width:50%;">
                                                    <span class="logistics-label">Vehicle No</span>
                                                    <span class="logistics-val">@item.VehicleNo</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding:0; border:none; width:50%; padding-top:5px;">
                                                    <span class="logistics-label">LR Number</span>
                                                    <span class="logistics-val">@item.LRNo</span>
                                                </td>
                                                @*<td style="padding:0; border:none; width:50%; padding-top:5px;">
            <span class="logistics-label">Driver Contact</span>
            <span class="logistics-val">@item.DriverContact</span>
        </td>*@
                                            </tr>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="section-title">Rating-Wise Performance Matrix</div>
            <table class="rating-matrix">
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left:20px;">KVA Power Segment</th>
                        <th>Today's Sale</th>
                        <th>Month MTD</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var range in ratingSummary)
                    {
                        <tr>
                            <td style="text-align: left; padding-left:20px; font-weight:700; color:#00698f;">@range.RangeName</td>
                            <td style="font-weight: 700; color: #00698f;">@range.Count</td>
                            <td style="font-weight: 700; color: #1e293b;">@range.MonthlyCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="footer">
            <p>System-generated Logistics Audit from <strong>IEPL ERP Cloud</strong>.</p>
            <p style="margin-top:6px;">&copy; @DateTime.Now.Year IEC Electric Power Limited</p>
        </div>
    </div>
</body>
</html>
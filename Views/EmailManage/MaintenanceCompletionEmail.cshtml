
@{
    Layout = null; // Email templates usually don't use a layout
}

<!DOCTYPE html>
<html>
<head>
    <title>@Model.Subject</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 20px auto;
            background-color: #ffffff;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        h3 {
            background-color: #28a745;
            color: #ffffff;
            padding: 10px 15px;
            border-radius: 5px;
            text-align: center;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #dddddd;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #f5f5f5;
            font-weight: bold;
        }

        .item-table th {
            background-color: #f0f8ff;
        }

        .footer {
            margin-top: 30px;
            color: #777777;
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <h3>@Model.Subject</h3>
        <p>Dear Plant Head,</p>
        <p>This is to inform you that a maintenance task has been successfully completed and Pending For Approval.</p>

        <table>
            <tr>
                <th>Asset ID</th>
                <td>@Model.AssetID</td>
            </tr>
            <tr>
                <th>Machine</th>
                <td>@Model.MachineName</td>
            </tr>
            <tr>
                <th>Due Date</th>
                <td>@Model.DueDate.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Completed By</th>
                <td>@Model.CompletedBy</td>
            </tr>
            <tr>
                <th>Completion Date</th>
                <td>@Model.CompletionDate.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            <tr>
                <th>Completion Remarks</th>
                <td>@Model.CompletionRemarks</td>
            </tr>
        </table>

        @if (Model.ItemsUsed != null)
        {
            <h4 style="margin-top: 20px;">Items Involved</h4>
            <table class="item-table">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Quantity Used</th>
                        <th>UOM</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ItemsUsed)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.Quantity</td>
                            <td>@item.UOM</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    <div class="footer">
        <p>This is an auto-generated email from IEPL ERP system. Please do not reply.</p>
        <p>All rights reserved. IEC Electric Power Limited.</p>
        <p><a href="http://erp.iecelectric.co.in/">http://erp.iecelectric.co.in/</a></p>
    </div>
    </div>
</body>
</html>
@{
    ViewBag.Title = "RequisitionApprovalEmailTemplate";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Requisition Approval Information</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 20px auto;
            background-color: #ffffff;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        h2 {
            color: #333333;
        }

        h3 {
            background-color: #00698f;
            color: #ffffff;
            padding: 10px 15px;
            border-radius: 5px;
            text-align: center;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #dddddd;
            padding: 12px;
            text-align: left;
        }

        th {
            background-color: #f5f5f5;
            font-weight: bold;
        }

        .highlight {
            background-color: #f9f9f9;
        }

        .footer {
            margin-top: 30px;
            color: #777777;
            font-size: 14px;
            text-align: center;
        }

            .footer a {
                color: #337ab7;
            }
    </style>
</head>
<body>
    <div class="container-fluid">

        <h3>Requisition Approval Information</h3>
        <table class="table table-sm">
            <tr class="highlight">
                <th>Requisition No:</th>
                <td>@Model.RequsitionHead.RequisitionNumber</td>
            </tr>
            <tr>
                <th>Requisition Date:</th>
                <td>@Model.RequsitionHead.RequisitionDate.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr class="highlight">
                <th>Created By:</th>
                <td>@Model.RequsitionHead.CreatedBy</td>
            </tr>
            <tr>
                <th>Approved By:</th>
                <td>@Model.RequsitionHead.ApprovedBy</td>
            </tr>
            <tr class="highlight">
                <th>BOM Number:</th>
                <td>@Model.RequsitionHead.BOMNumber</td>
            </tr>
            <tr>
                <th>BOM Date:</th>
                <td>@Model.RequsitionHead.BOMDate.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr class="highlight">
                <th>Financial Year:</th>
                <td>@Model.RequsitionHead.Finyear</td>
            </tr>
        </table>

        <h3>Requisition Items</h3>

        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Item Code</th>
                    <th>UOM</th>
                    <th>Quantity</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RequsitionLines)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td>@item.ItemCode</td>
                        <td>@item.UOM</td>
                        <td>@item.Quantity</td>
                        <td>@item.Action</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="footer">
            <p>Please do not reply to this email as it is an auto-generated email from IEPL ERP system.</p>
            <p>All rights reserved. IEC Electric Power Limited.</p>
            <p><a href="http://erp.iecelectric.co.in/">http://erp.iecelectric.co.in/</a></p>
        </div>

    </div>
</body>
</html>
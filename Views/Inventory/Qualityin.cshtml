@model IEnumerable<CMKL.Models.Logisticin>

@{
    ViewBag.Title = "Logisticin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
@*<script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <script src="~/Scripts/bootstrap.min.js"></script>*@


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        window.onload = function () {
            toastr.success("@TempData["message"]")
            
        }
    </script>
    
}

<h3 style="text-align:center">Quality In Item Wise</h3>


@*<p>
        @Html.ActionLink("Create New", "Create")
    </p>
*@

<div class="container">
    <table class="table table-striped table-dark">
        
            <tr>
                <th>
                    @Html.DisplayName("Company Name")

                </th>
                <th>
                    @Html.DisplayName("Bill No")

                </th>
                <th>
                    @Html.DisplayName("Bill Date")

                </th>
                <th>
                    @Html.DisplayName("Item Name")

                </th>
                <th>
                    @Html.DisplayName("Product Code")

                </th>

            </tr>
       
        @foreach (var item in Model)
        {
            <tr>                
                <td>
                    @Html.DisplayFor(modelItem => item.CompanyName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Billno)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.billdate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Itemname)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Productcode)
                </td>               

                <td>
                    @* @Html.ActionLink("Stock Take IN (Quality)", "Qualityindetail", new { ids = item.id })
        <a href="#" data-toggle="modal" data-target="#EditRecord" class="edit" data-id="@item.id">Edit</a>
        <button onclick="location.href='#'" data-toggle="modal" data-target="#EditRecord" class="edit" data-id="@item.id">Edit</button>
                    *@<button type="button" class="btn btn-success edit" data-toggle="modal" data-target="#EditRecord" data-id="@item.id">Update </button>
                    @* <a href="#" data-toggle="modal" onclick="edit(@item.id)" class="edit">Edit</a>*@
                </td>

            </tr>
        }
    </table>
    </div>


    <div class="modal fade" tabindex="-1" role="dialog" id="EditRecord">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title" style="text-align:center">Update Serial Number </h3>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form id="myform" method="post" asp-controller="Home" asp-action="EditRecord">
                    <div class="modal-body">
                        <div class="col-sm-6" style="display:none;">
                            <label>ID:</label>
                            <input type="text" class="form-control" name="id" id="id" required readonly />
                        </div>

                        <div class="col-sm-6">
                            <label>Company Name:</label>
                            <input type="text" class="form-control" name="Company Name" id="CompanyName" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Bill Number:</label>
                            <input type="text" class="form-control" name="Bill No" id="Billno" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Bill Date:</label>
                            <input type="text" class="form-control" name="Bill Date" id="billdate" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Item Name:</label>
                            <input type="text" class="form-control" name="Item Name" id="itemname" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Item Desc:</label>
                            <input type="text" class="form-control" name="Item Desc" id="itemdesc" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Item Code:</label>
                            <input type="text" class="form-control" name="Item Code" id="itemcode" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Logistic In Date:</label>
                            <input type="text" class="form-control" name="Item Code" id="logisticindate" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Plant In Date:</label>
                            <input type="text" class="form-control" name="Item Code" id="plantindate" required readonly />
                        </div>
                        <div class="col-sm-6">
                            <label>Serial No:</label>
                            <input type="text" class="form-control" name="Serial No" id="serialno" required />
                        </div>
                        <div class="col-sm-6">
                            <label>Quality:</label>
                            <select class="form-control" id="quality">
                                <option id="3">Select</option>
                                <option id="1">Passed</option>
                                <option id="2">Not Passed</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label>Rejection Reason:</label>
                            <select class="form-control" id="rejectionreason">
                                <option id="5">NA</option>
                                <option id="1">Short Supply</option>
                                <option id="2">Wrong Supply</option>
                                <option id="3">Physical Damage</option>
                                <option id="4">Line Rejection</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label>Quality Remarks if any:</label>
                            <input type="text" class="form-control" name="Serial No" id="qremarks" required />
                        </div>
                        <div class="col-sm-6">
                            <label style="align-content:center">Quality File Attachment</label>
                            <input type="file" class="form-control-file" id="qualityupload">
                        </div>
                    </div>



                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" style="text-align:right" data-dismiss="modal">Cancel</button>
                        @*<button type="submit" id="update" class="btn btn-primary">Save changes</button>*@
                        <p><button type="button" id="add" class="btn btn-success">Update Data</button></p>

                    </div>
                </form>

        </div>
        </div>
    </div>


    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/toastr/Js/toastr.js"></script>
    <link href="~/toastr/toastr.css" rel="stylesheet" />

    <script>


        $(document).ready(function () {
            $('table .edit').on('click', function () {
                var id = $(this).data("id");

                $.ajax({
                    type: 'POST',
                    url: 'GetItem/?id="+id;',
                    data: { "id": id },
                    success: function (response) {
                        $('#EditRecord #id').val(response.id);
                        $('#EditRecord #CompanyName').val(response.CompanyName);
                        $('#EditRecord #Billno').val(response.Billno);
                        $('#EditRecord #billdate').val(response.billdate);
                        $('#EditRecord #itemname').val(response.Itemname);
                        $('#EditRecord #itemdesc').val(response.Itemdesc);
                        $('#EditRecord #itemcode').val(response.Productcode);
                        $('#EditRecord #logisticindate').val(response.logisticindate);
                        $('#EditRecord #plantindate').val(response.plantindate);
                    }
                })
            });

            $('table .delete').on('click', function () {
                var id = $(this).data("id");

                $.ajax({
                    type: 'POST',
                    url: 'Home/FindRecord/',
                    data: { "cusid": id },
                    success: function (response) {
                        $('#DeleteRecord #id').val(response.id);
                        $('#DeleteRecord #name').val(response.name);
                        $('#DeleteRecord #email').val(response.email);
                        $('#DeleteRecord #phone').val(response.phone);
                    }
                })
            });
        });

        $(document).ready(function () {
           
            $("#add").click(function () {
                var data = $("#myForm").serialize();
                var formData = new FormData();
                var totalFiles = document.getElementById("qualityupload").files.length;
                for (var i = 0; i < totalFiles; i++) {
                    var file = document.getElementById("qualityupload").files[i];
                    formData.append("qualityupload", file);
                }
                formData.append("fid", $("#id").val());
                formData.append("fserno", $("#serialno").val());
                formData.append("fquality", $("#quality").val());
                formData.append("frejection", $("#rejectionreason").val());
                formData.append("fremarks", $("#qremarks").val());
                
                
                                
                $.ajax({
                    type: "POST",
                    url: "/Inventory/updatequality",
                    data: formData,
                    contentType: false,
                    processData: false,
                   
                    success: function (response) {
                        if (response.success == true) {

                            toastr.success(response.message);
                            window.location.href = '/Inventory/Qualityin';
                            $('#EditRecord').modal('hide');


                        }
                        else {
                            toastr.error(response.message);
                        }


                    },
                    error: function () {
                        toastr.error('There is Somthing Wrong');                       

                    }


                });
            });
        })

        $('#quality').change(function () {

            var selectedValue = $("#quality").val();
            debugger;
            $.ajax({
                url: '@Url.Action("dropdownquality", "Inventory")',
                //url: '/Controller/dropdown',
                type: 'GET',
                dataType: 'json',
                data: { selectedValue: selectedValue },
                success: function (data) {
                    $('#rejectionreason').empty();
                    var s = '<option value="-1">Select</option>';
                    for (var i = 0; i < data.length; i++) {
                        s += '<option value="' + data[i] + '">' + data[i] + '</option>';
                    }
                    $("#rejectionreason").html(s);

                }
            });
        });
    </script>

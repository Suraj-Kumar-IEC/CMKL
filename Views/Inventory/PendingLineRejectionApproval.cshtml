
@{
    ViewBag.Title = "PendingLineRejectionApproval";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}

<h3 style="background-color: #00698f; color: #ffffff; padding: 5px 10px; border-radius: 5px; text-align: center;">Pending Line Rejections</h3>

<table class="table table-sm table-bordered" id="pendingLrTable">
    <thead>
        <tr>
            <th>Voucher Number</th>
            <th>Voucher Date</th>
            <th>Supplier</th>
            <th>Bill Number</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td colspan="5" class="text-center">Loading pending Line Rejections...</td>
        </tr>
    </tbody>
</table>

<div class="modal fade" id="lrDetailsModal" tabindex="-1" role="dialog" aria-labelledby="lrDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="lrDetailsModalLabel">Line Rejection Details</h5>
            </div>
            <div class="modal-body" id="lrDetailsContent">
            </div>
            <div class="modal-footer">
                <button type="button" id="closemodal" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />

@section Scripts {
    <script>
        $(document).ready(function () {
            // --- Load Pending LRs using AJAX ---
            function loadPendingLrs() {
                $.ajax({
                    url: '/Inventory/GetPendingLRsJson', //  new Controller/Action for JSON
                    type: 'GET',
                    success: function (data) {
                        var tableBody = $('#pendingLrTable tbody');
                        tableBody.empty(); // Clear loading message or any previous data
                        debugger;
                        if (data && data.data && data.data.length > 0) {
                            $.each(data.data, function (index, lr) {
                                const FormattedVDate = moment(lr.voucherDate).format('DD/MM/YYYY');
                                var row = `
                                            <tr>
                                                <td>${lr.voucherNumber}</td>
                                                <td>${FormattedVDate}</td>
                                                <td>${lr.supplierName}</td>
                                                <td>${lr.billNumber}</td>
                                                <td>
                                                    <button class="btn btn-info btn-sm view-details-btn" data-lr-id="${lr.lrId}">
                                                        <i class="fas fa-eye"></i> View Details
                                                    </button>
                                                    <button class="btn btn-success btn-sm approve-lr-btn" data-lr-id="${lr.lrId}">
                                                        <i class="fas fa-check"></i> Approve
                                                    </button>
                                                </td>
                                            </tr>
                                        `;
                                tableBody.append(row);
                            });
                            initializeEvents(); //  event handlers after rows are added
                        } else {
                            tableBody.append('<tr><td colspan="5" class="text-center">No pending Line Rejections found.</td></tr>');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Error loading pending LRs:", status, error, xhr);
                        $('#pendingLrTable tbody').html('<tr><td colspan="5" class="text-center text-danger">Failed to load Line Rejections. Please try again.</td></tr>');
                    }
                });
            }
            $('#closemodal').click(function () {
                $('#lrDetailsModal').modal('hide');
            });

            // --- Populate Modal Function ---
            function populateModal(data) {
                var modalContent = $('#lrDetailsContent');
                modalContent.empty();

                if (data) {
                    const FormattedVDate = moment(data.VoucherDate).format('DD/MM/YYYY');
                    const FormattedLRDate = moment(data.LRDate).format('DD/MM/YYYY');
                    let html = `
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Voucher Number:</strong> ${data.VoucherNumber}</p>
                                <p><strong>Voucher Date:</strong> ${FormattedVDate}</p>
                                <p><strong>Supplier:</strong> ${data.SupplierName}</p>
                                <p><strong>Bill Number:</strong> ${data.BillNumber}</p>
                                <p><strong>LR Date:</strong> ${FormattedLRDate}</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Created By:</strong> ${data.CreatedBy}</p>
                                <p><strong>Created On:</strong> ${FormattedVDate}</p>
                                <p><strong>Remarks:</strong> ${data.Remarks}</p>
                            </div>
                        </div>
                        <hr>`;

                    html += `
                        <h4>Rejected Items</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Item Name</th>
                                    <th>Quantity</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>${data.ItemName}</td>
                                    <td>${data.Quantity}</td>
                                </tr>
                            </tbody>
                        </table>`;
                    modalContent.html(html);
                } else {
                    modalContent.html('<p class="text-danger">No details found for this Line Rejection.</p>');
                }
            }

            // --- Initialize Event Handlers (called after table is populated) ---
            function initializeEvents() {
                $('.view-details-btn').off('click').click(function () { // Detach previous handlers
                    var lrId = $(this).data('lr-id');
                    $.ajax({
                        url: '/Inventory/GetLRDetailsJson', //  Controller/Action for JSON
                        type: 'GET',
                        data: { lrId: lrId },
                        success: function (data) {

                            populateModal(data);
                            $('#lrDetailsModal').modal('show');
                        },
                        error: function (xhr, status, error) {
                            console.error("Error loading LR details:", status, error, xhr);
                            alert("Failed to load Line Rejection details.");
                        }
                    });
                });

                $('.approve-lr-btn').off('click').click(function () {
                    var $button = $(this); // Store the button in a variable
                    var lrId = $button.data('lr-id');
                    if (confirm("Are you sure you want to approve this Line Rejection?")) {
                        $.ajax({
                            url: '/Inventory/ApproveLR',
                            type: 'POST',
                            data: { lrId: lrId },
                            success: function (response) {
                                if (response.success) {
                                    toastr.success(response.message);
                                    $button.closest('tr').fadeOut(function () { // Use the stored button variable
                                        $(this).remove();
                                    });
                                } else {
                                    alert(response.message);
                                }
                            },
                            error: function (xhr, status, error) {
                                console.error("Error approving LR:", status, error, xhr);
                                alert("Failed to approve Line Rejection.");
                            }
                        });
                    }
                });

            }

            // --- Initial Load ---
            loadPendingLrs(); // Call function to load data on page load

        });
    </script>
}

<script>
    $(document).ready(function () {

        $.ajax({
            type: 'GET',
            url: '@Url.Action("BOMMasterDropdown", "BOM")',
            dataType: 'json',
            success: function(data) {
                $.each(data.baseframe, function (index, item) {
                    //$("#baseframe").empty();
                    $("#baseframe").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });

                $.each(data.DG, function (index, item) {
                   // $("#dgassy").empty();
                    $("#dgassy").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });

                $.each(data.panel, function (index, item) {
                   // $("#panel").empty();
                    $("#panel").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });

                $.each(data.Alternator, function (index, item) {
                  //  $("#alternator").empty();
                    $("#alternator").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.canopy, function (index, item) {
                    //  $("#alternator").empty();
                    $("#canopy").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.fueltank, function (index, item) {
                    //  $("#alternator").empty();
                    $("#fueltank").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.exhaust, function (index, item) {
                    //  $("#alternator").empty();
                    $("#exhaustsystem").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.acoustic, function (index, item) {
                    //  $("#alternator").empty();
                    $("#acoustictreatment").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.assembly, function (index, item) {
                    //  $("#alternator").empty();
                    $("#assembly").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.final, function (index, item) {
                    //  $("#alternator").empty();
                    $("#finalpacking").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });
                $.each(data.electrical, function (index, item) {
                    //  $("#alternator").empty();
                    $("#electrical").append("<option value='" + item.value + "'>" + item.text + "</option>");
                });

            }
        });

    });
</script>

<script type="text/javascript">
    $(function () {
        var previousValue = "";
        $("#finalItem").click(function () {
            var currentValue = $(this).val();
            if (currentValue !== previousValue) {
                previousValue = currentValue;
                $.ajax({
                    url: '@Url.Action("GetFinalItems", "BOM")',
                    type: 'GET',
                    dataType: 'json',
                    success: function (data) {
                        $('#finalItem').empty(); // clear existing options
                        var options = '';
                        $.each(data, function (index, item) {
                            options += '<option value="' + item.Value + '">' + item.Text + '</option>';
                        });
                        $('#finalItem').append(options); // append new options
                        $('#finalItem').val(previousValue); // select the previously selected value
                    }
                });
            }
        });
    });
</script>
<script>
    $(document).ready(function () {
        $('#CreateFGItem').click(function (event) {
            // Prevent the default form submission
            event.preventDefault();

            if ($('#FinalProductCode').val() === "") {
                toastr.error('Please Enter Product Code');
                return false;
            }
            // Get the item name and code
            var itemName = $('#FinalProduct').val();
            var itemCode = $('#FinalProductCode').val();
            debugger;


            // ... rest of your code to build and show the modal ...

            $('#confirmModal').modal('show');
            $('#confirmModal').on('shown.bs.modal', function (e) {
                $('#FGname').text(itemName);
                $('#FGCode').text(itemCode);
                $('#FGUOM').text('Nos');
            });
        });
        $('#closemodal').click(function () {
            $('#confirmModal').modal('hide');
        });

        // Handle the "Save BOM" button click
        $('#continueSave').click(function () {
            debugger;
            var canopy = $("#canopy").val();
            var fueltank = $("#fueltank").val();
            var exhaustsystem = $("#exhaustsystem").val();
            var acoustictreatment = $("#acoustictreatment").val();
            var finalpacking = $("#finalpacking").val();
            var assembly = $("#assembly").val();
            var electrical = $("#electrical").val();
            var finalItemv = $("#finalItem").val();
            var baseframev = $("#baseframe").val();
            var dgassyv = $("#dgassy").val();
            var panelv = $("#panel").val();
            var alternatorv = $("#alternator").val();
            var masteritemcode = $('#FinalProductCode').val();
            var masteritemname = $('#FinalProduct').val();
            var masteruom = '1';
            // Perform your save logic here, e.g., submit a form
            var dataToSend = {
                finalItem: finalItemv,
                canopy: canopy,
                fueltank: fueltank,
                exhaustsystem: exhaustsystem,
                acoustictreatment: acoustictreatment,
                finalpacking: finalpacking,
                assembly: assembly,
                baseframe: baseframev,
                dgassy: dgassyv,
                panel: panelv,
                alternator: alternatorv,
                electrical: electrical,
                masteritemcode: masteritemcode,
                masteritemname: masteritemname,
                masteruom: masteruom,
            };
            $.ajax({
                type: 'post',
                url: '/inventory/saveFGitem',
                data: dataToSend,
                success: function (data) {
                    if (data.success) {
                        toastr.success(data.msg);
                        $('#confirmModal').modal('hide');
                        // ... (other actions on success) ...
                    } else {
                        // Handle errors returned from the server
                        toastr.error(data.msg);
                        // You might want to display the error message in the modal or on the page
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    // Handle AJAX errors (e.g., network issues, server errors)
                    toastr.error("An error occurred while saving.");
                    console.error("AJAX Error:", textStatus, errorThrown);
                }
            });
        });
    });
</script>
<script>
    $(document).ready(function () {
    // Function to update the final product name and check for existing combinations
    function updateProductName() {
        var productName = "";

        // Get selected values from all dropdowns (Values of Selection)

        var canopy = $("#canopy").val();
        var fueltank = $("#fueltank").val();
        var exhaustsystem = $("#exhaustsystem").val();
        var acoustictreatment = $("#acoustictreatment").val();
        var finalpacking = $("#finalpacking").val();
        var assembly = $("#assembly").val();
        var electrical = $("#electrical").val();
        var finalItemv = $("#finalItem").val();
        var baseframev = $("#baseframe").val();
        var dgassyv = $("#dgassy").val();
        var panelv = $("#panel").val();
        var alternatorv = $("#alternator").val();

        // Get selected text for product name (Final Product Name Text)
        var finalItem = $("#finalItem option:selected").text();
        var baseframe = $("#baseframe option:selected").text();
        var dgassy = $("#dgassy option:selected").text();
        var panel = $("#panel option:selected").text();
        var alternator = $("#alternator option:selected").text();

        // Build the product name string for display
        var selectedValues = [finalItem + ' With', baseframe + ' - Base Frame', alternator + ' - Alternator', dgassy + ' - Type', panel + ' - Panel'];
        productName = selectedValues.filter(Boolean).join(" | ");

        // Update the "Final Product" input field
        $("#FinalProduct").val(productName);

        // Prepare data to send to the controller
        var dataToSend = {
            finalItem: finalItemv,
            canopy: canopy,
            fueltank: fueltank,
            exhaustsystem: exhaustsystem,
            acoustictreatment: acoustictreatment,
            finalpacking: finalpacking,
            assembly: assembly,
            baseframe: baseframev,
            dgassy: dgassyv,
            panel: panelv,
            alternator: alternatorv,
            electrical: electrical
        };

        // AJAX call to the controller
        $.ajax({
            type: "GET",
            url: "@Url.Action("CheckProductCombination", "BOM")", // Replace "BOM" with your actual controller name
            data: dataToSend,
            success: function (response) {
                if (response.success) {
                    toastr.success(response.msg);
                    debugger;
                    $('#CreateFGItem').prop('disabled', true);
                    $('#FinalProductCode').prop('disabled', true);
                    $('#FinalProductCode').val(response.itemcode);
                    // Combination does NOT exist, allow saving
                } else {
                    toastr.error(response.msg);
                    $('#CreateFGItem').prop('disabled', false);
                    $('#FinalProductCode').prop('disabled', false);
                    $('#FinalProductCode').val('');
                    // Combination exists, prevent saving
                }
            },
            error: function (xhr, status, error) {
                console.error("Error checking product combination:", error);
                // ... handle the error (e.g., display an error message)
            }
        });
    }
        // Attach change event handlers to all select elements
    $("select.form-control-sm").change(function () {
        updateProductName();
    });
});
</script>


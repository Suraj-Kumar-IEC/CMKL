                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal" id="closemodal" style=" background-color: #00698f; color: #ffffff; border-color: #0070d2;">Close</button>
                    <button type="button" id="continueSave" class="btn btn-primary" data-dismiss="modal" style=" background-color: #00698f; color: #ffffff; border-color: #0070d2;">Save FG Product</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>

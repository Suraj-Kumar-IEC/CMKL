@{
    ViewBag.Title = "FG Stock Lifecycle Analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --amber: #92400e;
        --green: #166534;
        --blue: #00698f;
        --slate: #475569;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Inter', sans-serif;
    }

    /* Animations */
    .animate-up {
        animation: fadeInUp 0.5s ease forwards;
        opacity: 0;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .header-glass {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        padding: 20px;
        border-radius: 12px;
        border-left: 6px solid var(--blue);
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        margin-bottom: 20px;
    }

    .stat-card {
        background: white;
        border-radius: 10px;
        padding: 15px;
        border: 1px solid #e2e8f0;
        transition: 0.3s;
        position: relative;
        border-bottom: 3px solid transparent;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px rgba(0,0,0,0.08);
        }

    .table-modern {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        border: none;
    }

        .table-modern thead th {
            background: #f8fafc;
            font-size: 0.62rem;
            letter-spacing: 0.3px;
            border: 1px solid #e2e8f0 !important;
            color: #64748b;
            vertical-align: middle;
        }

    .qty-badge {
        font-family: 'Consolas', monospace;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .bg-stage-wip {
        background-color: #f8fafc !important;
        color: var(--slate);
    }

    .bg-stage-prod {
        background-color: #f0fdf4 !important;
        color: var(--green);
    }

    .bg-stage-ewap {
        background-color: #fffbeb !important;
        color: var(--amber);
    }

    .loader-dot {
        width: 10px;
        height: 10px;
        background: var(--blue);
        border-radius: 50%;
        display: inline-block;
        animation: pulse 1s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.3;
            transform: scale(0.8);
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="header-glass animate-up">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold m-0 text-dark">FG Stock Lifecycle Analytics</h4>
                <p class="text-muted small m-0"><i class="fas fa-microchip me-1"></i> Assembly WIP → Production Completed → Tested FG</p>
            </div>
            <div class="d-flex gap-2">
                <input type="date" id="txtFromDate" class="form-control form-control-sm" value="@DateTime.Now.ToString("yyyy-MM-01")">
                <input type="date" id="txtToDate" class="form-control form-control-sm" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                <button class="btn btn-dark btn-sm px-4 fw-bold shadow-sm" onclick="loadLedger()">RUN REPORT</button>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4 text-center">
        <div class="col-md-3 animate-up" style="animation-delay:0.1s"><div class="stat-card" style="border-color:var(--slate)"><small class="text-muted fw-bold">IN-ASSEMBLY (WIP)</small><h2 class="fw-bold m-0" id="kpi-wip">0</h2></div></div>
        <div class="col-md-3 animate-up" style="animation-delay:0.2s"><div class="stat-card" style="border-color:var(--green)"><small class="text-muted fw-bold">PROD. COMPLETED</small><h2 class="fw-bold m-0 text-success" id="kpi-prod">0</h2></div></div>
        <div class="col-md-3 animate-up" style="animation-delay:0.3s"><div class="stat-card" style="border-color:var(--amber)"><small class="text-muted fw-bold">READY FG (TESTED)</small><h2 class="fw-bold m-0 text-warning" id="kpi-fg">0</h2></div></div>
        <div class="col-md-3 animate-up" style="animation-delay:0.4s"><div class="stat-card" style="border-color:#dc2626"><small class="text-muted fw-bold">DISPATCHED (OUT)</small><h2 class="fw-bold m-0 text-danger" id="kpi-out">0</h2></div></div>
    </div>

    <div class="card table-modern shadow-sm animate-up" style="animation-delay:0.5s">
        <div class="table-responsive">
            <table class="table mb-0" id="tblLedger">
                <thead class="text-center">
                    <tr>
                        <th rowspan="2" class="text-start bg-white align-middle px-3" style="min-width:200px;">Product Description [Model]</th>
                        <th colspan="4" class="bg-stage-wip py-2">Stage 1: Assembly WIP</th>
                        <th colspan="4" class="bg-stage-prod py-2">Stage 2: Production Completed</th>
                        <th colspan="4" class="bg-stage-ewap py-2">Stage 3: Tested FG (Ready)</th>
                    </tr>
                    <tr>
                        <th class="bg-light">Op.</th>
                        <th class="bg-light">In</th>
                        <th class="bg-light">Out</th>
                        <th class="bg-light fw-bold text-dark">Bal</th>
                        <th class="bg-light border-start">Op.</th>
                        <th class="bg-light">In</th>
                        <th class="bg-light">Out</th>
                        <th class="bg-light fw-bold text-dark">Bal</th>
                        <th class="bg-light border-start">Op.</th>
                        <th class="bg-light">In</th>
                        <th class="bg-light">Out</th>
                        <th class="bg-light fw-bold text-dark">Bal</th>
                    </tr>
                </thead>
                <tbody id="ledger-body" class="text-center small">
                    <tr><td colspan="13" class="py-5 text-muted">Ready to fetch data. Please click "RUN REPORT".</td></tr>
                </tbody>
                <tfoot class="bg-dark text-white fw-bold text-center" style="font-size: 0.75rem; border-top: 2px solid #334155;">
                    <tr>
                        <td class="text-end px-3">TOTALS:</td>
                        <td id="sumWOp">0</td>
                        <td id="sumWIn">0</td>
                        <td id="sumWOu">0</td>
                        <td id="sumWCl" style="background:#475569">0</td>
                        <td id="sumPOp">0</td>
                        <td id="sumPIn">0</td>
                        <td id="sumPOu">0</td>
                        <td id="sumPCl" style="background:#475569">0</td>
                        <td id="sumEOp">0</td>
                        <td id="sumEIn">0</td>
                        <td id="sumEOu">0</td>
                        <td id="sumECl" style="background:#475569">0</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />

<script>
    function loadLedger() {
        const from = $('#txtFromDate').val();
        const to = $('#txtToDate').val();

        $('#ledger-body').html('<tr><td colspan="13" class="py-5"><div class="loader-dot"></div><div class="loader-dot mx-2"></div><div class="loader-dot"></div><br><small class="text-muted mt-2 d-block">Calculating Triple-Stage Stock Movement...</small></td></tr>');

        $.ajax({
            url: '@Url.Action("GetFGStockLedger", "Inventory")',
            type: 'GET',
            data: { fromDate: from, toDate: to },
            success: function (res) {
                if (res.success) {
                    console.log("Total DB Records Found:", res.totalRecordsFound);
                    renderTable(res.data);
                }
                else {
                    toastr.error(res.message);
                    $('#ledger-body').html(`<tr><td colspan="13" class="py-5 text-danger">Error: ${res.message}</td></tr>`);
                }
            },
            error: function () {
                toastr.error("Connection Failed");
                $('#ledger-body').html('<tr><td colspan="13" class="py-5 text-danger">Critical Error: Connection Failed.</td></tr>');
            }
        });
    }

    function renderTable(data) {
        let rows = "";
        let s = {
            wop: 0, win: 0, wou: 0, wcl: 0,
            pop: 0, pin: 0, pou: 0, pcl: 0,
            eop: 0, ein: 0, eou: 0, ecl: 0
        };

        $.each(data, function (i, v) {
            s.wop += v.W_Op; s.win += v.W_In; s.wou += v.W_Ou; s.wcl += v.W_Cl;
            s.pop += v.P_Op; s.pin += v.P_In; s.pou += v.P_Ou; s.pcl += v.P_Cl;
            s.eop += v.E_Op; s.ein += v.E_In; s.eou += v.E_Ou; s.ecl += v.E_Cl;

            rows += `<tr class="border-bottom">
                <td class="text-start p-2"><div class="fw-bold text-dark" style="font-size:0.75rem;">${v.Description}</div></td>
                <td class="qty-badge text-muted">${v.W_Op}</td>
                <td class="qty-badge text-primary">+${v.W_In}</td>
                <td class="qty-badge text-danger">-${v.W_Ou}</td>
                <td class="qty-badge bg-light fw-bold">${v.W_Cl}</td>
                <td class="qty-badge text-muted border-start">${v.P_Op}</td>
                <td class="qty-badge text-primary">+${v.P_In}</td>
                <td class="qty-badge text-danger">-${v.P_Ou}</td>
                <td class="qty-badge bg-light fw-bold">${v.P_Cl}</td>
                <td class="qty-badge text-muted border-start">${v.E_Op}</td>
                <td class="qty-badge text-primary">+${v.E_In}</td>
                <td class="qty-badge text-danger">-${v.E_Ou}</td>
                <td class="qty-badge bg-warning bg-opacity-10 fw-bold" style="color:var(--amber)">${v.E_Cl}</td>
            </tr>`;
        });

        $('#ledger-body').hide().html(rows || '<tr><td colspan="13" class="py-5 text-muted">No data found for selected period.</td></tr>').fadeIn(400);

        $('#sumWOp').text(s.wop); $('#sumWIn').text(s.win); $('#sumWOu').text(s.wou); $('#sumWCl').text(s.wcl);
        $('#sumPOp').text(s.pop); $('#sumPIn').text(s.pin); $('#sumPOu').text(s.pou); $('#sumPCl').text(s.pcl);
        $('#sumEOp').text(s.eop); $('#sumEIn').text(s.ein); $('#sumEOu').text(s.eou); $('#sumECl').text(s.ecl);

        animateValue("kpi-wip", s.wcl);
        animateValue("kpi-prod", s.pcl);
        animateValue("kpi-fg", s.ecl);
        animateValue("kpi-out", s.eou);
    }

    function animateValue(id, end) {
        const obj = document.getElementById(id);
        if (!obj) return;
        let start = 0, duration = 1000, startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = Math.floor(progress * (end - start) + start);
            if (progress < 1) { window.requestAnimationFrame(step); }
        };
        window.requestAnimationFrame(step);
    }
</script>
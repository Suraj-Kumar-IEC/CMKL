@*Ajax Call to pick item according to Product Code*@

<script>
    getproductdetail();

    function getproductdetail() {


        $("#Itemcode").empty();
        $("#Itemcode").keyup(function (e) {
            var q = $("#Itemcode").val();


            $.ajax({
                type: "POST",
                url: '@Url.Action("getproductdetail", "Inventory")',
                dataType: "json",
                data: { dd: $("#Itemcode").val(), dd1: $("#company").val(),},
                success: function (data) {
                    console.log(data);

                    $('#Item').val(data.Itemname);
                    $('#desc').val(data.itemdesc);
                    $('#category').val(data.Itemcategory);
                    $('#stock').val(data.presentstock);
                    $('#itemid').val(data.id);
                    $('#norms').val(data.norms);
                    toastr.success("Item Found");
                    $("#basicvalue").focus();

                },
                error: function (xhr, status, error) {
                   // alert("The barcode entered is not correct");
                    toastr.error("Item Not Found");
                }
            });
            return true;
        });
    }
</script>


@*AutoFill Item Name Using Ajax*@

<script>
    var itemss;
    $("#Item").autocomplete({
        source: function (request, response) {
            $.ajax({
                url: '@Url.Action("itemdetail", "Inventory")',
                dataType: "json",
                data: { dd: $("#Item").val(), dd1: $("#company").val(), },
                //data: { search: $("#Item").val() },
                success: function (data) {
                    itemss = data;
                    response($.map(data, function (item) {
                        return { label: item.Itemname, value: item.Itemname };

                    }));

                },
                error: function (xhr, status, error) {
                    alert("Error");
                }


            });
        }
    });
</script>




@{
    ViewBag.Title = "BPRPurchase";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div><div class="container" align="center"><h2>BPR Purchase</h2></div></div>

<div>
    <div class="container" align="center">


        <table id="tablebill" class="table table-bordered">
            <tr align="center">
                <th>Bill Number</th>
                <th>Bill Date</th>
                <th>Select Company</th>
            </tr>
            <tr>
                <td>
                    <input type="text" class="form-control" placeholder="Bill Number" id="billno" name="billno" width="30px" required>
                </td>
                <td>
                    <input type="text" class="form-control" placeholder="Bill Date" id="billdt" name="billdt" width="30px" required>
                </td>
                <td>
                    <div class="col-sm-12">
                        <p>
                            <select class="form-control" id="company" name="Company" width="30px">
                                <option>GFE Kathua</option>
                                <option>IEC Barwala</option>
                                <option>IEC Panchkula</option>
                            </select>

                        </p>

                    </div>
                </td>
                <td>
                    <button type="button" id="save" class="btn btn-info" onclick="addProject()">Save Purchase Bill</button>
                </td>

            </tr>

        </table>

    </div>
</div>

<div>
    <div class="container" align="center">
        <div class="col-12">
            <table id="itemmaster" class="table table-bordered" align="center">
                <tr align="center">
                    <th>Item Code</th>
                    <th>Item Name</th>
                    <th>Item Description</th>
                    <th>Item Category</th>
                    <th>Norms</th>
                    <th>Stock</th>
                    <th>Transit</th>
                    <th>Basic Value</th>
                </tr>
                <tr align="center">
                    <td>
                        <input type="text" class="form-control" placeholder="Item Code" id="Itemcode" name="Itemcode" size="50px" required>
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Item" id="Item" name="Item" size="50px" required>
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Description" id="desc" name="desc" size="25px" disabled>
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Item Category" id="category" name="category" size="25px" disabled>
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Norms" id="norms" name="norms" size="25px">
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Stock" id="stock" name="stock" size:"5px" disabled>
                    </td>
                    <td>
                        <input type="number" class="form-control pro_price" id="qty" name="qty"
                               placeholder="qty" min="1" value="1" size:"5px" required disabled>
                    </td>
                    <td>
                        <input type="text" class="form-control" placeholder="Basic Value" id="basicvalue" name="basicvalue" size="25px" required>
                    </td>
                    <td>
                        <button class="btn btn-success" type="button" onclick="addproduct()">
                            Add
                        </button>
                    <td>
                        <input type="hidden" class="form-control" placeholder="itemid" id="itemid" name="itemid" size="5px" required>
                    </td>
                </tr>
            </table>

            <table class="table table table-bordered" id="product_list">
                <caption>Products</caption>

                <thead>
                    <tr>
                        <th style="width: 40px">Remove</th>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Item Desc</th>
                        <th>Item Category</th>
                        <th>Norms</th>
                        <th>Qty</th>
                        <th>Basic Price</th>


                    </tr>
                </thead>
                <tbody></tbody>
            </table>

        </div>
    </div>
</div>









@{
    ViewBag.Title = "GuestLogin";
    Layout = null;
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css">
<div class="container" style="margin-top:200px">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header text-center">
                    <img src="~/images/cmkl-logo.png" alt="Company Logo" class="img-fluid" style="max-width: 200px;">
                </div>
                <div class="card-body">
                    <form id="loginForm">
                        <div class="form-group">
                            <label for="username">Username:</label>
                            <input type="text" class="form-control" id="username" name="username" required>
                        </div>
                        <div class="form-group">
                            <label for="password">Password:</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>
                        <div class="form-group form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block">Log in</button>
                        <div id="loginError" class="text-danger mt-2" style="display: none;"></div>
                    </form>
                </div>
                <div class="card-footer text-center">
                    <button type="button" class="btn btn-secondary" id="generateUserLoginButton">Generate User Login</button>
                    <input type="text" id="id" hidden="hidden" />
                </div>
            </div>
        </div>
    </div>
</div>
<span id="idorder"></span>
<form id="redirectForm" action="http://cmklqrcode.in:91/Login/GuestLogin" method="post" style="display: none;">
    <input type="hidden" id="orderIdInput" name="OrderId" />
</form>
<img id="wait-sign" src="~/images/wait-cmkl.gif" class="wait-sign-image" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);" />
@* ... (other parts of your view) *@
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
<script>
    $(document).ready(function () {
        // 1. Remove OrderId from Query String
        debugger;
        const urlParams = new URLSearchParams(window.location.search);
        const orderId = urlParams.get('OrderId');
        $('#id').val(orderId);

        if (orderId) {
            // Store OrderId in session storage
            sessionStorage.setItem('OrderId', orderId);

            // Remove OrderId from URL
            urlParams.delete('OrderId');
            const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
            window.history.replaceState({}, document.title, newUrl);
        }
        $('#loginForm').submit(function (e) {
            e.preventDefault();
            debugger;
            $('#wait-sign').show();
            var formData = $(this).serialize();
            var id = $('#id').val();
            var pass = $('#password').val();
            var user = $('#username').val();
            $.ajax({
                type: 'get',
                url: '/Login/QRLogin',
                data: { id: id, pass: pass, user: user },
                success: function (response) {
                    if (response.success) {
                        // Get OrderId from query string
                        toastr.success('Login Success..');
                        $('#wait-sign').hide();
                        window.location.href = '/CMKLProduct/ProductInformation';
                    } else {
                        toastr.error('Login Fail..');
                        $('#wait-sign').hide();
                    }
                },
                // ... (rest of your AJAX code)
            });
        });

        $('#generateUserLoginButton').click(function () {
            debugger; // This line will trigger a breakpoint in your browser's debugger

            var id = $('#username').val();
            if (id.trim() === '') {
                toastr.error('Please type your Registered Email ID in the User ID Field');
                $('#username').focus();
                return false;
            }

            // ... your other logic for generating a user login ...
        });
    });
</script>

<style>
    .wait-sign-image {
        width: 200px;
        height: 200px;
    }
</style>
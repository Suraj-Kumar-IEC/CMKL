
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}


<div class="container">
    <div class="row">
        <div class="col-md-6 col-md-offset-3">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 style="background-color: #00698f; color: #ffffff; padding: 5px 10px; border-radius: 5px; text-align: center;">Change Password</h3>
                </div>
                <div class="panel-body">
                    <form id="change-password-form">
                        <div class="form-group">
                            <label class="slds-form-element__label" for="username">
                                <span class="slds-text-link" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                                    User Name
                                </span>
                            </label>
                            <input type="text" id="username" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label class="slds-form-element__label" for="pass">
                                <span class="slds-text-link" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                                    Enter Existing Password
                                </span>
                            </label>
                            <input type="password" id="old-password" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label class="slds-form-element__label" for="newpassword">
                                <span class="slds-text-link" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                                    Enter New Password
                                </span>
                            </label>
                            <input type="password" id="new-password" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label class="slds-form-element__label" for="confirm">
                                <span class="slds-text-link" style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                                    Confirm Password
                                </span>
                            </label>
                            <input type="password" id="confirm-password" class="form-control" />
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary" style="background-color: #00698f; color: #ffffff;">Update</button>
                        </div>
                    </form>

                    <div id="result"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.16.2/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/exceljs/4.2.1/exceljs.min.js"></script>

<script>
    $(document).ready(function () {
        $('#change-password-form').submit(function (e) {
            e.preventDefault();

            var username = $('#username').val();
            var oldPassword = $('#old-password').val();
            var newPassword = $('#new-password').val();
            var confirmPassword = $('#confirm-password').val();

            if (newPassword !== confirmPassword) {
                toastr.error('Passwords do not match');
                // $('#result').html('Passwords do not match');
                return;
            }
            if (newPassword.length > 10) {
                toastr.warning("Password length must not exceed 10 characters.");
                return false; // Cancel the AJAX request
            }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("UpdatePassword", "Login")',
                data: {
                    username: username,
                    oldPassword: oldPassword,
                    newPassword: newPassword
                },
                success: function (data) {
                    if (data.success) {
                        toastr.success('Password Has been Updated');
                        $('#change-password-form')[0].reset();
                    } else {
                        toastr.error('Error: ' + data.error);
                       // $('#result').html('Error: ' + data.error);
                    }
                },
                error: function (xhr, status, error) {
                    toastr.error('Error: ' + error);
                    //$('#result').html('Error: ' + error);
                }
            });
        });
    });
</script>


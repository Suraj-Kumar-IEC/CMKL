                type: 'get',
                url: '/Purchase/GetPrintDataMRN',

                data: { poId: poId },
                success: function (data)
                {
                    //load Head Data
                    const formattedPODate = moment(data.poHeadData.PODate).format('DD/MM/YYYY');
                    const formatmrndate = moment(data.poHeadData.MRNDate).format('DD/MM/YYYY');

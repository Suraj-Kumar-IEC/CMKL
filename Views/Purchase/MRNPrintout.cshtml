                    const formatqualityadt = moment(data.poHeadData.qualityadt).format('DD/MM/YYYY');
                    const formatplantadt = moment(data.poHeadData.plantadt).format('DD/MM/YYYY');
                    const formataccountadt = moment(data.poHeadData.accountadt).format('DD/MM/YYYY');
                    //const formataccountadt = moment(data.poHeadData.accountadt).format('DD/MM/YYYY');
                    $('#CompanyName').text(data.poHeadData.companyname);
                    $('#CompanyNameHeader').text(data.poHeadData.companyname); 
                    $('#CAddress').text(data.poHeadData.CAddress);
                    $('#CAddress1').text(data.poHeadData.CAddress1);
                    $('#CGST').text(data.poHeadData.CGST);
                    $('#CPAN').text(data.poHeadData.CPAN);
                    $('#CContact').text(data.poHeadData.CContact);
                    $('#CDestination').text(data.poHeadData.CDestination);
                    $('#PODate').text(formattedPODate);
                    $('#PONumber').text(data.poHeadData.PONumber);
                    $('#GE').text(data.poHeadData.GateEntry);
                    $('#GEDate').text(formategatedate);
                    $('#SupplierName').text(data.poHeadData.SupplierName);
                    $('#SupplierAddress').text(data.poHeadData.supplierAddress);
                    $('#SupplierAddress1').text(data.poHeadData.supplierAddress1);
                    $('#SupplierState').text(data.poHeadData.supplierState);
                    $('#SupplierEmail').text(data.poHeadData.SEmail);
                    $('#SupplierGST').text(data.poHeadData.SupplierGST);
                    $('#ContactPerson').text(data.poHeadData.SupplierContactPerson);
                    $('#SupplierContact').text(data.poHeadData.SupplierContact);
                    $('#MRN').text(data.poHeadData.MRN);
                    $('#MRNDate').text(formatmrndate);
                    $('#totaltaxamount').text(parseFloat(data.poHeadData.TaxAmount).toFixed(2));
                    $('#totalbilltaxamount').text(parseFloat(data.poHeadData.BillTaxAmount).toFixed(2));
                    $('#totalbillamount').text(parseFloat(data.poHeadData.totalbillamount).toFixed(2));
                    $('#totalbillamountonbill').text(formattedTotal);

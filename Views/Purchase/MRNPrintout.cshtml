<title>A4 Paper Size with Shade - Centered Content</title>
<style>
/* Set A4 size */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

@@page {
    size: A4;
    margin: 0; /* Remove default page margins */
}

@@media print {
    .watermark {
        display: block !important; /* Ensure it's visible */
    }

    /* Add border to each page */
    body {
        border: 2px solid black; /* Adjust border style as needed */
        box-sizing: border-box; /* Include border in element's total width and height */
    }
}

.watermark-container {
    position: fixed; /* or absolute, depending on your layout */
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1; /* Place it behind other content */
    pointer-events: none; /* Allow clicks to pass through */
}
   
/* Set content to fill the entire A4 page */
html,
.setting > div {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column; /* Arrange content vertically */
    text-align: center;
}

.setting > div h4 {
    margin: 0; /* Remove default margin on the heading */
}

/* Style content with shaded background */
.content {
    width: 80%;
    height: 80%;
    padding: 20px;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
    background-color: #f0f0f0;
}

.table-container {
    width: 100%;
    font-size: 8px; /* Set font-size for the table container */
    overflow-x: auto;
}

.table {
    width: 100%;
    border-collapse: collapse;
}

.table th, .table td {
    border: 1px solid black;
    padding: 5px;
    text-align: left;
    word-wrap: break-word;
    font-size: inherit; /* Inherit font-size from the table container */
}

.inrow {
    padding: 10px 0;
}

/* Prevent page breaks within the table */
.table-container {
    page-break-inside: avoid;
}

/* Add top margin to the second page */
@@media print {
    .setting > div:nth-child(n+13) { /* Adjust the selector if needed */
        margin-top: 20px; /* Add some top margin to the second page content */
    }
}
</style>


                }
            });
        });

        //item line scan
        $('#BasicPrice, #Qty, #Discount, #Tax').on('input', function () {

            var BasicPrice = $('#BasicPrice').val();
            var Quantity = $('#Qty').val();
            var DiscountPercentage = $('#Discount').val();
            var Taxpercent = $('#Tax option:selected').attr('data-percent') || 0;
            var taxType = $('#Tax option:selected').attr('data-type');
            debugger;


            var TotalPrice = parseFloat(BasicPrice * Quantity);
            var NetBasicAmount = parseFloat(BasicPrice - (BasicPrice * DiscountPercentage / 100));
            var NetBasic = parseFloat((BasicPrice-((BasicPrice / 100) * DiscountPercentage)));
            var DiscountAmount = parseFloat((TotalPrice / 100) * DiscountPercentage);
            var NetTotal = parseFloat(TotalPrice - DiscountAmount);
            var NetBasicTaxable = parseFloat((NetBasic * Taxpercent / 100) + (NetBasic));
            var NetTotalTaxable = parseFloat((NetTotal * Taxpercent / 100) + (NetTotal));
            var Taxamount = parseFloat(NetTotal * Taxpercent / 100);
            if (taxType === 'Inclusive') {
                toastr.warning('Inclusive Calculation Not Defined in System');
            }
            else if (taxType === 'Exclusive') {
                $('#NetBasic').val(NetBasicAmount.toFixed(2));
                $('#NetTotal').val(NetTotalTaxable.toFixed(2));
                $('#TaxableAmount').val(NetTotal.toFixed(2));
                $('#TaxAmount').val(Taxamount.toFixed(2));
            }
            else
            {
                toastr.error('Select Tax');
            }

        })

        $('#freightAmount, #insuranceAmount, #pfCharges, #otherCharges , #OtherTax, #PFTax, #Insurancetax, #frieghttax ').on('input', function () {

            //Calculation is for Exclusive taxes only

            //Existing TaxonBill & Total Amount

            var Billtaxable = parseFloat($('#BillTaxableAmount').val() || 0);
            var BillGross = parseFloat($('#BillGrossAmount').val() || 0);


            var freight = parseFloat($('#freightAmount').val());
            var insurance = parseFloat($('#insuranceAmount').val());
            var pf = parseFloat($('#pfCharges').val());
            var other = parseFloat($('#otherCharges').val());

            //selected taxtype
            var freighttax = $('#frieghttax option:selected').attr('data-percent') || 0;
            var insurancetax = $('#Insurancetax option:selected').attr('data-percent') || 0;
            var pftax = $('#PFTax option:selected').attr('data-percent') || 0;
            var othertax = $('#OtherTax option:selected').attr('data-percent') || 0;

            //Calculate tax only
            var totalfrieghttax = parseFloat((freight * freighttax / 100));
            var totalinsurancetax = parseFloat((insurance * insurancetax / 100));
            var totalpftax = parseFloat((pf * pftax / 100));
            var totalothertax = parseFloat((other * othertax / 100));

            //Calculate Total for Other Detail Modal
            var totalfrieght = parseFloat((freight * freighttax / 100) + freight);
            var totalinsurance = parseFloat((insurance * insurancetax / 100) + insurance);
            var totalpf = parseFloat((pf * pftax / 100) + pf);
            var totalother = parseFloat((other * othertax / 100) + other);
            //Show Tax Only
            $('#frieghttaxamount').val(totalfrieghttax.toFixed(2));
            $('#insurancetaxamount').val(totalinsurancetax.toFixed(2));
            $('#pftaxamount').val(totalpftax.toFixed(2));
            $('#othertaxamount').val(totalothertax.toFixed(2));

            //Show Total
            $('#ttlfrieght').val(totalfrieght.toFixed(2));
            $('#ttlinsurace').val(totalinsurance.toFixed(2));
            $('#ttlpf').val(totalpf.toFixed(2));
            $('#ttlother').val(totalother.toFixed(2));


        })

    })

    </script>

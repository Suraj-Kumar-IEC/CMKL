
@{
    ViewBag.Title = "PurchaseOrder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}

<h3 style="background-color: #00698f; color: #ffffff; padding: 5px 12px; border-radius: 5px; text-align: center;">Purchase Order</h3>
<div class="container-fluid">

    <div class="row col-md-12" style="justify-content:center">
        <div class="col-md-3">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Select Supplier</label>
            <select id="Supplier" class="form-control form-control-sm">
                <option>
                    Select Supplier
                </option>
            </select>
        </div>
        <div class="col-md-3">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Supplier Address</label>
            <input type="text" class="form-control form-control-sm" id="SAddress" disabled="disabled" />
        </div>
        <div class="col-md-3">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Supplier Email</label>
            <input type="text" id="SEmail" class="form-control form-control-sm" disabled="disabled" />
        </div>
        <div class="col-md-3">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Contact Number</label>
            <input type="text" id="SContact" class="form-control form-control-sm" disabled="disabled" />
        </div>

        <div class="row" style="justify-content:center">
            <div class="col-md-2">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Select Company</label>
                <select id="Company" class="form-control form-control-sm">
                    <option>
                        Select Company
                    </option>
                </select>
            </div>
            <div class="col-md-2">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                    PO Number
                </label>
                <input type="text" class="form-control form-control-sm" id="POnumber" disabled="disabled" />

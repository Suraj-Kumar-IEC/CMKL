            </label>
            <input type="text" id="Discount" class="form-control form-control-sm" value="0" />
        </div>
        <div class="col-md-1">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                Net Basic
            </label>
            <input type="text" id="NetBasic" class="form-control form-control-sm" disabled="disabled" />
        </div>
        <div class="col-md-1">
            <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">

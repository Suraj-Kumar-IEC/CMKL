                url: '@Url.Action("GetSupplierDetail", "Purchase")',
                type: 'GET',
                data: { Supplierid: supplierid },
                //datatype: 'JSON',
                success: function (data)
                {
                    debugger;
                    $('#SAddress').val(data.Address);
                    $('#SEmail').val(data.Email);
                    $('#SContact').val(data.Contact);

                }
            })
        })
        $('#indentid').on('change', function () {
            //Get Indent Date
            var indno = $('#indentid option:selected').text();
            var indid = $('#indentid option:selected').val();
            $.ajax({
                type: 'GET',
                url: '/Purchase/GetIndentDate',
                data: { indid: indid },
                success: function (data) {
                    if (data && data.IndentDate) {
                        // Parse the date from the provided format
                        var dateString = data.IndentDate;
                        var milliseconds = parseInt(dateString.match(/\d+/)[0]);
                        var momentDate = moment(milliseconds);

                        if (momentDate.isValid()) {
                            var formattedDate = momentDate.format('YYYY-MM-DD');
                            // Display the formatted date
                            $('#IndentDate').val(formattedDate);
                        } else {
                            console.error("Invalid date received from server.");
                            $('#IndentDate').val(""); // Clear the input if the date is invalid.
                        }

                    } else {
                        console.error("Invalid date data received.");
                        $('#IndentDate').val(""); // Clear the input if the data is invalid.
                    }
                },
                error: function (xhr, status, error) {
                    console.error("AJAX Error:", status, error);
                    $('#IndentDate').val(""); // Clear the input if the ajax fails.
                }
            });

            $('#IndentNumber').val(indno);
        });

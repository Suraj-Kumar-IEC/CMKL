    <br />
    @*Button Code*@
    <div class="row justify-content-center">
        <div class="col-md-2">
            <button type="button" id="AddItem" class="btn btn-success"><i class="fa fa-save"></i>Add Item</button>
        </div>
        <div class="col-md-2">
            <button type="button" id="AddOtherCharges" class="btn btn-warning"><i class="fa fa-save"></i>Other Charges</button>
        </div>
        <div class="col-md-2">

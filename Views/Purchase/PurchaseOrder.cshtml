    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
    <script src="~/toastr/Js/toastr.js"></script>
    <link href="~/toastr/toastr.css" rel="stylesheet" />
    
    <script>
        $(document).ready(function () {
            $('#IsServiceOrder').on('change', function () {
                if ($(this).is(':checked')) {
                    $('#orderTypeLabel').text('Service Order').css('color', 'orange');
                } else {
                    $('#orderTypeLabel').text('Material Order').css('color', 'black');
                }
            });
            //Save PO Script
            $('#SavePO').click(function (event) {
                event.preventDefault();
                debugger;
                reclculation();

                if ($('#Company option:selected').text() === 'Select Company') {
                    toastr.error('Select Company');
                    $('#Company').focus();
                    return false;
                }
                if ($('#Supplier option:selected').text() === 'Select Supplier') {
                    toastr.error('Select Supplier');
                    $('#Supplier').focus();
                    return false;
                }
                $('#wait-sign').show();
                let Supplierid = $('#Supplier option:selected').val();
                let Companyid = $('#Company option:selected').val();
                let headid = $('#headid').val();
                // let PONumber = $('#POnumber').val() || 0;
                let PODate = $('#PODate').val();
                let IndentNumber = $('#IndentNumber').val();
                let IndentDate = $('#IndentDate').val();
                let DeliveryDate = $('#deliverydate').val();
                let BillTaxableAmount = $('#BillTaxableAmount').val();
                let taxtypeonbill = $('#taxtypeonbill option:Selected').val();
                let IGST = $('#IGST').val();
                let CGST = $('#CGST').val();
                let SGST = $('#SGST').val();
                let Billtaxamount = $('#Billtaxamount').val();
                let BillGrossAmount = $('#BillGrossAmount').val();
                let frieghttype = $('#frieghttype option:selected').val();
                let freightAmount = $('#freightAmount').val();
                let frieghttax = $('#frieghttax option:selected').val();
                let frieghttaxamount = $('#frieghttaxamount').val();
                let ttlfrieght = $('#ttlfrieght').val();
                let insurancetype = $('#insurancetype option:selected').val();
                let insuranceAmount = $('#insuranceAmount').val();
                let Insurancetax = $('#Insurancetax option:selected').val();
                let insurancetaxamount = $('#insurancetaxamount').val();
                let ttlinsurace = $('#ttlinsurace').val();
                let pftype = $('#pftype option:selected').val();
                let pfCharges = $('#pfCharges').val();
                let PFTax = $('#PFTax option:selected').val();

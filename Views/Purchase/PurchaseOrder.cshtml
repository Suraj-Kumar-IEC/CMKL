            </div>
            <div class="col-md-2">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">Select Indent</label>
                <select id="indentid" class="form-control form-control-sm">
                    <option>
                        Select Indent
                    </option>
                </select>
            </div>
            <div class="col-md-2">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                    Indent Number
                </label>
                <input type="text" id="IndentNumber" class="form-control form-control-sm" value="0" />
            </div>
            <div class="col-md-1">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                    Indent Date
                </label>
                <input type="date" id="IndentDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <label style="background-color: #00698f; padding: 4px 8px; color: #ffffff; border-radius: 4px;">
                    Delivery Date

                          '<td>' + entry.VoucherNo + '</td>' +
                          '<td>' + formattedVoucherDate + '</td>' +
                          '<td>' + entry.GRNo + '</td>' +
                          '<td>' + formattedGRDate + '</td>' +
                          '<td>' + entry.FrieghtAmount + '</td>' +
                          '<td>' + entry.Taxamount + '</td>' +
                          '<td>' + entry.BillAmount + '</td>' +
                          '<td>' + (entry.TaxAmountonBill || 0) + '</td>' +
                          '<td>' + (entry.BillAmountonBill || 0) + '</td>' +
                          '<td><button class="btn btn-success btn-sm view-items-btn" data-id="' + entry.id + '">View Items</button></td>' +
                          '</tr>';

                tableBody.append(row);
            });
        },
        error: function(xhr, status, error) {
            console.error("Error fetching data: " + error);
            // Consider adding more user-friendly error handling here (e.g., display an error message)
        }
    });
}

        $('#closemodal').click(function () {
            debugger;

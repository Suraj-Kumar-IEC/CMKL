                        totalRejectedQuantity += parseFloat(item.RejectedQuantity);
                        totalBasicPrice += parseFloat(item.BasicPrice);
                        totalTaxAmount += parseFloat(item.TaxAmount);
                        totalTotalAmount += parseFloat(item.TotalAmount);
                    });

                    // Append totals to footer
                    var footerRow = '<tr>' +
                        '<td colspan="1">Total:</td>' +
                        '<td>' + totalBillQuantity.toFixed(2) + '</td>' +

        // Create MRN

      
            // Loop through each row of the table
        $('#createMRNButton').click(function () {

                var rejectedQuantityFound = false;
                var returnCreated = false;
                var stopProcessing = false; // Flag to stop processing if needed

                // Loop through each row of the table
                $('#viewItemsTableBody tr:not(:last-child)').each(function () {
                    var qualityRejected = parseFloat($(this).find('td:nth-child(5)').text()) || 0; // Parse as float, handle potential NaN

                    if (qualityRejected > 0) {
                        rejectedQuantityFound = true;

                        // Check if return is created for this row
                        var rejectionReturn = $(this).find('td:nth-child(10)').text();
                        if (rejectionReturn == 'NA') {
                            returnCreated = false;
                            stopProcessing = true; // Stop processing if rejected quantity and no return
                            return false; // Break out of the .each() loop
                        } else {
                            returnCreated = true;
                        }
                    }
                });

                if (stopProcessing) {
                    // Show error message
                    toastr.warning('Purchase Return Not Created Yet');
                    $('#print-btn').hide();
                } else {
                var billid = $('#billid').val();
                $.ajax({
                    type: 'POST',
                    url: '/Purchase/generateMRN/',
                    data: { BillID: billid },
                    success: function (data) {
                        debugger;
                        var formattedMRNDate = moment(data.mrndate).format('DD-MM-YYYY');
                        $('#MRNNo').text(data.mrn);
                        $('#MRNDate').text(formattedMRNDate);
                        toastr.success('MRN Number Generated-' + data.mrn);

                        $('#print-btn').removeAttr('hidden').show();
                        $('#createMRNButton').hide();
                        Loaddata();
                        
                    }

                });
            }
        });

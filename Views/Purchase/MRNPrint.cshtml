        //

        $(document).on('click', '.view-items-btn', function () {
            var id = $(this).data('id');
            loadBillDetails(id);
        });

        function loadBillDetails(id) {
            $.ajax({
                type: 'GET',
                url: '/Purchase/GetItemsDetail', // Replace with your actual API URL
                data: { id: id },
                success: function (data) {

                    var BillDate = moment(data.billDetails.BillDate).format('DD-MM-YYYY');
                    var GRDate = moment(data.billDetails.GRDate).format('DD-MM-YYYY');
                    var FormatedPODate = moment(data.billDetails.PODate).format('DD-MM-YYYY');
                    // Populate the bill details section with data
                    $('#billNo').text(data.billDetails.BillNo);
                    $('#billDate').text(BillDate);
                    $('#supplierName').text(data.billDetails.SupplierName);
                    $('#totalAmount').text(data.billDetails.TotalAmount);
                    $('#GR').text(data.billDetails.GRNumber);
                    $('#GRDT').text(GRDate);
                    $('#billid').val(id);
                    $('#PONumber').text(data.billDetails.PONumber);
                    $('#PODate').text(FormatedPODate);



                    // Populate the modal table with data
                    var tableBody = $('#viewItemsTableBody');
                    tableBody.empty();
                    $.each(data.itemsDetail, function (index, item) {
                        var row = '<tr' + (item.RejectedQuantity !== 0 ? ' class="rejected"' : '') + '>' +
                            '<td>' + item.ItemCode + '</td>' +
                            '<td>' + item.BillQuantity + '</td>' +
                            '<td>' + item.Quantity + '</td>' +
                            '<td>' + item.QualityApprovedQty + '</td>' +
                            '<td>' + item.RejectedQuantity + '</td>' +
                            '<td>' + item.BasicPrice + '</td>' +
                            '<td>' + item.Tax + '</td>' +
                            '<td>' + item.TaxAmount + '</td>' +
                            '<td>' + item.TotalAmount + '</td>' +
                            '<td>' + item.RejectionReturn + '</td>' +
                            '</tr>';
                        tableBody.append(row);
                    });

                    // Calculate totals
                    var totalBillQuantity = 0;
                    var totalQuantity = 0;
                    var totalQualityApprovedQty = 0;
                    var totalRejectedQuantity = 0;
                    var totalBasicPrice = 0;
                    var totalTaxAmount = 0;
                    var totalTotalAmount = 0;

                    $.each(data.itemsDetail, function (index, item) {
                        totalBillQuantity += parseFloat(item.BillQuantity);
                        totalQuantity += parseFloat(item.Quantity);
                        totalQualityApprovedQty += parseFloat(item.QualityApprovedQty);
                        totalRejectedQuantity += parseFloat(item.RejectedQuantity);
                        totalBasicPrice += parseFloat(item.BasicPrice);
                        totalTaxAmount += parseFloat(item.TaxAmount);
                        totalTotalAmount += parseFloat(item.TotalAmount);
                    });
                    // Append totals to footer
                    var footerRow = '<tr>' +
                        '<td colspan="1">Total:</td>' +
                        '<td>' + totalBillQuantity.toFixed(2) + '</td>' +
                        '<td>' + totalQuantity.toFixed(2) + '</td>' +
                        '<td>' + totalQualityApprovedQty.toFixed(2) + '</td>' +
                        '<td>' + totalRejectedQuantity.toFixed(2) + '</td>' +
                        '<td>' + totalBasicPrice.toFixed(2) + '</td>' +
                        '<td></td>' + // Tax column is not summed
                        '<td>' + totalTaxAmount.toFixed(2) + '</td>' +
                        '<td>' + totalTotalAmount.toFixed(2) + '</td>' +
                        '<td></td>' + // Rejection Return column is not summed
                        '</tr>';
                    tableBody.append(footerRow);
                    // Show the modal
                    $('#viewItemsModal').modal('show');
                    $('#print-btn').removeAttr('hidden').hide();
                    // $('#print-btn').removeAttr('hidden').show();
                    $('#createMRNButton').show();
                   
                    $('#MRNNo').text('');
                    $('#MRNDate').text(''); 

                }
            });
        }

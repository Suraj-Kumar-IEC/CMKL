                        '<td>' + totalBasicPrice.toFixed(2) + '</td>' +
                        '<td></td>' + // Tax column is not summed
                        '<td>' + totalTaxAmount.toFixed(2) + '</td>' +
                        '<td>' + totalTotalAmount.toFixed(2) + '</td>' +
                        '<td></td>' + // Rejection Return column is not summed
                        '</tr>';
                    tableBody.append(footerRow);
                    // Show the modal
                    $('#viewItemsModal').modal('show');
                }
            });
        });
    });
</script>

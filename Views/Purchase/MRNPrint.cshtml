                var formattedVoucherDate = moment(entry.VoucherDate).format('DD-MM-YYYY');
                var formattedGRDate = moment(entry.GRDate).format('DD-MM-YYYY');

                var row = '<tr>' +
                          '<td>' + entry.id + '</td>' +

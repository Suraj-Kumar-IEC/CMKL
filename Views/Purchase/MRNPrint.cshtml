<table id="stockInTable" class="table table-bordered table-striped table-sm">
    <thead>
        <tr>
            <th>ID</th>
            <th>Supplier Name</th>
            <th>Bill No</th>
            <th>Bill Date</th>
            <th>Voucher No</th>
            <th>Voucher Date</th>
            <th>GR Number</th>
            <th>GR Date</th>
            <th>Frieght</th>
            <th>Tax Amount</th>
            <th>Bill Amount</th>
            <th>Tax (On Bill)</th>
            <th>Amount (On Bill)</th>
            <th>View Detail</th>           
        </tr>
    </thead>
    <tbody></tbody>
</table>
<!-- Modal -->
<div class="modal fade" id="viewItemsModal" tabindex="-1" role="dialog" aria-labelledby="viewItemsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewItemsModalLabel">View Items</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="bill-details">
                    <h3 style="background-color: #00698f; color: #ffffff; padding: 5px 12px; border-radius: 5px; text-align: center;">MRN Detail (IEPL)</h3>
                    <div class="row" style="line-height:2px">
                        <div class="col-md-2">
                            <p><strong>MRN No:</strong> <span id="MRNNo"></span></p>
                            <p><strong>MRN Date:</strong> <span id="MRNDate"></span></p>
                        </div>
                        <div class="col-md-2">
                            <p><strong>Bill No:</strong> <span id="billNo"></span></p>
                            <p><strong>Bill Date:</strong> <span id="billDate"></span></p>
                            <input type="number" hidden="hidden" id="billid" />
                        </div>
                        <div class="col-md-2">
                            <p><strong>PO No:</strong> <span id="PONumber"></span></p>
                            <p><strong>PO Date:</strong> <span id="PODate"></span></p>

                        </div>
                        <div class="col-md-2">
                            <p><strong>Supplier Name:</strong> <span id="supplierName"></span></p>
                            <p><strong>Total Amount:</strong> <span id="totalAmount"></span></p>
                        </div>
                        <div class="col-md-2">
                            <p><strong>GR Number:</strong> <span id="GR"></span></p>
                            <p><strong>GR Date:</strong> <span id="GRDT"></span></p>
                        </div>
                        <div class="col-md-2">
                            <p><strong>Gate Entry:</strong> <span id="GE"></span></p>                            
                        </div>
                    </div>
                    <hr style="border-top: 1px solid #000; margin-top: 10px; margin-bottom: 10px;">
                    <br />
                </div>
                <table class="table table-striped" id="viewItemsTable">
                    <thead>
                        <tr>
                            <th>Item Code</th>
                            <th>Bill Quantity</th>
                            <th>Recieved Quantity</th>
                            <th>Quality Accepted</th>
                            <th>Quality Rejected</th>
                            <th>Basic Price</th>
                            <th>Tax</th>
                            <th>Tax Amount</th>
                            <th>Total Amount</th>
                            <th>Rejection Return</th>
                        </tr>
                    </thead>
                    <tbody id="viewItemsTableBody">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal" id="closemodal">Close</button>
                <button type="button" class="btn btn-primary" id="createMRNButton">Create MRN</button>
                <button type="button" class="btn btn-info" id="print-btn" hidden>Print</button>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>

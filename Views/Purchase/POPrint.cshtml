<title>A4 Paper Size with Shade - Centered Content</title>
<style>
    /* Set A4 size */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    @@page {
        size: A4;
        margin: 5mm; /* Remove default page margins */
    }

    @@media print {
        .watermark {
            display: block !important;
        }

        body {
            /* border: none; */ /* Try removing the border */
            border: 1px solid black; /* Or reduce the size */
            box-sizing: border-box;
        }
    }

    .watermark-container {
        position: fixed; /* or absolute, depending on your layout */
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1; /* Place it behind other content */
        pointer-events: none; /* Allow clicks to pass through */
    }


    /* Set content to fill the entire A4 page */
    html,
    .setting > div {
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column; /* Arrange content vertically */
        text-align: center;
    }

        .setting > div h4 {
            margin: 0; /* Remove default margin on the heading */
        }

    /* Style content with shaded background */
    .content {
        width: 80%;
        height: 80%;
        padding: 20px;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
        background-color: #f0f0f0;
    }

    .table-container {
        width: 100%;
        font-size: 8px; /* Set font-size for the table container */
        overflow-x: auto;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

        .table th, .table td {
            border: 1px solid black;
            padding: 5px;
            text-align: left;
            word-wrap: break-word;
            font-size: inherit; /* Inherit font-size from the table container */
        }

    .inrow {
        padding: 10px 0;
    }

    /* Prevent page breaks within the table */
    .table-container {
        page-break-inside: avoid;
    }

    /* Add top margin to the second page */
    @@media print {
        /* ... other print styles ... */

        .setting > div:nth-child(7) { /* Targeting the table-container div */
            min-height: 300px; /* Adjust this value as needed - a bit less than a full page */
            page-break-inside: avoid; /* Keep table rows together as much as possible */
        }

        .supplier-acceptance {
            page-break-before: avoid; /* Try to keep it on the same page */
        }
    }
    @@media print {
        /* ... other print styles ... */

        .terms-and-conditions ul li {
            line-height: 0.9; /* Adjust this value as needed */
            margin-bottom: 2px; /* Optional: Reduce space between list items */
        }

            .terms-and-conditions ul li p {
                line-height: inherit; /* Ensure paragraph inherits the li's line-height */
                margin-bottom: 0; /* Remove default paragraph bottom margin */
            }
    }
</style>



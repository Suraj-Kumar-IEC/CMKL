    <div class="setting">
        <div class="table-container">
            <table class="table" id="table">
                <thead>
                    <tr>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Quantity</th>
                        <th>UOM</th>
                        <th>Last Order Date</th>
                        <th>Last Order Quantity</th>
                        <th>Last Supplier</th>
                        <th>Last Price</th>
                        <th>Min Level</th>
                        <th>MOQ</th>
                        <td>Monthly Cons. (Avg.)</td>
                        <th>Available Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.IndentItemDetail)
                    {
                        <tr>
                            <td>@item.ItemCode</td>
                            <td>@item.ItemName</td>
                            <td>@item.Quantity</td>
                            <td>@item.UOM</td>
                            <td>@item.LastOrderDate</td>
                            <td>@(item.LastOrderQuantity != null ? item.LastOrderQuantity.ToString() : "NA")</td>
                            <td>@(item.LastSupplier != null ? item.LastSupplier.ToString() : "NA")</td>
                            <td>@(item.LastPrice != null ? item.LastPrice.ToString("0.00") : "NA")</td>
                            <td>@(item.MinimumLevel != null ? item.MinimumLevel.ToString() : "NA")</td>
                            <td>@(item.MOQ != null ? item.MOQ.ToString() : "NA")</td>
                            <td>@(item.Average() != null ? item.Average().ToString() : "NA")</td>
                            <td>@item.AvailableStock</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div>

<script>
    //$(document).ready(function () {
    //    $('#Print').click();
    //})
    function printContent() {
        var printWindow = window.open('', '', 'height=794,width=612'); // A4 dimensions in pixels
        printWindow.document.write('<html><head><title></title></head><body>');
        printWindow.document.write(document.querySelector('.setting').innerHTML);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();
    }
</script>
<script>
    $(document).ready(function () {

            var id = @ViewBag.id;
            $.ajax({
                type: 'get',
                url: '/Purchase/IndentPrintOutData',
                data: { id: id },
                success: function (data)
                {

                    //load Head Data
                    const formattedindentDate = moment(data.IndentHeadData.IndentDate).format('DD/MM/YYYY');
                    $('#CompanyNameHeading').text(data.CompanyDetail.CompanyName);
                    $('#CompanyName').text(data.CompanyDetail.CompanyName);
                    $('#CAddress').text(data.CompanyDetail.CAddress);
                    $('#CAddress1').text(data.CompanyDetail.CAddress1);
                    $('#CGST').text(data.CompanyDetail.CGST);
                    $('#CPAN').text(data.CompanyDetail.CPAN);
                    $('#CContact').text(data.CompanyDetail.CContact);
                    $('#CDestination').text(data.CompanyDetail.CDestination);
                    $('#IndentNumber').text(data.IndentHeadData.IndentNumber);
                    $('#IndentDate').text(formattedindentDate);
                    $('#TotalItems').text(data.IndentHeadData.TotalQuantity);
                    $('#CreatedBy').text(data.IndentHeadData.CreatedBy);
                    $('#ApprovedBy').text(data.IndentHeadData.ApprovedBy);
                    var imageUrl;
                    var simageurl;

                    if (data && data.IndentHeadData) {
                        if (data.IndentHeadData.ImagePath) {
                            imageUrl = '@Url.Content("~/")' + data.IndentHeadData.ImagePath.substring(2);
                            $('#signatureImage').attr('src', imageUrl);
                        }

                        if (data.IndentHeadData.simagepath) {
                            simageurl = '@Url.Content("~/")' + data.IndentHeadData.simagepath.substring(2);
                            $('#ssignatureImage').attr('src', simageurl);
                        }
                    }
                  //  var imageUrl = '@Url.Content("~/")' + data.IndentHeadData.ImagePath.substring(2);
                  //  var simageurl = '@Url.Content("~/")' + data.IndentHeadData.simagepath.substring(2);
                   // $('#signatureImage').attr('src', imageUrl);
                   // $('#ssignatureImage').attr('src', simageurl);

                    const itemsTbody = document.getElementById('items');
                    let totalQuantity = 0;
                    data.IndentItemDetail.forEach(item => {
                        const rowHTML = `
                            <tr>
                        <td>${item.ItemCode}</td>
                        <td>${item.ItemName}</td>
                        <td>${parseFloat(item.Quantity).toFixed(3)}</td>
                        <td>${item.UOM}</td>
                        <td>${item.LastOrderDate}</td>
                        <td>${item.LastOrderQuantity ? parseFloat(item.LastOrderQuantity).toFixed(3) : 'NA'}</td>
                        <td>${item.LastSupplier || 'NA'}</td>
                        <td>${item.LastPrice ? parseFloat(item.LastPrice).toFixed(2) : 'NA'}</td>
                        <td>${item.MinimumLevel ? parseFloat(item.MinimumLevel).toFixed(3) : 'NA'}</td>
                        <td>${item.MOQ ? parseFloat(item.MOQ).toFixed(3) : 'NA'}</td>
                        <td>${item.Average ? parseFloat(item.Average).toFixed(3) : 'NA'}</td>
                        <td>${parseFloat(item.AvailableStock).toFixed(3)}</td>
                        <td>${ item.Remarks || 'NA'}</td>                      
                            </tr>
                        `;
                        itemsTbody.innerHTML += rowHTML;
                    });
                    debugger;
                    //$('#Print').click();


                }

            });
        })


</script>



<script type="text/javascript">
    $(document).ready(function () {
        console.log("Checking for security modal..."); // Debugging line
        if ($('#securityErrorModal').length > 0) {
            console.log("Modal found! Launching...");
            $('#securityErrorModal').modal('show');
        }
    });
    $(document).on('click', '[data-dismiss="modal"], [data-bs-dismiss="modal"]', function () {
        $('#securityErrorModal').modal('hide'); // For Bootstrap 4

        // For Bootstrap 5, if the above fails:
        var modalEntity = document.getElementById('securityErrorModal');
        var modalInstance = bootstrap.Modal.getInstance(modalEntity);
        if (modalInstance) {
            modalInstance.hide();
        }
    });
</script>



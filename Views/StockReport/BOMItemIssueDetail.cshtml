@{
    ViewBag.Title = "BOM Item Issue Intelligence";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            const isInModal = !!(document.querySelector('.modal.show'));
            const handleInvalidUser = () => {
                toastr.error("Session Expired. Please Login.");
                setTimeout(() => { window.location.href = "@Url.Action("Index", "Login")"; }, 2000);
            };
            setTimeout(handleInvalidUser, isInModal ? 500 : 0);
        });
    </script>
    <div class="vh-100 vw-100 bg-white"></div>
}

<style>
    :root {
        --brand-blue: #00698f;
        --brand-dark: #004d69;
        --light-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    body { background-color: var(--light-bg); font-family: 'Inter', 'Segoe UI', sans-serif; }

    /* Executive Header */
    .report-header {
        background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-dark) 100%);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    /* KPI Stat Cards */
    .stat-card {
        background: white; border-radius: 12px; padding: 18px;
        border: 1px solid var(--border-color); box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        display: flex; flex-direction: column; transition: transform 0.2s ease;
        height: 100%;
    }
    .stat-card:hover { transform: translateY(-3px); }
    .stat-label { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: #64748b; letter-spacing: 0.5px; margin-bottom: 5px; }
    .stat-value { font-size: 1.4rem; font-weight: 800; color: var(--brand-blue); }

    /* UI Containers */
    .custom-card {
        background: white; border-radius: 12px; border: 1px solid var(--border-color);
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); overflow: hidden; margin-bottom: 2rem;
    }

    .form-label-pill {
        font-weight: 700; font-size: 0.65rem; color: #ffffff !important;
        text-transform: uppercase; background-color: var(--brand-blue);
        padding: 2px 10px; border-radius: 4px; display: inline-block; margin-bottom: 5px;
    }

    /* Table Styles */
    .table-container { max-height: 600px; overflow-y: auto; }
    .table thead th {
        position: sticky; top: 0; background: #f1f5f9; color: var(--brand-blue);
        font-weight: 800; font-size: 0.7rem; text-transform: uppercase;
        border: none; padding: 12px 10px; z-index: 10;
    }
    .table tbody td { vertical-align: middle; font-size: 0.82rem; padding: 12px 10px; border-bottom: 1px solid #f1f5f9; }

    .id-pill { font-weight: 700; font-size: 0.65rem; color: #ffffff; background-color: var(--brand-blue); padding: 2px 8px; border-radius: 4px; display: inline-block; }
    .action-badge { font-size: 0.65rem; font-weight: 800; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; border: 1px solid #e2e8f0; }
    .bg-no-action { background-color: #f0fdf4; color: #166534; border-color: #bbf7d0; }

    .total-row { background-color: #f1f5f9 !important; font-weight: 800; color: var(--brand-blue); }

    .animate-up { animation: fadeInUp 0.5s ease forwards; opacity: 0; }
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container-fluid px-4 py-4 animate-up">
    <!-- Header -->
    <div class="report-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0 fw-bold"><i class="fas fa-microchip mr-3"></i> Part Traceability Hub</h2>
            <small class="text-white-50">Audit material consumption across various production BOMs for a specific component.</small>
        </div>
        <div class="text-end">
            <button class="btn btn-success btn-sm rounded-pill px-4 fw-bold shadow-sm" onclick="exportToExcel()">
                <i class="fas fa-file-excel me-2"></i> Export Trace Log
            </button>
        </div>
    </div>

    <!-- 1. Search Box -->
    <div class="custom-card shadow-sm mb-4">
        <div class="card-body p-4 bg-light">
            <div class="row justify-content-center">
                <div class="col-md-5">
                    <div class="text-center mb-2">
                        <label class="form-label-pill">Target Part Identity</label>
                    </div>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white"><i class="fas fa-barcode text-muted"></i></span>
                        <input type="text" id="itemcode" class="form-control form-control-lg fw-bold border-primary" placeholder="Enter Part Code & Press Enter..." autocomplete="off" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Dashboards KPIs (Visible after search) -->
    <div class="row g-4 mb-4" id="kpi-row" style="display:none;">
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 5px solid var(--brand-blue);">
                <span class="stat-label">Total Volume Issued</span>
                <span class="stat-value" id="kpi-total-qty">0.00</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 5px solid #6366f1;">
                <span class="stat-label">Unique BOM Vouchers</span>
                <span class="stat-value" id="kpi-bom-count" style="color:#6366f1">0</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card" style="border-left: 5px solid #10b981;">
                <span class="stat-label">Inventory Impact</span>
                <span class="stat-value text-success">Verified Consumption</span>
            </div>
        </div>
    </div>

    <!-- 3. Main Data Grid -->
    <div class="custom-card shadow-lg">
        <div class="p-3 border-bottom bg-white d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary uppercase small"><i class="fas fa-list-ul me-2"></i>Component Issuance History</h6>
            <div id="itemDescHeader" class="fw-bold text-dark small"></div>
        </div>
        <div class="table-container">
            <table id="ItemDetail" class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">BOM Ref.</th>
                        <th>Part Identity</th>
                        <th>Item Description</th>
                        <th class="text-center">UOM</th>
                        <th class="text-center">Requested</th>
                        <th class="text-center">Issued Qty</th>
                        <th class="text-center">Auth Date</th>
                        <th>Authorized By</th>
                        <th class="text-center">Lifecycle</th>
                    </tr>
                </thead>
                <tbody id="itemdetaillines">
                    <tr>
                        <td colspan="9" class="text-center py-5 text-muted italic">
                            Enter an Item Code above to generate the technical trace report.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Global Wait Sign -->
<img id="wait-sign" src="~/images/wait.gif" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10005; width: 80px;" />

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
    $(document).ready(function () {
        $("#itemcode").on("keydown", function (event) {
            if (event.key === "Enter" || event.key === "Tab") {
                var itemCode = $(this).val().trim();
                if (!itemCode) return;

                $('#wait-sign').show();
                $.ajax({
                    url: '@Url.Action("BomDetailsReport", "StockReport")',
                    type: 'GET',
                    data: { itemCode: itemCode },
                    dataType: 'json',
                    success: function (response) {
                        $('#wait-sign').hide();
                        var tableBody = $("#itemdetaillines");
                        tableBody.empty();

                        if (response.success && response.data && response.data.length > 0) {
                            $('#kpi-row').fadeIn();
                            toastr.success('Technical logs retrieved.');

                            let sumApprovedQuantity = 0;
                            let uniqueBOMs = new Set();

                            // Set Item Description in Header
                            $('#itemDescHeader').text(response.data[0].ItemName);

                            $.each(response.data, function (index, item) {
                                var formattedDate = item.ApprovedOn ? moment(parseInt(item.ApprovedOn.substr(6))).format('DD/MM/YYYY') : '---';
                                uniqueBOMs.add(item.BOMNumber);

                                var actionClass = item.Action === "No Action" ? "bg-no-action" : "";

                                var row = `<tr>
                                    <td class="text-center"><span class="id-pill shadow-sm">${item.BOMNumber}</span></td>
                                    <td class="font-monospace fw-bold text-primary small">${item.ItemCode}</td>
                                    <td class="fw-bold text-dark">${item.ItemName}</td>
                                    <td class="text-center small fw-bold">${item.UOM}</td>
                                    <td class="text-center text-muted">${parseFloat(item.RequiredQuantity || 0).toFixed(2)}</td>
                                    <td class="text-center fw-bold text-primary">${parseFloat(item.ApprovedQuantity || 0).toFixed(2)}</td>
                                    <td class="text-center text-muted small">${formattedDate}</td>
                                    <td class="small fw-bold">${item.ApprovedBy || 'System'}</td>
                                    <td class="text-center">
                                        <span class="action-badge ${actionClass}">${item.Action}</span>
                                    </td>
                                </tr>`;
                                tableBody.append(row);

                                if (item.Action === "No Action") {
                                    sumApprovedQuantity += parseFloat(item.ApprovedQuantity || 0);
                                }
                            });

                            // Dashboard Update
                            $('#kpi-total-qty').text(sumApprovedQuantity.toLocaleString(undefined, {minimumFractionDigits: 2}));
                            $('#kpi-bom-count').text(uniqueBOMs.size);

                            // Footer Row
                            var footerRow = `<tr class="total-row">
                                <td colspan="5" class="text-end py-3">AGGREGATE VOLUME (No Action Items):</td>
                                <td class="text-center py-3 fs-6">${sumApprovedQuantity.toFixed(2)}</td>
                                <td colspan="3"></td>
                            </tr>`;
                            tableBody.append(footerRow);

                        } else {
                            $('#kpi-row').fadeOut();
                            $('#itemDescHeader').text('');
                            tableBody.append('<tr><td colspan="9" class="text-center py-5 text-muted italic"><i class="fas fa-info-circle me-2"></i>No consumption identified for this Part Code.</td></tr>');
                            toastr.info('Trace query returned zero results.');
                        }
                    },
                    error: function (error) {
                        $('#wait-sign').hide();
                        toastr.error("Server communication error.");
                    }
                });
            }
        });
    });

    function exportToExcel() {
        var table = document.getElementById("ItemDetail");
        var wb = XLSX.utils.table_to_book(table, { raw: true });
        var partCode = $('#itemcode').val() || 'Unspecified';
        XLSX.writeFile(wb, 'Part_Traceability_' + partCode + '_' + moment().format('DDMMYYYY') + '.xlsx');
    }
</script>
@using System.Globalization
@{
    ViewBag.Title = "SaleReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            // Check if the current context is inside a Bootstrap modal
            const isInModal = !!(document.querySelector('.modal.show'));

            if (isInModal) {
                // If inside a modal, wait for a short delay
                setTimeout(() => {
                    handleInvalidUser();
                }, 500); // Adjust the delay as needed
            } else {
                // If not in a modal, proceed immediately
                handleInvalidUser();
            }

            function handleInvalidUser() {
                toastr.error("Invalid User");

                setTimeout(function () {
                    window.location.href = "@Url.Action("Index", "Login")";
                }, 2000); // Redirect after 2 seconds
            }
        });
    </script>
    <div style="height: 100vh; width: 100vw; background-color: #fff;"></div>
}

<style>
    /* Custom CSS for the Generate Report button */
    .btn-generate-report {
        background-color: #00698f; /* Your desired background color */
        color: #ffffff; /* Your desired text color */
        border-color: #00698f; /* Optional: make border match background */
    }

        .btn-generate-report:hover {
            background-color: #005a7a; /* Slightly darker on hover */
            border-color: #005a7a;
        }
</style>

<h3 style="background-color: #00698f; color: #ffffff; padding: 5px 10px; border-radius: 5px; text-align: center; margin-top: 20px;">Sale Report</h3>

<div class="container mt-4">
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <div class="card p-3 shadow-sm bg-light">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="fromdate" class="form-label">From Date</label>
                        <input type="date" id="fromdate" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-4">
                        <label for="todate" class="form-label">To Date</label>
                        <input type="date" id="todate" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="button" id="generate" class="btn btn-sm flex-fill btn-generate-report">Generate Report</button>
                        <button type="button" class="btn btn-success btn-sm flex-fill" onclick="exportToExcel()" style="display:none;">Export to Excel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Sales Report Table -->
<div class="table-responsive mt-5">
    <h4 class="text-primary text-center">Sales Report</h4>
    <table id="salereport" class="table table-sm table-bordered table-hover">
        <thead>
            <tr>
                <th>Invoice No</th>
                <th>Invoice Date</th>
                <th>Customer Name</th>
                <th>Billing Address</th>
                <th>Shipping Address</th>
                <th>GST No</th>
                <th>Genset Rating</th>
                <th>Engine Model</th>
                <th>Engine Sr No</th>
                <th>Alternator No</th>
                <th>KRM</th>
                <th>DG Qty</th>
                <th>Battery Rating</th>
                <th>Battery Serial</th>
                <th>Battery Qty</th>
                <th>Panel Serial</th>
                <th>Control Panel</th>
                <th>Basic Price</th>
                <th>Frieght</th>
                <th>IGST Amount</th>
                <th>CGST</th>
                <th>SGST</th>
                <th>Grand Total</th>
                <th>Transport</th>
                <th>Vehicle Number</th>
            </tr>
        </thead>
        <tbody id="salelines">
            <tr>
                <td colspan="24" class="text-center py-4">Select date range and click 'Generate Report'</td>
            </tr>
        </tbody>
        <tfoot class="table-light fw-bold">
            <tr>
                <td colspan="11" class="text-end">Total Sale Quantity:</td>
                <td id="totalsalequantity" class="text-end"></td>
                <td colspan="5" class="text-end">Total:</td>
                <td id="totalBasicPrice" class="text-end"></td>
                <td id="totalFrieght" class="text-end"></td>
                <td id="totalTaxAmount" class="text-end"></td>
                <td id="CGST" class="text-end"></td>
                <td id="SGST" class="text-end"></td>
                <td id="totalGrandTotal" class="text-end"></td>
                <td colspan="2"></td>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Sale Return Report Table -->
<div class="table-responsive mt-5">
    <h4 class="text-danger text-center">Sale Return Report</h4>
    <table id="salereturnreport" class="table table-sm table-bordered table-hover">
        <thead>
            <tr>
                <th>Return Voucher No</th>
                <th>Return Date</th>
                <th>Invoice No</th>
                <th>Invoice Date</th>
                <th>Customer Name</th>
                <th>Billing Address</th>
                <th>Shipping Address</th>
                <th>GST No</th>
                <th>Genset Rating</th>
                <th>Engine Model</th>
                <th>Engine Serial No</th>
                <th>Alternator No</th>
                <th>KRM No</th>
                <th>Quantity</th>
                <th>Battery Rating</th>
                <th>Battery Serial</th>
                <th>Battery Qty</th>
                <th>Panel Serial</th>
                <th>Control Panel</th>
                <th>Problem</th>
                <th>Basic Price</th>
                <th>Frieght</th>
                <th>IGST Amount</th>
                <th>CGST</th>
                <th>SGST</th>
                <th>Grand Total</th>
                <th>Return BOM No</th>
                <th>New BOM No</th>
            </tr>
        </thead>
        <tbody id="salereturnlines">
            <tr>
                <td colspan="27" class="text-center py-4">No data found for the selected date range.</td>
            </tr>
        </tbody>
        <tfoot class="table-light fw-bold">
            <tr>
                <td colspan="13" class="text-end">Total Return Quantity:</td>
                <td id="totalsalereturnquantity" class="text-end"></td>
                <td colspan="6" class="text-end">Total:</td>
                <td id="totalReturnBasicPrice" class="text-end"></td>
                <td id="totalReturnFrieght" class="text-end"></td>
                <td id="totalReturnTaxAmount" class="text-end"></td>
                <td id="CGST" class="text-end"></td>
                <td id="SGST" class="text-end"></td>
                <td id="totalReturnGrandTotal" class="text-end"></td>
                <td colspan="2"></td>
            </tr>
        </tfoot>
    </table>
</div>
<div id="reportErrorMessage" class="text-danger mt-3 text-center"></div>

@*<!-- Add Moment.js CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <!-- Add jQuery and Bootstrap scripts to ensure they are loaded before your custom script -->
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>*@

<!-- Your existing scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
    function exportToExcel() {
        var salesTable = document.getElementById("salereport");
        var returnsTable = document.getElementById("salereturnreport");

        // Create and download the Sales Report Excel file
        var salesWb = XLSX.utils.table_to_book(salesTable, { raw: true });
        XLSX.writeFile(salesWb, 'Sales_Report.xlsx');

        // Create and download the Sale Return Report Excel file
        var returnsWb = XLSX.utils.table_to_book(returnsTable, { raw: true });
        XLSX.writeFile(returnsWb, 'Sale_Return_Report.xlsx');
    }

    $(document).ready(function () {
        $('#generate').click(function () {
            const fromdt = $('#fromdate').val();
            const to = $('#todate').val();

            if (!fromdt || !to) {
                toastr.warning('Please select both From Date and To Date.');
                return;
            }

            // Show loading messages
            $('#salelines').empty().append('<tr><td colspan="24" class="text-center py-4">Loading sales data...</td></tr>');
            $('#salereturnlines').empty().append('<tr><td colspan="27" class="text-center py-4">Loading sales return data...</td></tr>');

            $('#reportErrorMessage').empty();
            $('button[onclick="exportToExcel()"]').hide();

            // Clear footer totals
            $('#salereport tfoot').find('td').not(':first').text('');
            $('#salereturnreport tfoot').find('td').not(':first').text('');


            $.ajax({
                url: '@Url.Action("SaleReportData", "Reports")',
                type: 'GET',
                data: { fromdt: fromdt, to: to },
                success: function (response) {
                    // Clear previous data
                    $('#salelines').empty();
                    $('#salereturnlines').empty();

                    let totalBasicPrice = 0;
                    let totalFrieght = 0;
                    let totalTaxAmount = 0;
                    let CGST = 0;
                    let SGST = 0;
                    let totalGrandTotal = 0;
                    let totalsalequantity = 0;


                    let totalReturnBasicPrice = 0;
                    let totalReturnFrieght = 0;
                    let totalReturnTaxAmount = 0;
                    let ReturnCGST = 0;
                    let ReturnSGST = 0;
                    let totalReturnGrandTotal = 0;
                    let totalsalereturnquantity = 0;

                    // Populate Sales Table
                    if (response.sale && response.sale.length > 0) {
                        $.each(response.sale, function (index, item) {
                            const Billdt = item.Billdt ? moment(item.Billdt).format('DD/MM/YYYY') : 'N/A';
                            const BasicPrice = item.BasicPrice != null ? parseFloat(item.BasicPrice).toFixed(2) : '0.00';
                            const Frieght = item.Frieght != null ? parseFloat(item.Frieght).toFixed(2) : '0.00';
                            const TaxAmount = item.TaxAmount != null ? parseFloat(item.TaxAmount).toFixed(2) : '0.00';
                            const CGSTA = item.CGST != null ? parseFloat(item.CGST).toFixed(2) : '0.00';
                            const SGSTA= item.SGST != null ? parseFloat(item.SGST).toFixed(2) : '0.00';
                            const Total = item.Total != null ? parseFloat(item.Total).toFixed(2) : '0.00';

                            totalBasicPrice += parseFloat(item.BasicPrice || 0);
                            totalFrieght += parseFloat(item.Frieght || 0);
                            totalTaxAmount += parseFloat(item.TaxAmount || 0);
                            CGST += parseFloat(item.CGST || 0);
                            SGST += parseFloat(item.SGST || 0);
                            totalGrandTotal += parseFloat(item.Total || 0);
                            totalsalequantity += parseFloat(item.Quantity || 0);

                            const row = '<tr>' +
                                '<td>' + (item.Billno || 'N/A') + '</td>' +
                                '<td>' + Billdt + '</td>' +
                                '<td>' + (item.CustomerName || 'N/A') + '</td>' +
                                '<td>' + (item.Billing || 'N/A') + '</td>' +
                                '<td>' + (item.Shipping || 'N/A') + '</td>' +
                                '<td>' + (item.CustomerGST || 'N/A') + '</td>' +
                                '<td>' + (item.Rating || 'N/A') + '</td>' +
                                '<td>' + (item.Emodel || 'N/A') + '</td>' +
                                '<td>' + (item.ESerial || 'N/A') + '</td>' +
                                '<td>' + (item.AlternatorSerial || 'N/A') + '</td>' +
                                '<td>' + (item.KRM || 'N/A') + '</td>' +
                                '<td>' + (item.Quantity || 'N/A') + '</td>' +
                                '<td>' + (item.BRating || 'N/A') + '</td>' +
                                '<td>' + (item.BSerial || 'N/A') + '</td>' +
                                '<td>' + (item.BatteryQty || 'N/A') + '</td>' + 
                                '<td>' + (item.PSerial || 'N/A') + '</td>' +
                                '<td>' + (item.ControlPanel || 'N/A') + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + (item.Transport || 'N/A') + '</td>' +
                                '<td>' + (item.VehicleNumber || 'N/A') + '</td>' +
                                '</tr>';
                            $('#salelines').append(row);
                        });

                        // Update sales footer totals
                        $('#totalBasicPrice').text("NA");
                        $('#totalFrieght').text("NA");
                        $('#totalTaxAmount').text("NA");
                        $('#CGST').text("NA");
                        $('#SGST').text("NA");
                        $('#totalGrandTotal').text("NA");
                        $('#totalsalequantity').text("NA");

                    } else {
                        $('#salelines').append('<tr><td colspan="22" class="text-center py-4">No sales data found for the selected date range.</td></tr>');
                    }
                    debugger;
                    // Populate Sale Return Table
                    if (response.returnData && response.returnData.length > 0) {
                        $.each(response.returnData, function (index, item) {
                            const returnDate = item.ReturnDate ? moment(item.ReturnDate).format('DD/MM/YYYY') : 'N/A';
                            const InvoiceDateC = item.InvoiceDate ? moment(item.InvoiceDate).format('DD/MM/YYYY') : 'N/A';
                            const BasicPrice = item.BasicPrice != null ? parseFloat(item.BasicPrice).toFixed(2) : '0.00';
                            const Frieght = item.Frieght != null ? parseFloat(item.Frieght).toFixed(2) : '0.00';
                            const TaxAmount = item.TaxAmount != null ? parseFloat(item.TaxAmount).toFixed(2) : '0.00';
                            const Total = item.Total != null ? parseFloat(item.Total).toFixed(2) : '0.00';
                            const CGSTA = item.CGST != null ? parseFloat(item.CGST).toFixed(2) : '0.00';
                            const SGSTA = item.SGST != null ? parseFloat(item.SGST).toFixed(2) : '0.00';


                            totalReturnBasicPrice += parseFloat(item.BasicPrice || 0);
                            totalReturnFrieght += parseFloat(item.Frieght || 0);
                            totalReturnTaxAmount += parseFloat(item.TaxAmount || 0);
                            ReturnCGST += parseFloat(item.CGST || 0);
                            ReturnSGST += parseFloat(item.SGST || 0);
                            totalReturnGrandTotal += parseFloat(item.Total || 0);
                            totalsalereturnquantity += parseFloat(item.Quantity || 0);

                            const row = '<tr>' +
                                '<td>' + (item.ReturnVoucher || 'N/A') + '</td>' +
                                '<td>' + returnDate + '</td>' +
                                '<td>' + (item.InvoiceNo || 'N/A') + '</td>' +
                                '<td>' + (InvoiceDateC || 'N/A') + '</td>' +
                                '<td>' + (item.CustomerName || 'N/A') + '</td>' +
                                '<td>' + (item.Billing || 'N/A') + '</td>' +
                                '<td>' + (item.Shipping || 'N/A') + '</td>' +
                                '<td>' + (item.CustomerGST || 'N/A') + '</td>' +
                                '<td>' + (item.Rating || 'N/A') + '</td>' +
                                '<td>' + (item.Emodel || 'N/A') + '</td>' +
                                '<td>' + (item.ESerial || 'N/A') + '</td>' +
                                '<td>' + (item.AlternatorSerial || 'N/A') + '</td>' +
                                '<td>' + (item.KRM || 'N/A') + '</td>' +
                                '<td>' + (item.Quantity || 'N/A') + '</td>' +
                                '<td>' + (item.BRating || 'N/A') + '</td>' +
                                '<td>' + (item.BSerial || 'N/A') + '</td>' +
                                '<td>' + (item.BatteryQty || 'N/A') + '</td>' +
                                '<td>' + (item.PSerial || 'N/A') + '</td>' +
                                '<td>' + (item.ControlPanel || 'N/A') + '</td>' +
                                '<td>' + (item.Problem || 'N/A') + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + "NA" + '</td>' +
                                '<td>' + (item.DispatchReturnBOM || 'N/A') + '</td>' +
                                '<td>' + (item.NewBOM || 'N/A') + '</td>' +
                                '</tr>';
                            $('#salereturnlines').append(row);
                        });

                        // Update sales return footer totals
                        $('#totalReturnBasicPrice').text("NA");
                        $('#totalReturnFrieght').text("NA");
                        $('#totalReturnTaxAmount').text("NA");
                        $('#ReturnCGST').text("NA");
                        $('#ReturnSGST').text("NA");
                        
                        $('#totalReturnGrandTotal').text("NA");
                        $('#totalsalereturnquantity').text("NA");
                    } else {
                        $('#salereturnlines').append('<tr><td colspan="27" class="text-center py-4">No sales return data found for the selected date range.</td></tr>');
                    }

                    // Show export button if there's any data
                    if (response.sale.length > 0 || response.returns.length > 0) {
                        $('button[onclick="exportToExcel()"]').show();
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    console.error("Error fetching Sale Report data:", textStatus, errorThrown, jqXHR.responseText);
                    toastr.error("Error fetching report data.");
                    $('#reportErrorMessage').html('Error loading report data. Please check the console.');
                    $('#salelines').empty().append('<tr><td colspan="22" class="text-center py-4 text-danger">Error loading data.</td></tr>');
                    $('#salereturnlines').empty().append('<tr><td colspan="11" class="text-center py-4 text-danger">Error loading data.</td></tr>');
                }
            });
        });
    });
</script>

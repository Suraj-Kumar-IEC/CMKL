@model IEnumerable<CMKL.Models.PaymentViewCompany>

@{
    ViewBag.Title = "LogisticView";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
@*<script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <script src="~/Scripts/bootstrap.min.js"></script>*@


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        window.onload = function () {
            toastr.success("@TempData["message"]")

        }
    </script>

}

<h2 style="text-align:center">Logistic View</h2>


<table class="table table-striped table-dark">
    <tr align="center" style="text-align:center">
        <th style="text-align:center;">
            @Html.DisplayName("OA Number")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("Supplier / Dealer")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("Customer Name")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("End Customer Price With GST")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("Branch Payment To Dealer")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("Dealer Payment To OEM")
        </th>
        <th style="text-align:center;">
            @Html.DisplayName("Pending Amount To OEM")
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr align="center">
            <td>
                @Html.DisplayFor(modelItem => item.OrderId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.supplier_dealer)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CustomerName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndCusOrderPricewithGST)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AmountToDealer)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TotalAmount)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.BalanceAmount)
            </td>

            <td>
                @*<div>
                <button type="button" class="btn btn-success edit" data-toggle="modal" data-target="#EditRecord" data-id="@item.OrderId">Update Payment</button>
            </div>
                *@
                <div>
                    @Html.ActionLink("View Branch Payments", "paymentdetaildealer", new { id = item.OrderId }, new { @class = "btn btn-primary" })
                </div>

                @Html.ActionLink("View Dealer Payemnts", "paymentdetailtransfer", new { id = item.OrderId }, new { @class = "btn btn-info" })
            </td>

        </tr>
    }


</table>

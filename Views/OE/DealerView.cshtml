@model  IEnumerable<CMKL.Models.Authorizeddealerview>

@{
    ViewBag.Title = "Dealer View Page";
    // Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />
@*<script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <script src="~/Scripts/bootstrap.min.js"></script>*@


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        window.onload = function () {
            toastr.success("@TempData["message"]")

        }
    </script>

}

<h3 style="text-align:center">Dealer Payment Update Page</h3>


@*<p>
        @Html.ActionLink("Create New", "Create")
    </p>
*@

<div class="container">
    <table class="table table-striped table-dark">

        <tr>
            <th>
                @Html.DisplayName("OA Number")

            </th>
            <th>
                @Html.DisplayName("Branch")

            </th>
            <th>
                @Html.DisplayName("Dealer Name")

            </th>
            <th>
                @Html.DisplayName("Dealer Incentive")

            </th>
            <th>
                @Html.DisplayName("Engine Model")

            </th>
            <th>
                @Html.DisplayName("Engine Rating")

            </th>
            <th>
                @Html.DisplayName("Phase")

            </th>

        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.OrderId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BranchOffice)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.supplier_dealer)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Billingincentive)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EngineModel)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RatingDesc)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PhaseDesc)
                </td>

                <td>
                    @* @Html.ActionLink("Stock Take IN (Quality)", "Qualityindetail", new { ids = item.id }) *@
                    <div>
                        <button type="button" class="btn btn-success edit" data-toggle="modal" data-target="#EditRecord" data-id="@item.OrderId">Update Payment</button>
                    </div>
                    <div>
                        @Html.ActionLink("View Branch Payments", "paymentdetaildealer", new { id = item.OrderId }, new { @class = "btn btn-primary" })
                    </div>
                    
                        @Html.ActionLink("View Payments transfered", "paymentdetailtransfer", new { id = item.OrderId }, new { @class = "btn btn-info" })
                    


                </td>

            </tr>
        }
    </table>
</div>


<div class="modal fade" tabindex="-1" role="dialog" id="EditRecord">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" style="text-align:center">Update Payment</h3>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="myform" method="post" asp-controller="Home" asp-action="EditRecord">
                <div class="modal-body">
                    <div class="col-sm-6" style="display:none;">
                        <label>OA Number:</label>
                        <input type="text" class="form-control" name="OA Number" id="id" required readonly />
                    </div>

                    <div class="col-sm-6">
                        <label>Customer Name:</label>
                        <input type="text" class="form-control" name="Customer Name" id="customername" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Engine:</label>
                        <input type="text" class="form-control" name="Engine" id="engine" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Rating:</label>
                        <input type="text" class="form-control" name="Rating" id="rating" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Basic Price Billing to KD:</label>
                        <input type="text" class="form-control" name="Basic Price KD" id="basicpricekd" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Dealer Incentive Amount:</label>
                        <input type="text" class="form-control" name="Incentive Amount" id="incentive" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>End Customer Order Price Basic:</label>
                        <input type="text" class="form-control" name="End Customer Order Price Basic" id="orderprice" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Payment To GOEM by Dealer:</label>
                        <input type="text" class="form-control" name="Total Billing Amount" id="KDtotalamount" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>End Customer Order Price with GST:</label>
                        <input type="text" class="form-control" name="End Customer Order Price with GST" id="endcustomerorderpricegst" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Total Amount Recieved Till Date:</label>
                        <input type="text" class="form-control" name="Total Amount Recieved" id="totalamounttilldt" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Company:</label>
                        <select class="form-control" id="company">
                            <option id="1">Green Field Enterprises Kathua</option>
                            <option id="2">Industrial Equipments Company Barwala</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label>Payment Transfer Date:</label>
                        <input type="text" class="form-control" name="Date" id="paymentdt" required />
                    </div>
                    <div class="col-sm-6">
                        <label>Amount to Be Transfered:</label>
                        <input type="text" class="form-control" name="Amount Recieved" id="amountrecieved" required />
                    </div>
                    <div class="col-sm-6">
                        <label>Mode Of Payment:</label>
                        <select class="form-control" id="paymentmode">
                            <option id="1">Cash</option>
                            <option id="2">RTGS</option>
                            <option id="3">Cheque</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label>Ref No/Cheque/RTGS:</label>
                        <input type="text" class="form-control" name="Amount Recieved" id="refno" required />
                    </div>
                    <div class="col-sm-6">
                        <label>Balance Amount From Branch:</label>
                        <input type="text" class="form-control" name="Balance Amount" id="Balance" required readonly />
                    </div>
                    <div class="col-sm-6">
                        <label>Pending Amount For Transfer:</label>
                        <input type="text" class="form-control" name="Balance Amount" id="pendingamounttransfer" required readonly />
                    </div>



                </div>



                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" style="text-align:right" data-dismiss="modal">Cancel</button>
                    @*<button type="submit" id="update" class="btn btn-primary">Save changes</button>*@
                    <p><button type="button" id="add" class="btn btn-success">Update Data</button></p>

                </div>
            </form>

        </div>
    </div>
</div>


<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/jquery-ui-1.12.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
<link href="~/toastr/toastr.css" rel="stylesheet" />



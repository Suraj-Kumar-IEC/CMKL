<script>

         @{var dt = DateTime.Now.ToString("dd/MM/yyyy"); }
        $.noConflict();
        jQuery(document).ready(function ($) {
            $(function () {
                $('#paymentdt').datepicker({
                    dateFormat: 'dd/mm/yy',


                });
                @*$('#paymentdt').datepicker('setDate','today')*@

            });

        });
    </script>

<script>


        $(document).ready(function () {
            $('table .edit').on('click', function () {
                var id = $(this).data("id");

                $.ajax({
                    type: 'POST',
                    url: 'GetDealer/?id="+id;',
                    data: { "id": id },
                    success: function (response) {
                        $('#EditRecord #id').val(response.id);
                        $('#EditRecord #customername').val(response.customername);
                        $('#EditRecord #engine').val(response.engine);
                        $('#EditRecord #rating').val(response.rating);
                        $('#EditRecord #incentive').val(response.incentive);
                        $('#EditRecord #basicpricekd').val(response.basicpricekd);
                        $('#EditRecord #advance').val(response.advance);
                        $('#EditRecord #orderprice').val(response.endcustomerorderprice);
                        $('#EditRecord #KDtotalamount').val(response.KDtotalamounttogoem);
                        $('#EditRecord #totalamounttilldt').val(response.totalamounttilldt);
                        $('#EditRecord #endcustomerorderpricegst').val(response.endcustomerorderpricewithGST);
                        $('#EditRecord #Balance').val(response.balanceamount);
                        $('#EditRecord #pendingamounttransfer').val(response.pendingamounttransfer);


                    }
                })
            });

            $('table .delete').on('click', function () {
                var id = $(this).data("id");

                $.ajax({
                    type: 'POST',
                    url: 'Home/FindRecord/',
                    data: { "cusid": id },
                    success: function (response) {
                        $('#DeleteRecord #id').val(response.id);
                        $('#DeleteRecord #name').val(response.name);
                        $('#DeleteRecord #email').val(response.email);
                        $('#DeleteRecord #phone').val(response.phone);
                    }
                })
            });
        });

        $(document).ready(function () {

            $("#add").click(function () {
                var data = $("#myForm").serialize();
                var formData = new FormData();
               // var totalFiles = document.getElementById("qualityupload").files.length;
              //  for (var i = 0; i < totalFiles; i++) {
               //     var file = document.getElementById("qualityupload").files[i];
               //     formData.append("qualityupload", file);
               // }
                formData.append("fid", $("#id").val());
                formData.append("fpm", $("#paymentmode").val());
                formData.append("fpr", $("#amountrecieved").val());
                formData.append("fdt", $("#paymentdt").val());
                formData.append("frn", $("#refno").val());
                formData.append("fcp", $("#company").val());
                //formData.append("fremarks", $("#qremarks").val());



                $.ajax({
                    type: "POST",
                    url: "/OE/updatepaymentdealer",
                    data: formData,
                    contentType: false,
                    processData: false,

                    success: function (response) {
                        if (response.success == true) {

                            toastr.success(response.message);
                            window.location.href = '/OE/DealerView';
                            $('#EditRecord').modal('hide');


                        }
                        else {
                            toastr.error(response.message);
                        }


                    },
                    error: function () {
                        toastr.error('There is Somthing Wrong');

                    }


                });
            });
        })

        $('#quality').change(function () {

            var selectedValue = $("#quality").val();
            debugger;
            $.ajax({
                url: '@Url.Action("dropdownquality", "Inventory")',
                //url: '/Controller/dropdown',
                type: 'GET',
                dataType: 'json',
                data: { selectedValue: selectedValue },
                success: function (data) {
                    $('#rejectionreason').empty();
                    var s = '<option value="-1">Select</option>';
                    for (var i = 0; i < data.length; i++) {
                        s += '<option value="' + data[i] + '">' + data[i] + '</option>';
                    }
                    $("#rejectionreason").html(s);

                }
            });
        });
</script>

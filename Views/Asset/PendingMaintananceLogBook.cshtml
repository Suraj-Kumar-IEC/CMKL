@{
    ViewBag.Title = "Maintenance Log Book (Pending)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            const isInModal = !!(document.querySelector('.modal.show'));
            const handleInvalidUser = () => {
                toastr.error("Session Expired. Please Login.");
                setTimeout(() => { window.location.href = "@Url.Action("Index", "Login")"; }, 2000);
            };
            setTimeout(handleInvalidUser, isInModal ? 500 : 0);
        });
    </script>
    <div class="vh-100 vw-100 bg-white"></div>
}

<link href="~/toastr/toastr.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<style>
    :root {
        --brand-blue: #00698f;
        --brand-dark: #004d69;
        --light-bg: #f8fafc;
        --border-color: #e2e8f0;
    }

    body {
        background-color: var(--light-bg);
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    /* Page Header with Gradient */
    .report-header {
        background: linear-gradient(135deg, var(--brand-blue) 0%, var(--brand-dark) 100%);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    /* Dashboard KPI Tiles */
    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 18px;
        border: 1px solid var(--border-color);
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--brand-blue);
        }

    .stat-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #64748b;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--brand-blue);
    }

    /* Main Table Container */
    .custom-card {
        background: white;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .card-header-custom {
        background: #fff;
        padding: 15px 20px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-title-line {
        font-weight: 700;
        color: var(--brand-blue);
        text-transform: uppercase;
        font-size: 0.85rem;
        margin: 0;
    }

    /* Quick Search Bar */
    .search-wrapper {
        position: relative;
        width: 350px;
    }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

    .search-input {
        border-radius: 25px !important;
        padding-left: 40px !important;
        background: #f8fafc !important;
        border: 1.5px solid var(--border-color) !important;
        height: 38px !important;
        font-size: 0.85rem;
    }

    /* Table Enhancements */
    .table thead th {
        background: #f1f5f9;
        color: var(--brand-blue);
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        border: none;
        padding: 12px 15px;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .table tbody td {
        vertical-align: middle;
        font-size: 0.8rem;
        padding: 12px 15px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Action Buttons */
    .btn-complete {
        background-color: #198754;
        color: white;
        font-weight: 700;
        border: none;
        border-radius: 6px;
        padding: 6px 15px;
        font-size: 0.7rem;
        transition: 0.2s;
        text-transform: uppercase;
    }

        .btn-complete:hover {
            background-color: #157347;
            transform: translateY(-1px);
            color: white;
        }

    .btn-items {
        background-color: #f1f5f9;
        color: #475569;
        font-weight: 700;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 6px 15px;
        font-size: 0.7rem;
        text-transform: uppercase;
    }

        .btn-items:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .machine-identity {
        font-weight: 700;
        color: #1e293b;
        display: block;
    }

    .task-badge {
        font-size: 0.65rem;
        background: #e0f2fe;
        color: #0369a1;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 800;
    }

    .due-pill {
        font-size: 0.7rem;
        padding: 2px 10px;
        border-radius: 20px;
        font-weight: 700;
    }

    .overdue {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .on-time {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    /* Modal Styling */
    .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }

    .modal-header {
        background: var(--brand-blue);
        color: white;
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
        border: none;
    }

    .modal-title {
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .form-label-pill {
        font-weight: 700;
        font-size: 0.65rem;
        color: #ffffff !important;
        text-transform: uppercase;
        background-color: var(--brand-blue);
        padding: 2px 10px;
        border-radius: 4px;
        display: inline-block;
        margin-bottom: 5px;
    }

    .animate-up {
        animation: fadeInUp 0.5s ease forwards;
        opacity: 0;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="report-header d-flex justify-content-between align-items-center animate-up">
        <div>
            <h2 class="mb-0 fw-bold"><i class="fas fa-tools mr-3"></i> Maintenance Work Queue</h2>
            <small class="text-white-50">Operational log of pending technical tasks awaiting technician completion</small>
        </div>
        <div class="text-end">
            <span class="badge bg-white text-primary border px-3 py-2 rounded-pill fw-bold shadow-sm">
                <i class="fas fa-sync-alt mr-2"></i> Live Feed
            </span>
        </div>
    </div>

    <!-- Dashboard KPI Tiles -->
    <div class="row g-3 mb-4 animate-up" style="animation-delay: 0.1s;">
        <div class="col-md-3">
            <div class="stat-card" style="border-left: 5px solid var(--brand-blue);">
                <span class="stat-label">Total Pending Tasks</span>
                <span class="stat-value" id="kpi-total">0</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="border-left: 5px solid #ef4444;">
                <span class="stat-label">Overdue Tasks</span>
                <span class="stat-value text-danger" id="kpi-overdue">0</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="border-left: 5px solid #f59e0b;">
                <span class="stat-label">Critical (With Items)</span>
                <span class="stat-value text-warning" id="kpi-critical">0</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="border-left: 5px solid #10b981;">
                <span class="stat-label">Avg. Lead Time</span>
                <span class="stat-value text-success">Healthy</span>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="custom-card shadow-sm animate-up" style="animation-delay: 0.2s;">
        <div class="card-header-custom">
            <h6 class="card-title-line"><i class="fas fa-clipboard-list mr-2"></i> Pending Execution List</h6>
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" id="quickSearch" class="form-control search-input" placeholder="Quick find machine, task, or owner...">
            </div>
        </div>
        <div class="table-responsive">
            <table id="pendingTasksTable" class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Asset & SubUnit</th>
                        <th>Task Identity</th>
                        <th>Frequency</th>
                        <th>Owner</th>
                        <th class="text-center">Due Date</th>
                        <th class="text-center">Action Hub</th>
                    </tr>
                </thead>
                <tbody id="tasksBody">
                    <tr><td colspan="6" class="text-center py-5 text-muted">Retrieving technical queue...</td></tr>
                </tbody>
            </table>
        </div>
        <div id="noTasksMessage" class="alert alert-info text-center m-4 shadow-sm" style="display:none;">
            <i class="fas fa-check-circle mr-2 text-success"></i> Maintenance queue is clear. No pending tasks identified.
        </div>
    </div>
</div>

<!-- Modal: Item Consumption Review -->
<div class="modal fade" id="viewItemsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header py-3">
                <h5 class="modal-title m-0"><i class="fas fa-box-open mr-2"></i> Material Consumption List</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-light border small text-muted mb-3">
                    Authorized materials required for: <b><span id="modalTaskMachineName"></span></b>
                </div>
                <div class="table-responsive rounded-lg border">
                    <table id="modalItemsTable" class="table table-sm table-striped mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="py-3 px-3">Material Name</th>
                                <th class="text-center py-3">Req. Quantity</th>
                                <th class="py-3">UOM</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Items will be loaded here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Work Completion Signature -->
<div class="modal fade" id="completeTaskModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header py-3">
                <h5 class="modal-title m-0"><i class="fas fa-check-double mr-2"></i> Log Work Completion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="completeTaskForm">
                <div class="modal-body p-4 bg-light">
                    <input type="hidden" id="completeTaskLogbookId" name="logbookId" />

                    <div class="card p-3 mb-4 border-0 shadow-sm bg-white">
                        <small class="text-muted fw-bold uppercase" style="font-size:0.6rem">Target Asset:</small>
                        <p class="m-0 fw-bold text-dark fs-5" id="modalCompleteTaskMachineName">---</p>
                    </div>

                    <div class="form-group">
                        <span class="form-label-pill">Technical Action Details</span>
                        <textarea class="form-control border-2 shadow-sm" id="completionRemarks" name="remarks" rows="4" required placeholder="Describe the maintenance action taken, parts cleaned/replaced..."></textarea>
                        <div class="invalid-feedback fw-bold">Remarks are required for technical audit trails.</div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-white justify-content-center">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="submitCompletionBtn" class="btn btn-success rounded-pill px-5 shadow fw-bold">
                        Confirm Completion
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<img id="wait-sign" src="~/images/wait.gif" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10005; width: 80px;" />
<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>
@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="~/toastr/Js/toastr.js"></script>

    <script>
        $(document).ready(function () {
            loadPendingTasks();

            // Real-time Instant Search
            $("#quickSearch").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#tasksBody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            function loadPendingTasks() {
                $('#tasksBody').html('<tr><td colspan="6" class="text-center py-5 text-muted"><i class="fas fa-sync fa-spin mr-2"></i> Initializing log queue...</td></tr>');
                $('#noTasksMessage').hide();

                $.ajax({
                    url: '@Url.Action("GetPendingTasks", "Asset")',
                    type: 'GET',
                    dataType: 'json',
                    success: function (response) {
                        var tableBody = $('#tasksBody');
                        tableBody.empty();

                        if (response.success && response.data && response.data.length > 0) {
                            let overdue = 0;
                            let critical = 0;
                            const today = moment().startOf('day');

                            $.each(response.data, function (index, task) {
                                const dueDate = moment(task.DueDate);
                                const isOverdue = dueDate.isBefore(today);
                                if (isOverdue) overdue++;
                                if (task.HasItems) critical++;

                                var statusPill = isOverdue
                                    ? `<span class="due-pill overdue"><i class="fas fa-exclamation-circle mr-1"></i> ${dueDate.format('DD/MM/YYYY')}</span>`
                                    : `<span class="due-pill on-time"><i class="fas fa-calendar-check mr-1"></i> ${dueDate.format('DD/MM/YYYY')}</span>`;

                                var itemsAction = task.HasItems ?
                                    `<button class="btn-items view-items-btn" data-id="${task.Id}"><i class="fas fa-box"></i> Items</button>` :
                                    `<span class="text-muted small italic">No Materials</span>`;

                                var row = `
                                    <tr>
                                        <td>
                                            <span class="machine-identity">${task.MachineName || 'N/A'}</span>
                                            <small class="text-muted italic">${task.SubunitName || 'General Asset'}</small>
                                        </td>
                                        <td><span class="task-badge">${task.EquipmentName || 'Standard Task'}</span></td>
                                        <td class="small text-muted">${task.FrequencyName || 'One-time'}</td>
                                        <td><div class="small fw-bold text-dark">${task.Owner || 'N/A'}</div></td>
                                        <td class="text-center">${statusPill}</td>
                                        <td class="text-center">
                                            <div class="d-flex gap-2 justify-content-center align-items-center">
                                                ${itemsAction}
                                                <button class="btn-complete complete-btn" data-id="${task.Id}" data-machinename="${task.MachineName}">
                                                    <i class="fas fa-file-signature"></i> Finalize
                                                </button>
                                            </div>
                                        </td>
                                    </tr>`;
                                tableBody.append(row);
                            });

                            $('#kpi-total').text(response.data.length);
                            $('#kpi-overdue').text(overdue);
                            $('#kpi-critical').text(critical);

                            toastr.success('Log queue synchronized.');
                        } else {
                            tableBody.append('<tr><td colspan="6" class="text-center py-5 text-muted italic">Authorization queue is clear.</td></tr>');
                            $('#noTasksMessage').show();
                            $('#kpi-total, #kpi-overdue, #kpi-critical').text('0');
                        }
                    },
                    error: function () {
                        toastr.error("Database connection failure.");
                    }
                });
            }

            // Global functions for inline events
            $('#pendingTasksTable').on('click', '.view-items-btn', function () {
                var logbookId = $(this).data('id');
                var machineName = $(this).closest('tr').find('.machine-identity').text();
                $('#modalTaskMachineName').text(machineName);

                var modalTableBody = $('#modalItemsTable tbody');
                modalTableBody.empty().html('<tr><td colspan="3" class="text-center py-4"><i class="fas fa-spinner fa-spin text-primary"></i> Accessing material logs...</td></tr>');
                $('#viewItemsModal').modal('show');

                $.ajax({
                    url: '@Url.Action("GetLogbookItems", "Asset")',
                    type: 'GET',
                    data: { logbookId: logbookId },
                    success: function (response) {
                        modalTableBody.empty();
                        if (response.success && response.data && response.data.length > 0) {
                            $.each(response.data, function (i, item) {
                                modalTableBody.append(`<tr><td class="px-3 fw-bold text-dark">${item.ItemName}</td><td class="text-center fw-bold text-primary">${item.Quantity}</td><td>${item.UOM}</td></tr>`);
                            });
                        } else {
                            modalTableBody.append('<tr><td colspan="3" class="text-center py-4 text-muted italic">No materials consumed for this log entry.</td></tr>');
                        }
                    }
                });
            });

            $('#pendingTasksTable').on('click', '.complete-btn', function () {
                $('#completeTaskLogbookId').val($(this).data('id'));
                $('#modalCompleteTaskMachineName').text($(this).data('machinename'));
                $('#completionRemarks').val('').removeClass('is-invalid');
                $('#completeTaskModal').modal('show');
            });

            $('#completeTaskForm').submit(function (e) {
                e.preventDefault();
                var logbookId = $('#completeTaskLogbookId').val();
                var remarks = $('#completionRemarks').val().trim();

                if (remarks === '') {
                    $('#completionRemarks').addClass('is-invalid');
                    return;
                }

                $('#submitCompletionBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Submitting...');
                $('#wait-sign').show();

                $.ajax({
                    url: '@Url.Action("CompleteTask", "Asset")',
                    type: 'POST',
                    data: { logbookId: logbookId, remarks: remarks },
                    success: function (response) {
                        $('#wait-sign').hide();
                        if (response.success) {
                            toastr.success(response.message);
                            $('#completeTaskModal').modal('hide');
                            loadPendingTasks();
                        } else {
                            toastr.error(response.message);
                        }
                    },
                    complete: function () {
                        $('#submitCompletionBtn').prop('disabled', false).text('Confirm Completion');
                    }
                });
            });
        });
    </script>
}
@{
    ViewBag.Title = "Task Master";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["U_Role"] == null)
{
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function () {
            const isInModal = !!(document.querySelector('.modal.show'));
            const handleInvalidUser = () => {
                toastr.error("Session Expired. Please Login.");
                setTimeout(() => { window.location.href = "@Url.Action("Index", "Login")"; }, 2000);
            };
            setTimeout(handleInvalidUser, isInModal ? 500 : 0);
        });
    </script>
    <div class="vh-100 vw-100 bg-white"></div>
}

<link href="~/toastr/toastr.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<style>
    :root {
        --primary-blue: #00698f;
        --secondary-blue: #005677;
        --light-bg: #f8f9fa;
        --card-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    body {
        background-color: var(--light-bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Dashboard Tiles */
    .stat-card {
        border: none;
        border-radius: 10px;
        transition: transform 0.2s;
        box-shadow: var(--card-shadow);
        background: #fff;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    /* Main UI Elements */
    .page-header {
        background: linear-gradient(135deg, var(--primary-blue) 0%, #004d69 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 10px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .custom-card {
        border: none;
        border-radius: 10px;
        box-shadow: var(--card-shadow);
        margin-bottom: 1.5rem;
        background: #fff;
    }

    .card-title-line {
        font-weight: 700;
        color: var(--primary-blue);
        border-bottom: 2px solid var(--primary-blue);
        padding-bottom: 10px;
        margin-bottom: 20px;
        display: inline-block;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .btn-save {
        background-color: var(--primary-blue);
        color: white;
        border: none;
        padding: 10px 30px;
        border-radius: 5px;
        font-weight: 600;
    }

        .btn-save:hover {
            background-color: var(--secondary-blue);
            color: white;
        }

    .search-container {
        position: relative;
    }

        .search-container i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }

    .search-input {
        padding-left: 40px;
        border-radius: 20px;
        border: 1px solid #dee2e6;
        font-size: 0.85rem;
    }

    .table thead th {
        background-color: #f1f4f6;
        color: #00698f;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        border-top: none;
        padding: 12px;
    }

    .table tbody td {
        vertical-align: middle;
        font-size: 0.85rem;
        padding: 12px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Fixed Subunit Badge Visibility */
    .subunit-pill {
        background-color: #f0f7f9;
        color: #00698f;
        border: 1px solid #bae6fd;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.7rem;
        display: inline-block;
    }
</style>

<div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0"><i class="fas fa-tasks mr-2"></i> Task Master</h2>
            <small class="text-white-50">Manage your equipment and machine tasks</small>
        </div>
        <div>
            <span class="badge badge-light p-2">v2.0 Professional</span>
        </div>
    </div>

    <!-- Dashboard Tiles -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-primary text-white"><i class="fas fa-microchip"></i></div>
                    <div class="ml-3">
                        <h6 class="mb-0 text-muted small uppercase fw-bold">Total Machines</h6>
                        <h4 class="mb-0 font-weight-bold" id="tileMachineCount">0</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-success text-white"><i class="fas fa-check-circle"></i></div>
                    <div class="ml-3">
                        <h6 class="mb-0 text-muted small uppercase fw-bold">Active Tasks</h6>
                        <h4 class="mb-0 font-weight-bold" id="tileTaskCount">0</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-warning text-white"><i class="fas fa-layer-group"></i></div>
                    <div class="ml-3">
                        <h6 class="mb-0 text-muted small uppercase fw-bold">SubUnits Active</h6>
                        <h4 class="mb-0 font-weight-bold" id="tileSubUnitCount">0</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-info text-white"><i class="fas fa-history"></i></div>
                    <div class="ml-3">
                        <h6 class="mb-0 text-muted small uppercase fw-bold">Latest Update</h6>
                        <h4 class="mb-0 font-weight-bold" id="tileLastDate">--</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Input Form -->
        <div class="col-lg-4">
            <div class="card custom-card">
                <div class="card-body">
                    <h5 class="card-title-line">Add New Task</h5>
                    <form id="TaskMasterForm">
                        <div class="form-group">
                            <label class="font-weight-600 small">Machine Name <span class="text-danger">*</span></label>
                            <select class="form-control form-control-sm" id="MachineID" required></select>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-600 small">SubUnit Name <span class="text-danger">*</span></label>
                            <select class="form-control form-control-sm" id="SubUnitID" required></select>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-600 small">Task Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-sm" id="TaskName" required placeholder="e.g. Oil Change">
                        </div>
                        <div class="form-group">
                            <label class="font-weight-600 small">Description</label>
                            <textarea class="form-control form-control-sm" id="TaskDesc" rows="3" placeholder="Enter instructions..."></textarea>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="resetForm()">Clear</button>
                            <button type="submit" id="saveTask" class="btn btn-save btn-sm">
                                <i class="fas fa-save mr-1"></i> Save Detail
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- List View -->
        <div class="col-lg-8">
            <div class="card custom-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title-line mb-0">Saved Task Inventory</h5>
                        <div class="search-container w-50">
                            <i class="fas fa-search"></i>
                            <input type="text" id="quickSearch" class="form-control search-input" placeholder="Search machine, subunit or task...">
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="mainTaskTable">
                            <thead>
                                <tr>
                                    <th>Machine Asset</th>
                                    <th>SubUnit</th>
                                    <th>Task Identity</th>
                                    <th>Remarks</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="tasktbl">
                                <!-- Data populated via AJAX -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/toastr/Js/toastr.js"></script>

<script>
    $(document).ready(function () {
        // Initialization
        GetMachineData();
        LoadTasks();

        // --- Live Quick Search Logic ---
        $("#quickSearch").on("keyup", function() {
            var value = $(this).val().toLowerCase();
            $("#tasktbl tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

        // --- Dropdown Population ---
        function GetMachineData() {
            $.ajax({
                url: '/Asset/GetmachineData',
                type: 'GET',
                success: function (data) {
                    $('#MachineID').empty().append('<option value="">-- Select Machine --</option>');
                    if(data.machine) {
                        $.each(data.machine, function (i, item) {
                            $('#MachineID').append($('<option>', { value: item.value, text: item.text }));
                        });
                        $('#tileMachineCount').text(data.machine.length);
                    }
                }
            });
        }

        $('#MachineID').change(function () {
            let MachineID = $(this).val();
            var $subunit = $('#SubUnitID');

            $subunit.empty().append('<option value="">-- Loading --</option>');

            if (!MachineID) {
                $subunit.empty().append('<option value="">-- Select Machine First --</option>');
                return;
            }

            $.ajax({
                url: '/Asset/GetSubUnit',
                data: { MachineID: MachineID },
                type: 'GET',
                success: function (data) {
                    $subunit.empty();
                    if (data.success && data.subunit.length > 0) {
                        $subunit.append('<option value="">-- Select SubUnit --</option>');
                        $.each(data.subunit, function (i, item) {
                            $subunit.append($('<option>', { value: item.value, text: item.text }));
                        });
                    } else {
                        $subunit.append('<option value="">-- No SubUnits Linked --</option>');
                        toastr.info('Note: This machine has no linked subunits.');
                    }
                }
            });
        });

        // --- Load Table Data ---
        function LoadTasks() {
            $.ajax({
                type: 'GET',
                url: '/Asset/GetTasks',
                beforeSend: function() { $('#tasktbl').html('<tr><td colspan="5" class="text-center py-4">Synchronizing with server...</td></tr>'); },
                success: function (data) {
                    var table = $('#tasktbl');
                    table.empty();
                    if (data.data && data.data.length > 0) {
                        $.each(data.data, function (index, item) {
                            // FIXED: Added .subunit-pill class for clear visibility
                            var row = `<tr>
                                <td class="fw-bold text-dark"><i class="fas fa-microchip me-2 opacity-50"></i>${item.MachineName}</td>
                                <td><span class="subunit-pill">${item.SubUnitName}</span></td>
                                <td class="fw-bold text-primary">${item.TaskName}</td>
                                <td class="text-muted small italic">${(item.Desc || "No special instructions")}</td>
                                <td class="text-center">
                                    <button class="btn btn-sm text-danger" title="Delete Task Mapping"><i class="fas fa-trash-alt"></i></button>
                                </td>
                            </tr>`;
                            table.append(row);
                        });

                        // Update Tiles
                        $('#tileTaskCount').text(data.data.length);
                        const uniqueSubunits = [...new Set(data.data.map(item => item.SubUnitName))].length;
                        $('#tileSubUnitCount').text(uniqueSubunits);
                        $('#tileLastDate').text(new Date().toLocaleDateString());
                    } else {
                        table.append('<tr><td colspan="5" class="text-center py-5 text-muted italic">No technical tasks mapped to assets yet.</td></tr>');
                    }
                }
            });
        }

        // --- Form Submission ---
        $('#TaskMasterForm').submit(function (e) {
            e.preventDefault();

            var formData = {
                TaskName: $('#TaskName').val(),
                TaSKDesc: $('#TaskDesc').val(),
                MachineID: $('#MachineID').val(),
                SubUnitID: $('#SubUnitID').val(),
            };

            $('#saveTask').prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Saving...');

            $.ajax({
                url: '@Url.Action("SaveTaskMaster", "Asset")',
                type: 'POST',
                data: formData,
                success: function (res) {
                    if (res.success) {
                        toastr.success(res.message);
                        LoadTasks();
                        resetForm();
                    } else {
                        toastr.error(res.message);
                    }
                },
                error: function () { toastr.error("Server connection error."); },
                complete: function () { $('#saveTask').prop('disabled', false).html('<i class="fas fa-save mr-1"></i> Save Detail'); }
            });
        });
    });

    function resetForm() {
        $('#TaskMasterForm')[0].reset();
        $('#SubUnitID').empty().append('<option value="">-- Select Machine First --</option>');
    }
</script>